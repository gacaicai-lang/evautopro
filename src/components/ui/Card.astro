---
// Unified Card component — standardized rounded-xl + border + hover
interface Props {
  href?: string;
  variant?: 'default' | 'elevated' | 'dark';
  padding?: 'sm' | 'md' | 'lg';
  hover?: boolean;
  class?: string;
}

const { href, variant = 'default', padding = 'md', hover = true, class: extraClass = '' } = Astro.props;

const variantClass = {
  default: 'bg-white border border-ink-200',
  elevated: 'bg-white border border-ink-200 shadow-sm',
  dark: 'bg-ink-800 border border-ink-700 text-white',
}[variant];

const paddingClass = { sm: 'p-5', md: 'p-6', lg: 'p-8' }[padding];

const hoverClass = hover
  ? variant === 'dark'
    ? 'hover:border-brand-500 transition-all'
    : 'hover:border-brand-500 hover:shadow-md transition-all'
  : '';

const Tag = href ? 'a' : 'div';
const baseClasses = ['rounded-xl', variantClass, paddingClass, hoverClass, hover && href && 'group block', extraClass];
---

<Tag href={href} class:list={baseClasses}>
  <slot />
</Tag>
