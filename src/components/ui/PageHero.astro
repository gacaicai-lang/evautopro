---
// Unified Hero — full-width dark background + title + optional subtitle/badges/CTA
import Breadcrumb from './Breadcrumb.astro';
import CTAGroup from './CTAGroup.astro';

interface Crumb { label: string; href?: string }
interface CTAButton { label: string; href: string; variant?: 'primary' | 'secondary' | 'ghost' | 'white'; icon?: string }

interface Props {
  eyebrow?: string;
  title: string;
  titleAccent?: string;  // 部分 title 高亮 brand-red
  subtitle?: string;
  breadcrumb?: Crumb[];
  badges?: string[];
  ctas?: CTAButton[];
  bgImage?: string;
  size?: 'sm' | 'md' | 'lg';
}

const {
  eyebrow,
  title,
  titleAccent,
  subtitle,
  breadcrumb = [],
  badges = [],
  ctas = [],
  bgImage = '/images/hero-port-loading.svg',
  size = 'md',
} = Astro.props;

const paddingClass = {
  sm: 'py-16 lg:py-24',
  md: 'py-24 lg:py-32',
  lg: 'py-32 lg:py-40',
}[size];

const titleSize = {
  sm: 'text-3xl lg:text-5xl',
  md: 'text-4xl lg:text-6xl',
  lg: 'text-5xl lg:text-7xl',
}[size];
---

<section class:list={['relative bg-ink-900 overflow-hidden', paddingClass]}>
  <div class="absolute inset-0">
    <img src={bgImage} alt="" class="w-full h-full object-cover opacity-25" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-ink-900/80 via-ink-900/40 to-ink-900/60"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {breadcrumb.length > 0 && <div class="mb-6"><Breadcrumb items={breadcrumb} invert={true} /></div>}
    {eyebrow && <p class="text-xs font-semibold text-brand-500 uppercase tracking-[0.15em] mb-4">{eyebrow}</p>}
    <h1 class:list={[titleSize, 'font-bold text-white leading-[1.05] tracking-tight mb-6 max-w-4xl']}>
      {title}{titleAccent && <> <span class="text-brand-500">{titleAccent}</span></>}
    </h1>
    {subtitle && (
      <p class="text-lg lg:text-xl text-ink-300 max-w-2xl mb-10 leading-relaxed">{subtitle}</p>
    )}
    {badges.length > 0 && (
      <div class="flex flex-wrap gap-3 mb-10">
        {badges.map(b => (
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm text-white backdrop-blur-sm">
            <span class="text-brand-500">✓</span> {b}
          </span>
        ))}
      </div>
    )}
    {ctas.length > 0 && <CTAGroup buttons={ctas} />}
  </div>
</section>
