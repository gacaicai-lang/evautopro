---
// Unified Card Grid wrapper — 2/3/4 column responsive grid
interface Props {
  cols?: 2 | 3 | 4 | 5 | 6;
  gap?: 'sm' | 'md' | 'lg';
}

const { cols = 3, gap = 'md' } = Astro.props;

const colClass = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
  5: 'sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5',
  6: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-6',
}[cols];

const gapClass = { sm: 'gap-4', md: 'gap-6', lg: 'gap-8' }[gap];
---

<div class:list={['grid', colClass, gapClass]}>
  <slot />
</div>
