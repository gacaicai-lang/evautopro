---
const lang = Astro.currentLocale ?? 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;

const items = [
  { label: 'Home', href: `${prefix}/` },
  { label: 'Brands', href: `${prefix}/brands/` },
  { label: 'Cars', href: `${prefix}/cars/` },
  { label: 'Services', href: `${prefix}/services/` },
  { label: 'About Us', href: `${prefix}/about/` },
  { label: 'News', href: `${prefix}/news/` },
  { label: 'Contact', href: `${prefix}/contact/` },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-ink-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href={`${prefix}/`} class="flex items-center gap-2">
        <div class="w-9 h-9 rounded-lg bg-brand-500 flex items-center justify-center text-white font-bold text-lg">
          EV
        </div>
        <span class="font-bold text-ink-900 text-lg">EV Auto Pro</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {items.map(item => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-medium text-ink-700 hover:text-brand-500 hover:bg-ink-50 rounded-md transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right cluster -->
      <div class="flex items-center gap-3">
        <!-- CTA -->
        <a
          href={`${prefix}/contact/quote/`}
          class="hidden sm:inline-flex items-center px-4 py-2 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-md transition-colors"
        >
          Get Quote
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-ink-700 hover:text-brand-500"
          aria-label="Toggle menu"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="lg:hidden hidden border-t border-ink-200 py-2 space-y-1">
      {items.map(item => (
        <a
          href={item.href}
          class="block px-3 py-2 text-sm font-medium text-ink-700 hover:text-brand-500 hover:bg-ink-50 rounded-md"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', !!isHidden);
  });
</script>
