---
// WhatsAppField — a WhatsApp input that forces country identification.
// Renders a country-code <select> (flag + dial code) next to a number input,
// and keeps a hidden input[name="whatsapp"] synced to "+<dial> <number>" so
// every form's existing `new FormData(form)` submit picks up one clean,
// country-qualified WhatsApp value. The number input carries no name (so it
// isn't double-submitted) but still participates in constraint validation.
//
// Wiring is data-attribute based so a page can have several instances; a
// single shared script (bottom of file) wires every [data-wa] group.
interface Props {
  required?: boolean;
  label?: string;
  labelClass?: string;
  wrapClass?: string;   // classes on the outer flex row
  fieldClass?: string;  // classes applied to both the select and the number input
}
const {
  required = false,
  label,
  labelClass = 'block text-base text-ink-900 mb-2',
  wrapClass = '',
  fieldClass = 'px-3 py-3 border border-ink-300 rounded-md focus:border-brand-500 focus:outline-none text-base',
} = Astro.props;

// Primary export markets first, then a broad global set. `value` is the dial
// code; RU/KZ share +7, which is correct — the dial code is what we store.
const countries = [
  { flag: '🇷🇺', name: 'Russia', dial: '+7' },
  { flag: '🇰🇿', name: 'Kazakhstan', dial: '+7' },
  { flag: '🇺🇿', name: 'Uzbekistan', dial: '+998' },
  { flag: '🇦🇪', name: 'UAE', dial: '+971' },
