  { flag: '🇨🇳', name: 'China', dial: '+86' },
];
---

{label && <label class={labelClass}>{label}{required && <span class="text-brand-500"> *</span>}</label>}

<div class:list={['flex gap-2', wrapClass]} data-wa>
  <select data-wa-dial required={required} aria-label="Country code"
          class:list={['shrink-0 max-w-[7.5rem] bg-white', fieldClass]}>
    <option value="" disabled selected>Code</option>
    {countries.map(c => (
      <option value={c.dial}>{c.flag} {c.name} ({c.dial})</option>
    ))}
  </select>
  <input type="tel" data-wa-number inputmode="tel" required={required}
         placeholder="WhatsApp number" aria-label="WhatsApp number"
         class:list={['flex-1 min-w-0', fieldClass]} />
  <input type="hidden" name="whatsapp" data-wa-value />
</div>

<script>
  // Wire every WhatsApp field on the page. Keeps the hidden name="whatsapp"
  // value in sync as "+<dial> <number>" so form submit handlers need no change.
  document.querySelectorAll<HTMLElement>('[data-wa]').forEach(group => {
    const dial = group.querySelector<HTMLSelectElement>('[data-wa-dial]');
    const number = group.querySelector<HTMLInputElement>('[data-wa-number]');
    const hidden = group.querySelector<HTMLInputElement>('[data-wa-value]');
    if (!dial || !number || !hidden) return;
    const sync = () => {
      const n = number.value.replace(/[^\d]/g, '');
      hidden.value = dial.value && n ? `${dial.value} ${n}` : '';
    };
    dial.addEventListener('change', sync);
    number.addEventListener('input', sync);
  });
</script>
