---
const lang = Astro.currentLocale ?? 'en';
const prefix = lang === 'en' ? '' : `/${lang}`;
const year = new Date().getFullYear();

const cols = [
  {
    title: 'Vehicles',
    links: [
      { label: 'All Cars', href: `${prefix}/cars/` },
      { label: 'All Brands', href: `${prefix}/brands/` },
      { label: 'Electric SUVs', href: `${prefix}/cars/?type=suv` },
      { label: 'PHEV / Hybrid', href: `${prefix}/cars/?fuel=phev` },
      { label: 'Pickup Trucks', href: `${prefix}/cars/?type=pickup` },
    ],
  },
  {
    title: 'Markets',
    links: [
      { label: 'Russia', href: `${prefix}/markets/russia/` },
      { label: 'UAE', href: `${prefix}/markets/uae/` },
      { label: 'Kazakhstan', href: `${prefix}/markets/kazakhstan/` },
      { label: 'Brazil', href: `${prefix}/markets/brazil/` },
      { label: 'All Markets', href: `${prefix}/markets/` },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Export Process', href: `${prefix}/services/export-process/` },
      { label: 'Shipping', href: `${prefix}/services/shipping/` },
      { label: 'Inspection', href: `${prefix}/services/inspection/` },
      { label: 'Blog', href: `${prefix}/news/` },
      { label: 'Case Studies', href: `${prefix}/case-studies/` },
      { label: 'FAQ', href: `${prefix}/faq/` },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About', href: `${prefix}/about/` },
      { label: 'Founder', href: `${prefix}/about/founder/` },
      { label: 'Certifications', href: `${prefix}/about/certifications/` },
      { label: 'Contact', href: `${prefix}/contact/` },
      { label: 'Request Quote', href: `${prefix}/contact/quote/` },
    ],
  },
];
---

<footer class="bg-ink-900 text-ink-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand col -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-lg bg-brand-500 flex items-center justify-center text-white font-bold">
            EV
          </div>
          <span class="font-bold text-white text-lg">EV Auto Pro</span>
        </div>
        <p class="text-sm text-ink-400 mb-4">
          Authorized China NEV exporter. 15+ years in trade, 60+ countries served.
        </p>
        <div class="flex gap-3 text-xs">
          <span class="px-2 py-1 bg-ink-800 rounded text-ink-300">商务部出口</span>
          <span class="px-2 py-1 bg-ink-800 rounded text-ink-300">AEO</span>
        </div>
      </div>

      {cols.map(col => (
        <div>
          <h4 class="text-white font-semibold text-sm mb-4">{col.title}</h4>
          <ul class="space-y-2">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-ink-400 hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-ink-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="text-xs text-ink-500">
        © {year} EV Auto Pro. All rights reserved.
      </p>
      <div class="flex gap-4 text-xs text-ink-500">
        <a href={`${prefix}/legal/privacy/`} class="hover:text-white">Privacy Policy</a>
        <a href={`${prefix}/legal/terms/`} class="hover:text-white">Terms of Service</a>
        <a href={`${prefix}/legal/cookies/`} class="hover:text-white">Cookies</a>
      </div>
    </div>
  </div>
</footer>
