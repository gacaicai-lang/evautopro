---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Authorized China new energy vehicle exporter. Wholesale supply to Russia, Middle East, Central Asia, and LATAM.',
  ogImage = '/og-default.jpg',
  noindex = false,
} = Astro.props;

const lang = Astro.currentLocale ?? 'en';
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const fullTitle = title.includes('EV Auto Pro') ? title : `${title} | EV Auto Pro`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'EV Auto Pro',
  legalName: 'Shandong Wencai Import & Export Co., Ltd.',
  url: 'https://evautopro.com/',
  logo: new URL('/favicon.svg', Astro.site).href,
  email: 'cai@evautopro.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Guangzhou',
    addressRegion: 'Guangdong',
    addressCountry: 'CN',
  },
  areaServed: ['Russia', 'Central Asia', 'Middle East', 'Latin America', 'Africa', 'Southeast Asia'],
});
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="facebook-domain-verification" content="wq3w4ezqrt2alz9a7dm6vfp02fef88" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Inter (body) + Instrument Serif (display italic — editorial automotive accent) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={orgSchema} />

    <slot name="head" />
  </head>
  <body class="bg-white text-ink-900 antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
