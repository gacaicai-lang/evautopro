---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { markets } from '../../data/markets';

const marketList = Object.values(markets);
const activeMarkets = marketList.filter(m => m.hasExistingClients);
const openMarkets = marketList.filter(m => !m.hasExistingClients);
---

<BaseLayout
  title="Markets We Serve | EV Auto Pro China NEV Export — 60+ Countries"
  description="China NEV export to 8 key markets: Russia, UAE, Kazakhstan, Uzbekistan, Saudi Arabia, Egypt, Brazil, Mexico. EAC / GCC / SASO / INMETRO / NOM certified."
>
  {/* Hero Banner */}
  <section class="relative h-64 lg:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-ink-900">
      <img src="/images/hero-port-loading.svg" alt="" class="w-full h-full object-cover opacity-40" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-end pb-12">
      <div>
        <h1 class="text-5xl lg:text-6xl font-bold text-white mb-3">Markets</h1>
        <p class="text-lg text-ink-300">Where we ship Chinese cars — 60+ countries</p>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <nav class="text-xs text-ink-500">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2">&gt;&gt;</span>
      <span class="text-ink-900">Markets</span>
    </nav>
  </div>

  {/* Intro */}
  <section class="pt-8 pb-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-5">
        Direct China NEV Export Across 8 Strategic Markets
      </h2>
      <p class="text-base text-ink-600 leading-relaxed">
        From Russia / CIS to LATAM. From Gulf to Africa.<br/>
        Each market handled with local certifications, climate-adapted configs, and proven logistics routes.
      </p>
    </div>
  </section>

  {/* Active Markets (Russia 主推) */}
  {activeMarkets.length > 0 && (
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline gap-3 mb-8">
          <h2 class="text-2xl font-bold text-ink-900">Active Markets</h2>
          <span class="inline-flex items-center px-2 py-0.5 bg-brand-500 text-white text-xs font-bold rounded-full">DEALER NETWORK ESTABLISHED</span>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {activeMarkets.map(m => (
            <a href={`/markets/${m.slug}/`} class="group block bg-white border-2 border-brand-500 rounded-2xl overflow-hidden hover:shadow-xl transition-all">
              <div class="aspect-[4/3] bg-ink-100 overflow-hidden">
                <img src={m.hero_image} alt={m.name} class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <div class="text-3xl">{m.flag}</div>
                  <div>
                    <h3 class="font-bold text-base text-ink-900">{m.name}</h3>
                    <p class="text-xs text-ink-500">{m.cn}</p>
                  </div>
                </div>
                <p class="text-sm text-ink-600 leading-relaxed mb-4">{m.tagline}</p>
                <div class="pt-4 border-t border-ink-100 flex items-center justify-between">
                  <span class="text-xs text-brand-500 font-bold">{m.certifications.map(c => c.name).join(' · ')}</span>
                  <span class="text-sm font-semibold text-brand-500 group-hover:translate-x-1 transition-transform">Explore →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Open for Partnership Markets */}
  <section class="py-12 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline gap-3 mb-3">
        <h2 class="text-2xl font-bold text-ink-900">Open for Partnership</h2>
        <span class="inline-flex items-center px-2 py-0.5 bg-white border border-ink-300 text-ink-700 text-xs font-bold rounded-full">★ FIRST-MOVER BENEFITS</span>
      </div>
      <p class="text-sm text-ink-600 mb-8">
        We are actively building dealer networks in these markets. Authorized exporter terms available to first-mover partners.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {openMarkets.map(m => (
          <a href={`/markets/${m.slug}/`} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-2xl overflow-hidden transition-all">
            <div class="aspect-[4/3] bg-ink-100 overflow-hidden">
              <img src={m.hero_image} alt={m.name} class="w-full h-full object-cover" />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="text-3xl">{m.flag}</div>
                <div>
                  <h3 class="font-bold text-base text-ink-900 group-hover:text-brand-500 transition-colors">{m.name}</h3>
                  <p class="text-xs text-ink-500">{m.cn}</p>
                </div>
              </div>
              <p class="text-sm text-ink-600 leading-relaxed mb-4">{m.tagline}</p>
              <div class="pt-4 border-t border-ink-100 flex items-center justify-between">
                <span class="text-xs text-ink-700 font-bold">{m.certifications.map(c => c.name).join(' · ')}</span>
                <span class="text-sm font-semibold text-brand-500 group-hover:translate-x-1 transition-transform">Explore →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-20 bg-ink-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Don't see your market?</h2>
      <p class="text-base text-ink-300 mb-8">
        We serve 60+ countries beyond these 8. Tell us your destination — we'll handle certification + logistics.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact/quote/" class="inline-flex items-center px-8 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request Custom Market Quote
        </a>
        <a href="https://wa.me/8613800000000" class="inline-flex items-center px-8 py-3 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
