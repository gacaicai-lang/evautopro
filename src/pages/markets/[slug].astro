---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { markets, type Market } from '../../data/markets';
import { cars } from '../../data/cars';

export function getStaticPaths() {
  return Object.values(markets).map(m => ({
    params: { slug: m.slug },
    props: { market: m },
  }));
}

interface Props { market: Market; }
const { market } = Astro.props;

// 真图 slugs (geely + jetour 已有 launder webp)
const realImageSlugs = ['geely-atlas', 'geely-coolray', 'geely-emgrand', 'geely-monjaro', 'jetour-t2', 'jetour-dasheng', 'jetour-x70plus'];
---

<BaseLayout
  title={`Export Chinese Cars to ${market.name} | EV Auto Pro — ${market.certifications[0]?.name} Certified`}
  description={`Direct China NEV export to ${market.name}. ${market.tagline}. Top models, logistics routes, and certification handled.`}
>
  {/* 1. HERO */}
  <section class="relative bg-ink-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={market.hero_image} alt={market.name} class="w-full h-full object-cover opacity-25" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-40">
      <nav class="text-xs text-ink-400 mb-6">
        <a href="/" class="hover:text-brand-500">Home</a> ·
        <a href="/markets/" class="hover:text-brand-500">Markets</a> ·
        <span class="text-white">{market.name}</span>
      </nav>
      <div class="flex items-center gap-4 mb-6">
        <div class="text-6xl">{market.flag}</div>
        {market.hasExistingClients && (
          <div class="inline-flex items-center px-3 py-1 bg-brand-500 text-white text-xs font-bold rounded-full">
            ACTIVE DEALER NETWORK
          </div>
        )}
        {!market.hasExistingClients && (
          <div class="inline-flex items-center px-3 py-1 bg-white/10 border border-white/30 text-white text-xs font-bold rounded-full">
            ★ OPEN FOR PARTNERSHIP
          </div>
        )}
      </div>
      <h1 class="text-5xl lg:text-7xl font-bold text-white leading-tight mb-3">
        Export to <span class="text-brand-500">{market.name}</span>
      </h1>
      <p class="text-2xl text-brand-500 font-semibold mb-3">{market.cn}</p>
      <p class="text-lg lg:text-xl text-ink-300 max-w-3xl mb-10">{market.tagline}</p>
      <div class="flex flex-wrap gap-3">
        <a href={`/contact/quote/?market=${market.slug}`} class="btn-primary">Request {market.name} Quote</a>
        {market.ctaLangBtn && (
          <a href={`https://wa.me/8613800000000?text=${market.ctaLangBtn.whatsappText}`} class="inline-flex items-center px-6 py-3 bg-white text-ink-900 hover:bg-ink-100 font-semibold rounded-lg transition-colors">
            {market.ctaLangBtn.label}
          </a>
        )}
      </div>
    </div>
  </section>

  {/* 2. STATS */}
  <section class="py-16 lg:py-20 border-b border-ink-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        {market.stats.map(s => (
          <div>
            <div class="text-4xl lg:text-5xl font-bold text-brand-500 mb-2">{s.num}</div>
            <div class="text-base font-semibold text-ink-900">{s.label}</div>
            <div class="text-xs text-ink-500 mt-1">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 3. IMPORT PROCESS */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">{market.name}-Specific Process</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{market.importProcess.length}-step {market.name} import workflow</h2>
        <p class="text-base text-ink-600 mt-3 max-w-2xl mx-auto">
          Customized for {market.certifications[0]?.name} certification, climate, and local customs.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {market.importProcess.map(p => (
          <div class="bg-white border border-ink-200 rounded-xl p-5 hover:border-brand-500 hover:shadow-md transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-brand-500 flex items-center justify-center text-white font-bold">
                {p.step}
              </div>
              <div class="text-xs text-brand-500 font-semibold">{p.days}</div>
            </div>
            <h3 class="font-semibold text-base text-ink-900 mb-2">{p.title}</h3>
            <p class="text-xs text-ink-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 4. TOP MODELS */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Best-Fit for {market.name}</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Recommended models</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {market.topModels.slice(0, 6).map(m => {
          const carData = cars[m.slug];
          if (!carData) return null;
          const img = realImageSlugs.includes(m.slug)
            ? `/images/真图/laundered/evautopro-${m.slug}-01.webp`
            : `/images/car-${m.slug}.svg`;
          return (
            <a href={`/cars/${m.slug}/`} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-xl overflow-hidden transition-all">
              <div class="aspect-[16/10] bg-ink-100 overflow-hidden">
                <img src={img} alt={carData.model} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="p-5">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 bg-ink-100 text-ink-600 text-xs rounded">{carData.body_type}</span>
                  <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{carData.fuel_type}</span>
                </div>
                <h3 class="text-base font-semibold text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{carData.brand} {carData.model}</h3>
                <p class="text-sm text-ink-600 mb-4 leading-relaxed">{m.reason}</p>
                <div class="flex items-end justify-between pt-3 border-t border-ink-100">
                  <div>
                    <div class="text-xs text-ink-500">From FOB</div>
                    <div class="text-lg font-bold text-ink-900">${carData.pricing.fob_min.toLocaleString()}</div>
                  </div>
                  <span class="text-sm font-semibold text-brand-500 group-hover:translate-x-1 transition-transform">View →</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {/* 5. LOGISTICS ROUTES */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Logistics</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{market.logisticsRoutes.length} shipping routes to {market.name}</h2>
      </div>
      <div class="grid lg:grid-cols-3 gap-6">
        {market.logisticsRoutes.map(r => (
          <div class="bg-white border-2 border-ink-200 hover:border-brand-500 rounded-2xl p-8 transition-all relative">
            <span class="absolute top-4 right-4 px-3 py-1 bg-brand-500 text-white text-[10px] font-bold rounded-full">{r.flag}</span>
            <h3 class="text-xl font-bold text-ink-900 mb-3">{r.name}</h3>
            <div class="flex flex-wrap items-center gap-2 mb-4 text-sm">
              <span class="px-2 py-0.5 bg-brand-50 text-brand-700 rounded font-semibold">{r.duration}</span>
              <span class="text-ink-500">·</span>
              <span class="text-ink-700">{r.fits}</span>
            </div>
            <ul class="space-y-2 mb-4">
              {r.advantages.map(adv => (
                <li class="flex items-start gap-2 text-sm text-ink-700">
                  <span class="text-brand-500 mt-0.5">✓</span>
                  <span>{adv}</span>
                </li>
              ))}
            </ul>
            {r.note && <p class="text-xs text-orange-600 italic">⚠ {r.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 6. COMPLIANCE */}
  <section class="py-24 lg:py-32 bg-ink-900">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">{market.name} Compliance</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white">{market.complianceTitle}</h2>
      </div>
      <div class="bg-ink-800 rounded-2xl p-8">
        <p class="text-base text-ink-300 mb-6 leading-relaxed">{market.complianceIntro}</p>
        <ol class="space-y-3 mb-8">
          {market.complianceSteps.map((step, i) => (
            <li class="flex items-start gap-3 text-sm text-ink-300">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center text-white font-bold text-xs">{i + 1}</span>
              <span class="pt-1">{step}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {/* 7. CASES OR PARTNERSHIP INVITATION */}
  {market.hasExistingClients ? (
    <section class="py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">{market.name} Dealer Cases</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Active dealer network</h2>
          <p class="text-base text-ink-600 mt-3">Active customer cases — Russian dealer partnerships established since 2018.</p>
        </div>
      </div>
    </section>
  ) : (
    <section class="py-24 lg:py-32">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-brand-50 to-white border-2 border-brand-500 rounded-2xl p-10 lg:p-14 text-center">
          <div class="text-5xl mb-5">🤝</div>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-4">Open for {market.name} Partnership</h2>
          <p class="text-base text-ink-700 max-w-2xl mx-auto mb-8 leading-relaxed">
            We are actively building dealer network in {market.name}. As an authorized China NEV exporter with established Russia/CIS operations, we are looking for serious {market.name} partners to expand our presence.
          </p>
          <div class="grid sm:grid-cols-3 gap-6 max-w-3xl mx-auto mb-10 text-sm">
            <div>
              <div class="font-bold text-brand-500 mb-1">First-Mover Benefits</div>
              <p class="text-ink-600 text-xs">Exclusive city/region terms for founding partners</p>
            </div>
            <div>
              <div class="font-bold text-brand-500 mb-1">Direct Factory Pricing</div>
              <p class="text-ink-600 text-xs">No middleman markup. Verify on request.</p>
            </div>
            <div>
              <div class="font-bold text-brand-500 mb-1">Full Compliance Support</div>
              <p class="text-ink-600 text-xs">{market.certifications[0]?.name} + customs handled.</p>
            </div>
          </div>
          <div class="flex flex-wrap justify-center gap-3">
            <a href={`/contact/quote/?market=${market.slug}&type=partnership`} class="btn-primary">Apply as {market.name} Dealer</a>
            <a href="/about/" class="btn-secondary">Learn about EV Auto Pro</a>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* 8. WEATHER BOX (if applicable) */}
  {market.weatherBox && (
    <section class="py-16 bg-ink-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-[100px_1fr] gap-6 items-start bg-white border-2 border-brand-500 rounded-2xl p-8">
          <div class="text-7xl text-center">{market.weatherBox.icon}</div>
          <div>
            <h3 class="text-2xl font-bold text-ink-900 mb-3">{market.weatherBox.title}</h3>
            <div class="grid sm:grid-cols-2 gap-4 text-sm text-ink-700">
              <ul class="space-y-2">
                {market.weatherBox.items.slice(0, Math.ceil(market.weatherBox.items.length / 2)).map(item => (
                  <li class="flex items-start gap-2"><span class="text-brand-500">✓</span>{item}</li>
                ))}
              </ul>
              <ul class="space-y-2">
                {market.weatherBox.items.slice(Math.ceil(market.weatherBox.items.length / 2)).map(item => (
                  <li class="flex items-start gap-2"><span class="text-brand-500">✓</span>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* 9. MARKET-SPECIFIC FAQ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">{market.name} FAQ</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{market.faqs.length} questions specific to {market.name}</h2>
      </div>
      <div class="space-y-3">
        {market.faqs.map(f => (
          <details class="group bg-white border border-ink-200 rounded-xl overflow-hidden hover:border-brand-500 transition-colors">
            <summary class="flex items-start justify-between gap-4 cursor-pointer p-5 list-none">
              <span class="font-semibold text-base text-ink-900 flex-1 group-open:text-brand-500 transition-colors">{f.q}</span>
              <svg class="flex-shrink-0 w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-sm text-ink-700 leading-relaxed border-t border-ink-100">
              <div class="pt-4">{f.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* 10. CTA */}
  <section class="py-24 lg:py-32 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-4">Export to {market.name} today</h2>
      <p class="text-lg text-white/90 mb-10 max-w-2xl mx-auto">
        {market.certifications[0]?.name} certified · {market.tagline.split('·')[market.tagline.split('·').length - 1].trim()}
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`/contact/quote/?market=${market.slug}`} class="inline-flex items-center px-8 py-4 bg-white text-brand-500 hover:bg-ink-100 font-semibold rounded-lg transition-colors">
          Request {market.name} Quote
        </a>
        {market.ctaLangBtn && (
          <a href={`https://wa.me/8613800000000?text=${market.ctaLangBtn.whatsappText}`} class="inline-flex items-center px-8 py-4 bg-ink-900 text-white hover:bg-ink-800 font-semibold rounded-lg transition-colors">
            {market.ctaLangBtn.label}
          </a>
        )}
      </div>
    </div>
  </section>

  {/* Schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'Service',
    name: `China NEV Export to ${market.name}`,
    provider: { '@type': 'Organization', name: 'EV Auto Pro', url: 'https://evautopro.com' },
    areaServed: { '@type': 'Country', name: market.name },
    serviceType: 'Vehicle Export & Import Service',
    description: market.tagline,
  })} />
</BaseLayout>
