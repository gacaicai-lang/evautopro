---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import CardGrid from '../../components/ui/CardGrid.astro';
import CTAGroup from '../../components/ui/CTAGroup.astro';

// =====================================================================
// FAQ DATA — keep all content here so editing is easy.
// 9 categories, 40 questions, buyer-decision flow (no "Sourcing").
// =====================================================================

const faqCategories = [
  {
    id: 'vehicles-inventory',
    label: 'Vehicles & Inventory',
    desc: 'Stock, vehicle condition, and order flexibility.',
    icon: 'car',
  },
  {
    id: 'brands-models',
    label: 'Brands & Models',
    desc: 'Available Chinese NEV brands and how to pick the right model.',
    icon: 'tag',
  },
  {
    id: 'price-quotation',
    label: 'Price & Quotation',
    desc: 'How quotes work, what is included, and dealer pricing.',
    icon: 'dollar',
  },
  {
    id: 'order-payment',
    label: 'Order & Payment',
    desc: 'Order flow, deposits, payment methods and order changes.',
    icon: 'cart',
  },
  {
    id: 'shipping-delivery',
    label: 'Shipping & Delivery',
    desc: 'RoRo / container / multimodal routes, lead times and forwarders.',
    icon: 'ship',
  },
  {
    id: 'documents-customs',
    label: 'Documents & Customs',
    desc: 'Export paperwork, certificates and clearance support.',
    icon: 'doc',
  },
  {
    id: 'quality-inspection',
    label: 'Quality & Inspection',
    desc: 'Pre-shipment checks, third-party inspection and quality control.',
    icon: 'check',
  },
  {
    id: 'warranty-aftersales',
    label: 'Warranty & After-sales',
    desc: 'Brand warranty, spare parts supply and post-delivery support.',
    icon: 'wrench',
  },
  {
    id: 'dealer-cooperation',
    label: 'Dealer Cooperation',
    desc: 'Becoming a partner, long-term supply and fleet/bulk orders.',
    icon: 'handshake',
  },
];

const faqs = [
  // ---------- Vehicles & Inventory (5) ----------
  { id: 'all-new', cat: 'vehicles-inventory', q: 'Are all vehicles brand new?',
    a: 'Yes. We mainly export brand-new Chinese new energy vehicles, including official export versions and selected domestic models suitable for overseas markets. Vehicle condition, mileage, configuration and documents will be confirmed before quotation.' },
  { id: 'ready-stock', cat: 'vehicles-inventory', q: 'Do you have ready stock vehicles?',
    a: 'Yes. We maintain access to ready stock vehicles from multiple Chinese EV brands and dealer networks. Stock availability changes quickly, so please send your target model, quantity, color and destination country for confirmation.' },
  { id: 'single-unit', cat: 'vehicles-inventory', q: 'Can I order only one vehicle?',
    a: 'Yes. We can support single-unit orders for selected models and countries. For dealers and importers, mixed-model orders and container or Ro-Ro shipments are also available.' },
  { id: 'mix-models', cat: 'vehicles-inventory', q: 'Can I mix different models in one order?',
    a: 'Yes. You can mix different brands, models, colors and configurations in one shipment, depending on stock availability and shipping method.' },
  { id: 'ev-and-hybrid', cat: 'vehicles-inventory', q: 'Do you export both EV and hybrid vehicles?',
    a: 'Yes. We export pure electric vehicles, plug-in hybrid vehicles, range-extended EVs and selected fuel vehicles according to buyer demand and market regulations.' },

  // ---------- Brands & Models (5) ----------
  { id: 'which-brands', cat: 'brands-models', q: 'Which Chinese EV brands do you export?',
    a: 'We work with popular Chinese NEV brands such as BYD, Geely, Zeekr, Li Auto, Chery, MG, Leapmotor, XPeng, Neta and other export-ready brands. Available brands depend on stock, market policy and export documents.' },
  { id: 'supply-byd', cat: 'brands-models', q: 'Can you supply BYD vehicles?',
    a: 'Yes. BYD is one of the most requested brands for export. Please send the exact model, version, color and destination country so we can check current availability and export conditions.' },
  { id: 'choose-models', cat: 'brands-models', q: 'Can you help me choose models for my market?',
    a: 'Yes. Based on your country, budget, customer profile, road conditions and charging environment, we can recommend suitable models for retail, fleet, taxi, rental or dealership sales.' },
  { id: 'color-config', cat: 'brands-models', q: 'Can I request a specific color or configuration?',
    a: 'Yes. We can check specific colors, trims and configurations. If the exact version is not available, we will suggest similar alternatives.' },
  { id: 'lhd-rhd', cat: 'brands-models', q: 'Do you support left-hand drive and right-hand drive vehicles?',
    a: 'Most Chinese EVs are left-hand drive. Some right-hand drive models may be available depending on brand and market. Please confirm your destination country before ordering.' },

  // ---------- Price & Quotation (5) ----------
  { id: 'get-quote', cat: 'price-quotation', q: 'How do I get a quotation?',
    a: 'Send us the vehicle model, version, quantity, destination country and preferred shipping method. We will check stock and provide a quotation with vehicle price, export fees and estimated shipping cost when available.' },
  { id: 'price-include', cat: 'price-quotation', q: 'What does your price include?',
    a: 'The price can be quoted as EXW, FOB, CIF or other terms depending on your request. We will clearly list what is included, such as vehicle cost, inland transport, export handling, documents and shipping.' },
  { id: 'fixed-price', cat: 'price-quotation', q: 'Are your prices fixed?',
    a: 'Vehicle prices may change due to stock, exchange rate, manufacturer policy and market demand. Final price is confirmed before payment.' },
  { id: 'dealer-pricing', cat: 'price-quotation', q: 'Can you offer dealer pricing?',
    a: 'Yes. For repeat buyers, bulk orders and local distributors, we can offer dealer-level pricing and long-term cooperation terms.' },
  { id: 'price-differ', cat: 'price-quotation', q: 'Why are prices different between suppliers?',
    a: 'Prices vary depending on vehicle source, configuration, stock status, export documents, logistics cost and service responsibility. We focus on transparent pricing and safe export delivery.' },

  // ---------- Order & Payment (5) ----------
  { id: 'order-process', cat: 'order-payment', q: 'What is the order process?',
    a: 'The usual process is model confirmation, stock checking, quotation, proforma invoice, deposit payment, vehicle preparation, inspection, export documents, shipping and final delivery support.' },
  { id: 'payment-methods', cat: 'order-payment', q: 'What payment methods do you accept?',
    a: 'We usually accept bank transfer and other agreed international payment methods. Payment terms depend on order size, buyer type and cooperation history.' },
  { id: 'safe-pay', cat: 'order-payment', q: 'Is it safe to pay your company?',
    a: 'We provide company documents, proforma invoice, contract and payment instructions before payment. Buyers can also verify company information and order details before proceeding.' },
  { id: 'deposit', cat: 'order-payment', q: 'Do I need to pay a deposit?',
    a: 'Most orders require a deposit to lock the vehicle and start preparation. The balance is usually paid before shipment or according to agreed terms.' },
  { id: 'cancel-order', cat: 'order-payment', q: 'Can I cancel or change an order?',
    a: 'Order changes depend on vehicle preparation status and supplier policy. If the vehicle has already been reserved or processed, cancellation may involve cost.' },

  // ---------- Shipping & Delivery (5) ----------
  { id: 'shipping-methods', cat: 'shipping-delivery', q: 'Which shipping methods do you support?',
    a: 'We support container shipping, Ro-Ro shipping, land transport and multimodal shipping depending on destination country, vehicle quantity and cost efficiency.' },
  { id: 'delivery-time', cat: 'shipping-delivery', q: 'How long does delivery take?',
    a: 'Delivery time depends on stock availability, export document preparation, shipping schedule and destination port. We will provide an estimated timeline before order confirmation.' },
  { id: 'export-my-country', cat: 'shipping-delivery', q: 'Can you export to my country?',
    a: 'We export to many markets including the Middle East, Central Asia, Africa, Latin America, Southeast Asia and selected European markets. Please send your destination country and port for confirmation.' },
  { id: 'ship-to-port', cat: 'shipping-delivery', q: 'Can you arrange shipping to my port?',
    a: 'Yes. We can help arrange shipping to major destination ports and provide shipping cost estimates based on the vehicle quantity and shipping method.' },
  { id: 'own-forwarder', cat: 'shipping-delivery', q: 'Can I use my own freight forwarder?',
    a: 'Yes. You can use your own forwarder if preferred. We can coordinate vehicle handover, export documents and loading support in China.' },

  // ---------- Documents & Customs (4) ----------
  { id: 'export-docs', cat: 'documents-customs', q: 'What documents do you provide for export?',
    a: 'Common documents include commercial invoice, packing list, sales contract, export declaration documents, vehicle certificate and other documents required by the destination market.' },
  { id: 'customs-clearance', cat: 'documents-customs', q: 'Can you help with customs clearance?',
    a: 'We can support export customs clearance in China. Import customs clearance in the destination country is usually handled by the buyer or local customs broker.' },
  { id: 'vehicle-certs', cat: 'documents-customs', q: 'Do the vehicles come with certificates?',
    a: 'Available certificates depend on the vehicle brand, model and destination country. We will confirm document availability before quotation.' },
  { id: 'registration-docs', cat: 'documents-customs', q: 'Can you provide documents for registration in my country?',
    a: 'We can provide available export and vehicle documents from China. Registration requirements vary by country, so buyers should confirm local import and registration rules before ordering.' },

  // ---------- Quality & Inspection (3) ----------
  { id: 'pre-ship-inspect', cat: 'quality-inspection', q: 'Do you inspect vehicles before shipment?',
    a: 'Yes. We can check vehicle condition, appearance, mileage, configuration, battery status and basic functions before shipment. Photos and videos can be provided.' },
  { id: 'third-party-inspect', cat: 'quality-inspection', q: 'Can I arrange third-party inspection?',
    a: 'Yes. Buyers may arrange third-party inspection before shipment. We can coordinate inspection time and vehicle location.' },
  { id: 'ensure-quality', cat: 'quality-inspection', q: 'How do you ensure vehicle quality?',
    a: 'We source vehicles from reliable channels, confirm vehicle information before order, inspect before shipment and provide transparent photos, videos and documents.' },

  // ---------- Warranty & After-sales (3) ----------
  { id: 'warranty', cat: 'warranty-aftersales', q: 'Do the vehicles have warranty?',
    a: 'Warranty policy depends on brand, model and destination country. Some manufacturer warranties may be limited outside China. We will explain the available warranty situation before order confirmation.' },
  { id: 'spare-parts', cat: 'warranty-aftersales', q: 'Can you supply spare parts?',
    a: 'Yes. We can help supply common spare parts and maintenance parts for exported vehicles, especially for repeat buyers and dealers.' },
  { id: 'aftersales-support', cat: 'warranty-aftersales', q: 'Do you provide after-sales support?',
    a: 'We provide remote support for vehicle information, parts sourcing and basic after-sales coordination. Local repair and maintenance should be handled by qualified service providers in the destination market.' },

  // ---------- Dealer Cooperation (5) ----------
  { id: 'become-dealer', cat: 'dealer-cooperation', q: 'Can I become your local dealer or partner?',
    a: 'Yes. We welcome cooperation with overseas dealers, importers, fleet buyers and local distributors. Please share your company profile, target market and monthly demand.' },
  { id: 'long-term-supply', cat: 'dealer-cooperation', q: 'Can you support long-term supply?',
    a: 'Yes. For qualified partners, we can support regular stock updates, model recommendations, dealer pricing and repeated shipment arrangements.' },
  { id: 'marketing-materials', cat: 'dealer-cooperation', q: 'Can you provide marketing materials?',
    a: 'We can provide available vehicle photos, specifications and basic promotional materials to support local sales, depending on brand and model.' },
  { id: 'fleet-bulk', cat: 'dealer-cooperation', q: 'Do you support fleet or bulk orders?',
    a: 'Yes. We can support fleet orders for taxi, rental, corporate use, government projects and dealer bulk purchasing.' },
  { id: 'why-us', cat: 'dealer-cooperation', q: 'Why should overseas dealers work with you?',
    a: 'We combine multi-brand vehicle access, export experience, document support, shipping coordination and long-term after-sales parts support to help dealers import Chinese EVs more safely and efficiently.' },
];

// Attach category count + global numbering (01-40)
let globalIdx = 0;
const numberedFaqs = faqs.map(f => ({ ...f, num: ++globalIdx }));

const categoriesWithCount = faqCategories.map(c => ({
  ...c,
  count: numberedFaqs.filter(f => f.cat === c.id).length,
}));

// Group faqs by category for rendering
const grouped = categoriesWithCount.map(c => ({
  ...c,
  items: numberedFaqs.filter(f => f.cat === c.id),
}));

// Inline SVG icon paths (line, 24x24, stroke 1.5) — kept compact
const ICONS: Record<string, string> = {
  car:       'M5 17h14M5 17l-1-4 1-3h14l1 3-1 4M5 17v2a1 1 0 001 1h1a1 1 0 001-1v-2M16 17v2a1 1 0 001 1h1a1 1 0 001-1v-2M7 13h10',
  tag:       'M7 7h.01M7 3h5l9 9-9 9-9-9V7a4 4 0 014-4z',
  dollar:    'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2m0 0c-1.657 0-3-.895-3-2M12 4a8 8 0 100 16 8 8 0 000-16z',
  cart:      'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293A1 1 0 005.414 17H17m0 0a2 2 0 100 4 2 2 0 000-4zm-10 2a2 2 0 11-4 0 2 2 0 014 0z',
  ship:      'M3 17l3-3 3 3M12 7l3 3-3 3M21 17l-3-3-3 3M3 21h18M5 17V9l7-4 7 4v8',
  doc:       'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  check:     'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  wrench:    'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z',
  handshake: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
};

// 4 popular dealer questions (Section 5)
const popular = [
  { ref: 'ready-stock',       q: 'Do you have ready stock vehicles?',
    a: 'Yes — we keep access to ready stock from multiple brands. Send target model and country to confirm availability.' },
  { ref: 'mix-models',        q: 'Can I mix different models in one shipment?',
    a: 'Yes. Mix brands, models, colors and configurations in one container or RoRo shipment based on stock.' },
  { ref: 'export-docs',       q: 'What documents are provided for export?',
    a: 'Commercial invoice, packing list, sales contract, export declaration, vehicle certificate and destination-specific paperwork.' },
  { ref: 'export-my-country', q: 'Can you export to my country?',
    a: 'We export to 60+ countries across MEA, CIS, LATAM, SE Asia and select EU. Send your destination port to confirm.' },
];
---

<BaseLayout
  title="FAQ | Chinese EV Export Questions | EV Auto Pro"
  description="Find answers about Chinese EV export, vehicle inventory, brands, pricing, shipping, documents, payment, warranty and dealer cooperation."
>
  {/* ====================================================================
       SECTION 1 — HERO (full-bleed car background + left text overlay)
       ==================================================================== */}
  <section class="relative bg-ink-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/faq-hero.webp" alt="" class="w-full h-full object-cover" loading="eager" />
      {/* Dark overlay — left strong → right soft, so text reads cleanly while car stays visible */}
      <div class="absolute inset-0 bg-gradient-to-r from-ink-900/90 via-ink-900/65 to-ink-900/20"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-500 text-white text-xs font-semibold rounded-full mb-6 tracking-[0.12em]">
          BUYER FAQ
        </div>
        <h1 class="text-4xl lg:text-5xl xl:text-[3.5rem] font-bold text-white leading-[1.1] tracking-tight mb-5">
          Frequently Asked Questions for <span class="text-brand-500">Chinese EV Export</span>
        </h1>
        <p class="text-base lg:text-lg text-ink-200 mb-8 leading-relaxed max-w-xl">
          Find clear answers about vehicle inventory, brands, pricing, shipping, documents, payment, warranty and dealer cooperation before importing Chinese new energy vehicles.
        </p>
        <CTAGroup buttons={[
          { label: 'Get A Quote', href: '/contact/quote/', variant: 'primary' },
          { label: 'View Available Vehicles', href: '/cars/', variant: 'ghost' },
        ]} />
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 2 — QUICK FAQ CATEGORIES (9-card 3x3 grid)
       ==================================================================== */}
  <Section eyebrow="Help Centre" title="Browse Questions by Topic" subtitle="Start with the questions most importers and dealers ask before placing an order." align="center">
    <CardGrid cols={3} gap="md">
      {categoriesWithCount.map(c => (
        <a href={`#${c.id}`} class="group block bg-white border border-ink-200 hover:border-brand-500 rounded-xl p-6 transition-all hover:shadow-sm">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-11 h-11 rounded-lg bg-ink-100 group-hover:bg-brand-50 flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-ink-700 group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={ICONS[c.icon]} />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2 mb-1.5">
                <h3 class="font-semibold text-base text-ink-900 group-hover:text-brand-500 transition-colors leading-tight">{c.label}</h3>
                <span class="flex-shrink-0 text-[11px] text-ink-500 font-medium tabular-nums">{c.count} Qs</span>
              </div>
              <p class="text-xs text-ink-600 leading-relaxed">{c.desc}</p>
            </div>
          </div>
        </a>
      ))}
    </CardGrid>
  </Section>

  {/* ====================================================================
       SECTION 3 — MAIN FAQ AREA (sticky nav + accordion + consultant card)
       ==================================================================== */}
  <section class="bg-ink-50 border-y border-ink-200 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">

        {/* LEFT — sticky category nav (desktop) / horizontal tabs (mobile) */}
        <aside class="lg:col-span-3">
          {/* Mobile tabs (horizontal scrollable) */}
          <nav class="lg:hidden -mx-4 px-4 mb-8 overflow-x-auto">
            <ul class="flex gap-2 whitespace-nowrap pb-2">
              <li><a href="#all" class="inline-block px-4 py-2 bg-ink-900 text-white text-sm font-semibold rounded-full">All Questions</a></li>
              {categoriesWithCount.map(c => (
                <li><a href={`#${c.id}`} class="inline-block px-4 py-2 bg-white border border-ink-200 text-ink-700 hover:border-brand-500 hover:text-brand-500 text-sm font-medium rounded-full transition-colors">{c.label}</a></li>
              ))}
            </ul>
          </nav>

          {/* Desktop sticky vertical nav */}
          <div class="hidden lg:block sticky top-24">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-ink-500 mb-4 px-4">Categories</p>
            <nav class="bg-white border border-ink-200 rounded-xl overflow-hidden">
              <ul>
                <li>
                  <a href="#all" data-faq-link data-target="all"
                     class="faq-nav-link flex items-center justify-between gap-2 px-4 py-3 border-l-2 border-brand-500 bg-brand-50 text-ink-900 font-semibold text-sm">
                    <span>All Questions</span>
                    <span class="text-[11px] text-ink-500 font-medium tabular-nums">40</span>
                  </a>
                </li>
                {categoriesWithCount.map(c => (
                  <li class="border-t border-ink-100">
                    <a href={`#${c.id}`} data-faq-link data-target={c.id}
                       class="faq-nav-link flex items-center justify-between gap-2 px-4 py-3 border-l-2 border-transparent text-ink-700 hover:bg-ink-50 hover:text-ink-900 text-sm transition-colors">
                      <span>{c.label}</span>
                      <span class="text-[11px] text-ink-500 font-medium tabular-nums">{c.count}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </nav>

            {/* ============ EXPORT CONSULTANT CARD (Section 4 inline) ============ */}
            <div class="mt-6 bg-white border border-ink-200 rounded-xl p-6">
              <div class="inline-flex items-center gap-2 px-2.5 py-0.5 bg-brand-50 text-brand-700 text-[10px] font-semibold uppercase tracking-[0.15em] rounded-full mb-4">
                Export Support
              </div>
              <h3 class="text-lg font-bold text-ink-900 leading-snug mb-2">
                Need help choosing the right EV?
              </h3>
              <p class="text-xs text-ink-600 leading-relaxed mb-5">
                Tell us your target market, preferred brands, quantity and budget. Our export team will help you check stock, confirm configurations and prepare a quotation.
              </p>
              <div class="space-y-2 mb-5">
                <a href="https://wa.me/8619912345678" target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-lg transition-colors">
                  WhatsApp Us
                </a>
                <a href="/contact/quote/" class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-white border border-ink-300 hover:border-ink-500 text-ink-900 text-sm font-semibold rounded-lg transition-colors">
                  Get A Quote
                </a>
                <a href="mailto:cai@evautopro.com" class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-white border border-ink-300 hover:border-ink-500 text-ink-900 text-sm font-semibold rounded-lg transition-colors">
                  Email Us
                </a>
              </div>
              <ul class="space-y-2.5 pt-5 border-t border-ink-100 text-xs">
                <li class="flex items-start gap-2">
                  <span class="text-ink-400 flex-shrink-0">·</span>
                  <span class="text-ink-600"><span class="text-ink-900 font-medium">Response time:</span> Within 12 hours</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ink-400 flex-shrink-0">·</span>
                  <span class="text-ink-600"><span class="text-ink-900 font-medium">Support:</span> Stock · price · documents · shipping</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ink-400 flex-shrink-0">·</span>
                  <span class="text-ink-600"><span class="text-ink-900 font-medium">Buyer type:</span> Dealer · importer · fleet buyer</span>
                </li>
              </ul>
            </div>
          </div>
        </aside>

        {/* RIGHT — accordion area */}
        <div class="lg:col-span-9" id="all">
          <div class="space-y-14">
            {grouped.map(cat => (
              <div id={cat.id} class="scroll-mt-24">
                <div class="flex items-center gap-3 mb-6 pb-4 border-b border-ink-200">
                  <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-white border border-ink-200 flex items-center justify-center">
                    <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d={ICONS[cat.icon]} />
                    </svg>
                  </div>
                  <h2 class="text-xl lg:text-2xl font-bold text-ink-900 tracking-tight">{cat.label}</h2>
                  <span class="ml-auto text-xs text-ink-500 font-medium tabular-nums">{cat.count} questions</span>
                </div>
                <div class="space-y-3">
                  {cat.items.map((faq, i) => (
                    <details
                      id={faq.id}
                      class="group bg-white border border-ink-200 rounded-xl hover:border-brand-300 transition-colors scroll-mt-24"
                      open={faq.num === 1 && i === 0 && cat.id === 'vehicles-inventory'}
                    >
                      <summary class="flex items-start gap-4 cursor-pointer p-5 list-none">
                        <span class="flex-shrink-0 text-sm font-bold text-brand-500 tabular-nums pt-0.5 w-7">
                          {String(faq.num).padStart(2, '0')}
                        </span>
                        <span class="flex-1 font-semibold text-base text-ink-900 leading-snug pr-2 group-open:text-brand-500 transition-colors">
                          {faq.q}
                        </span>
                        <span class="flex-shrink-0 w-6 h-6 rounded-full border border-ink-300 group-hover:border-brand-500 text-ink-500 group-hover:text-brand-500 group-open:border-brand-500 group-open:text-brand-500 flex items-center justify-center mt-0.5 transition-colors relative">
                          <svg class="w-3 h-3 absolute transition-opacity group-open:opacity-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                          <svg class="w-3 h-3 absolute opacity-0 transition-opacity group-open:opacity-100" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
                        </span>
                      </summary>
                      <div class="px-5 pb-5 pt-1">
                        <div class="pl-11 pr-2 pt-4 border-t border-ink-100 text-sm text-ink-700 leading-[1.75]">
                          {faq.a}
                        </div>
                      </div>
                    </details>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 5 — POPULAR QUESTIONS for buyers (gray bg, 4 cards)
       ==================================================================== */}
  <Section bg="gray" eyebrow="Buyer Spotlight" title="Most Asked by Overseas Dealers" subtitle="The four questions every importer asks us first.">
    <CardGrid cols={4} gap="md">
      {popular.map((p, i) => (
        <a href={`#${p.ref}`} class="group block bg-white border border-ink-200 hover:border-brand-500 rounded-xl p-6 transition-all hover:shadow-sm h-full">
          <div class="text-xs font-bold text-brand-500 tabular-nums mb-3">Q{String(i + 1).padStart(2, '0')}</div>
          <h3 class="font-semibold text-base text-ink-900 group-hover:text-brand-500 transition-colors leading-snug mb-3">{p.q}</h3>
          <p class="text-xs text-ink-600 leading-relaxed mb-5">{p.a}</p>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-brand-500 group-hover:translate-x-0.5 transition-transform">
            Read Answer
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </CardGrid>
  </Section>

  {/* ====================================================================
       SECTION 6 — DARK CTA (matches Home final CTA)
       ==================================================================== */}
  <Section bg="dark" title="Ready to Import Chinese EVs?" subtitle="Send us your target model, quantity and destination country. We will check stock, quote price and suggest the best shipping solution." align="center" maxWidth="normal">
    <CTAGroup align="center" buttons={[
      { label: 'Get A Quote', href: '/contact/quote/', variant: 'primary' },
      { label: 'WhatsApp Us', href: 'https://wa.me/8619912345678', variant: 'white' },
    ]} />
  </Section>

  {/* ====================================================================
       FAQPage JSON-LD (first 10 questions per spec, expand to all 40)
       ==================================================================== */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: numberedFaqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />

  {/* Sticky-nav active-state highlighter — vanilla JS, no library */}
  <script is:inline>
    (function() {
      const links = document.querySelectorAll('[data-faq-link]');
      if (!links.length) return;
      const setActive = (target) => {
        links.forEach(l => {
          const isActive = l.getAttribute('data-target') === target;
          l.classList.toggle('border-brand-500', isActive);
          l.classList.toggle('bg-brand-50', isActive);
          l.classList.toggle('text-ink-900', isActive);
          l.classList.toggle('font-semibold', isActive);
          l.classList.toggle('border-transparent', !isActive);
          l.classList.toggle('text-ink-700', !isActive);
        });
      };
      // Track scroll to highlight current section
      const sections = ['all', ...Array.from(document.querySelectorAll('[id^="vehicles-"],[id^="brands-"],[id^="price-"],[id^="order-"],[id^="shipping-"],[id^="documents-"],[id^="quality-"],[id^="warranty-"],[id^="dealer-"]')).map(el => el.id).filter(id => id.includes('-') && !id.includes('cat-'))];
      const groupIds = ['vehicles-inventory','brands-models','price-quotation','order-payment','shipping-delivery','documents-customs','quality-inspection','warranty-aftersales','dealer-cooperation'];
      window.addEventListener('scroll', () => {
        const y = window.scrollY + 140;
        let current = 'all';
        for (const id of groupIds) {
          const el = document.getElementById(id);
          if (el && el.offsetTop <= y) current = id;
        }
        setActive(current);
      }, { passive: true });
    })();
  </script>
</BaseLayout>
