                </svg>
                WhatsApp Us
              </a>

              {/* Divider */}
              <div class="border-t border-ink-100 my-6"></div>

              {/* Contact info */}
              <ul class="space-y-4 text-sm">
                <li class="flex items-start gap-3">
                  <svg class="flex-shrink-0 w-5 h-5 text-brand-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <div>
                    <div class="text-ink-500 text-xs mb-0.5">Email</div>
                    <a href="mailto:cai@evautopro.com" class="text-ink-900 font-medium hover:text-brand-500">cai@evautopro.com</a>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="flex-shrink-0 w-5 h-5 text-brand-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <div>
                    <div class="text-ink-500 text-xs mb-0.5">Phone / WhatsApp</div>
                    <a href="tel:+8619912345678" class="text-ink-900 font-medium hover:text-brand-500">+86 199 1234 5678</a>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="flex-shrink-0 w-5 h-5 text-brand-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <div class="text-ink-500 text-xs mb-0.5">Working Hours</div>
                    <div class="text-ink-900 font-medium">Mon-Sat 9:00-18:00 (UTC+8)</div>
                  </div>
                </li>
              </ul>
            </div>

            {/* Category quick jump */}
            <div class="bg-ink-50 border border-ink-200 rounded-2xl p-5">
              <p class="text-xs font-semibold text-ink-500 uppercase tracking-wider mb-3">Jump to section</p>
              <ul class="space-y-2">
                {categoriesWithIdx.map(c => (
                  <li>
                    <a href={`#${c.id}`} class="flex items-center justify-between text-sm text-ink-700 hover:text-brand-500 group">
                      <span class="flex items-center gap-2">
                        <span class="text-base">{c.icon}</span>
                        <span class="group-hover:underline">{c.label}</span>
                      </span>
                      <span class="text-xs text-ink-400">{c.questions.length}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {/* ============ Bottom: 4 Trust Badge ============ */}
  <section class="bg-ink-50 border-t border-ink-200 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-14 h-14 rounded-full bg-white border-2 border-brand-50 flex items-center justify-center">
            <svg class="w-7 h-7 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h4 class="text-sm font-bold text-ink-900 mb-1">Quality Inspection</h4>
            <p class="text-xs text-ink-600 leading-relaxed">360° multi-point check on every unit before shipping.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-14 h-14 rounded-full bg-white border-2 border-brand-50 flex items-center justify-center">
            <svg class="w-7 h-7 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h4 class="text-sm font-bold text-ink-900 mb-1">15 Years Export</h4>
            <p class="text-xs text-ink-600 leading-relaxed">Serving 60+ countries with Russia-CIS specialization.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-14 h-14 rounded-full bg-white border-2 border-brand-50 flex items-center justify-center">
