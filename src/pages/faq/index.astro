---
import BaseLayout from '../../layouts/BaseLayout.astro';

// === Categories (data unchanged) ===
const categories = [
  {
    id: 'sourcing',
    label: 'Sourcing & Inventory',
    intro: 'Where the cars come from, what we keep in stock, and how each unit is verified before shipping.',
    questions: [
      { q: "What is the source of EV Auto Pro's vehicles?", a: 'We source directly from 6 authorized OEMs (Changan, Deepal, Qiyuan, Geely, VW China, Jetour) under signed dealer MoUs, plus active sourcing from 35 additional Chinese brands. Every unit traceable to factory invoice — no grey market.' },
      { q: 'Are all vehicles stored in China?', a: 'Yes. We maintain 200+ units in our Shanghai bonded warehouse for immediate shipment. Custom orders are produced at factory then transferred to our warehouse before export.' },
      { q: 'Do you sell new vehicles or only used cars?', a: 'We specialize in brand-new vehicles (latest model year 2026). Certified used cars launching Q3 2026 — currently we focus on new EV / PHEV / EREV / ICE.' },
      { q: 'What vehicle types do you specialize in?', a: 'Coupe SUVs, family SUVs, sedans, MPVs, and pickup trucks across BEV / PHEV / EREV / Hybrid / ICE drivetrains. Plus right-hand drive (RHD) variants for UK / SA / PK / ID markets.' },
      { q: 'Can I inspect vehicles in person before purchase?', a: 'Yes. You can visit our Shanghai warehouse or arrange a factory tour. We also provide free photo/video inspection reports for remote buyers (3-5 days turnaround).' },
      { q: 'What if my desired vehicle is unavailable?', a: 'We can place a custom factory order (30-60 days lead time) or recommend equivalent models from our 35-brand sourcing network. Send us your spec — we respond within 24h.' },
      { q: 'How is vehicle condition verified before shipment?', a: 'Multi-point inspection at our bonded warehouse covering exterior, interior, electrical, drivetrain, battery (for EV/PHEV), and software systems. Full photo + video report shared before container loading.' },
      { q: 'Are vehicles inspected before shipping?', a: 'Every single unit. We follow a 360° pre-shipment inspection protocol — same standard for retail and bulk dealer orders.' },
    ],
  },
  {
    id: 'logistics',
    label: 'Logistics & Customs',
    intro: 'Routes, lead times, documents, and the practical mechanics of moving cars to your port.',
    questions: [
      { q: 'Which regions does EV Auto Pro serve?', a: 'Active in 60+ countries. Primary markets: Russia & CIS, Middle East (UAE/SA/Egypt), Central Asia (Kazakhstan/Uzbekistan), LATAM (Brazil/Mexico), Africa, SE Asia.' },
      { q: 'Do you handle export documentation and compliance?', a: 'Yes — full document package including MoFCOM export license, commercial invoice, packing list, B/L, certificate of origin, vehicle export certificate, and destination-specific certs (EAC / GCC / INMETRO / SASO / NOM).' },
      { q: 'How soon can my vehicle ship?', a: 'In-stock units: 3-15 days from PI signing. Custom factory orders: 30-60 days. Lead time depends on shipping route and destination port readiness.' },
      { q: 'What shipment details are required?', a: 'Destination port, target arrival date, preferred shipping method (RoRo / Container / Block Train / Truck), consignee company details, and import license (if required by destination country).' },
      { q: 'What export documents are provided?', a: 'Commercial Invoice, Packing List, Bill of Lading (B/L), Certificate of Origin (CO), Vehicle Export Certificate, Insurance Policy, and destination-specific certification (EAC for Russia/CIS, GCC for ME, INMETRO for Brazil, etc).' },
      { q: 'What are typical shipping times?', a: 'Russia (St. Petersburg via RoRo): 30-45 days · UAE (Jebel Ali RoRo): 18-25 days · Kazakhstan (Block Train via Khorgos): 18-22 days · Brazil (Santos container): 35-50 days · Africa (varies by port): 25-45 days.' },
      { q: 'What fees apply at destination?', a: 'Import duty (varies by country, 10-40%), VAT, port handling, customs broker fees, last-mile delivery. We can include a CIF + duty estimate in your quote — transparent line-item breakdown.' },
      { q: 'When to choose RoRo vs Container shipping?', a: 'RoRo: lower cost, fastest, recommended for ≥10 units. Container (40HC): better for ≤8 units, more protection, supports CKD/SKD parts. Block Train: best for Central Asia (Khorgos route).' },
    ],
  },
  {
    id: 'payment',
    label: 'Payment & Transactions',
    intro: 'T/T, L/C, Incoterms, and what currencies clear through our bank.',
    questions: [
      { q: 'Is buying from EV Auto Pro secure for international purchases?', a: 'Yes. We are MOFCOM-licensed, AEO-certified, ISO 9001 certified. Standard payment terms: T/T 30% deposit + 70% before shipment. L/C at sight accepted from major banks. Every transaction backed by signed PI + B/L.' },
      { q: 'What payment methods are accepted?', a: 'T/T bank wire (standard), L/C at sight (major banks), Western Union for small orders, OA (open account) after first successful order with credit verification. We do NOT accept crypto or third-party escrow.' },
      { q: 'Are shipping costs included in quotes?', a: 'We provide FOB (Free On Board, before sea freight), CIF (Cost+Insurance+Freight to destination port), and EXW (Ex Works factory) options. You choose which Incoterm fits your import setup.' },
      { q: 'What is the difference between CIF and FOB?', a: 'FOB = price to load on ship at Shanghai port (you handle ocean freight). CIF = price including freight + insurance to your destination port (we handle shipping). EXW = factory pickup price (you arrange all logistics). CIF is simplest for first-time importers.' },
      { q: 'Can I pay in my local currency?', a: 'We invoice in USD by default. Bank wire from RUB / AED / KZT / BRL / etc converts at your bank rate. CNY direct settlement available for select markets — contact us.' },
      { q: 'How is payment confirmation communicated?', a: 'Email + WhatsApp confirmation within 2 business hours of receipt. Bank slip + SWIFT code shared for your record. Production / shipment milestone unlocked automatically upon confirmation.' },
    ],
  },
  {
    id: 'quality',
    label: 'Compliance & Quality',
    intro: 'Certifications, climate fit, charging compatibility — built for global markets.',
    questions: [
      { q: 'Which Chinese EVs meet EU standards?', a: 'Geely (Coolray, Atlas), VW China (ID.3, ID.7), and select BYD models meet EU WVTA homologation. For Russia / CIS, EAC certification applies. We handle homologation paperwork for each destination.' },
      { q: 'How do Chinese NEV batteries perform in high-temperature regions (Middle East / Africa)?', a: 'CATL / BYD blade batteries are LFP chemistry — thermally stable up to 60°C ambient. We recommend BEV with LFP for desert markets. PHEV / EREV models suit areas with limited charging infrastructure.' },
      { q: 'Can Chinese cars handle extreme cold weather (Russia / Kazakhstan)?', a: 'Yes. Our cars sold to Russia/CIS undergo cold-weather configuration: upgraded battery thermal management, cold-resistant tires, engine block heaters (for ICE/PHEV). Tested down to -30°C.' },
      { q: 'How to evaluate charging feasibility for Chinese NEVs in Africa?', a: 'Most Chinese NEVs support GB/T (China standard). For destinations without GB/T infrastructure, we supply CCS2 (Europe), Type 1 (US/Japan), or CHAdeMO adapter cables. PHEV alternative reduces charging dependence.' },
      { q: 'Are these cars compliant with Russian EAC certification?', a: 'Yes. All vehicles exported to Russia / CIS undergo EAC certification through our in-house compliance team. Documentation handled end-to-end — no delays at Russian customs.' },
      { q: 'What is CISPR / EMC certification and does it apply to Chinese cars?', a: 'CISPR 25 covers electromagnetic compatibility for in-vehicle electronics. All our exported vehicles pre-comply with CISPR 25 Class 3+ for global markets. Required for GCC and select EU destinations.' },
    ],
  },
  {
    id: 'oem',
    label: 'OEM & Customization',
    intro: 'Private label, paint codes, RHD, CKD kits, and fleet-specific configurations.',
    questions: [
      { q: 'Do you support OEM badging / private label?', a: 'Yes. We support OEM badging for orders ≥50 units (single model). Brand removal / dealer logo / custom paint codes available with 30-45 day production lead time.' },
      { q: 'Can you customize trim / color / interior configuration?', a: 'Yes. Factory custom orders: paint codes (10+ colors), wheel size (16-20"), interior trim (cloth/leather/PU), audio upgrade. MOQ varies by spec — typically ≥10 units per config.' },
      { q: 'Right-Hand Drive (RHD) conversion available?', a: 'Select models support factory RHD: Geely Coolray / Atlas, Changan CS75 Plus, Jetour T2. We do NOT offer aftermarket RHD conversion (not safe for export markets). MOQ for RHD batch: 20 units.' },
      { q: 'Can you supply CKD / SKD kits for local assembly?', a: 'Yes. CKD (Complete Knock Down) kits available for Egypt, Pakistan, Algeria markets where local assembly = lower import duty. MOQ 30 units. Factory provides assembly manual + tooling list.' },
      { q: 'Do you offer fleet-specific configurations (taxi / police / military)?', a: 'Yes for commercial fleets: taxi-grade interior (PU seats, partition glass), additional ports for fleet telematics, dual-battery for police use. Government / military orders require additional licensing — case-by-case.' },
      { q: 'Can I order pre-loaded language/region software?', a: 'Yes. Infotainment language pre-load: Russian, Arabic, Spanish, Portuguese, French. Navigation maps: Russia/CIS, GCC, LATAM. Specify at PI stage — pre-installed at factory.' },
    ],
  },
  {
    id: 'warranty',
    label: 'Warranty & After-Sales',
    intro: '5-year coverage, depots in Moscow / Almaty / Dubai, and end-to-end claim support.',
    questions: [
      { q: 'What is the manufacturer warranty on exported vehicles?', a: 'Standard 5-year / 100,000 km vehicle warranty (varies by brand). 8-year / 160,000 km battery warranty on BEV / PHEV. We provide warranty card + service manual in destination language.' },
      { q: 'Where can my customer claim warranty service?', a: 'Authorized dealers in your market (we share network list) or our after-sales depots in Moscow, Almaty, Dubai. For markets without local dealer, we coordinate factory technical support remotely + parts express ship.' },
      { q: 'Do you cover transit damage / port damage?', a: 'Yes. Marine cargo insurance is included in CIF quotes (or available as optional add-on for FOB). Coverage: ALL RISKS including transit damage, port handling, weather. Claim process: photo evidence + B/L → 14-day resolution.' },
      { q: 'Do you provide spare parts supply?', a: 'Yes. We maintain parts depots in Moscow / Almaty / Dubai. Other markets: parts ship from Shanghai within 7-14 days. Genuine OEM + quality aftermarket parts. Bulk distributor pricing available.' },
      { q: 'What if a vehicle has a defect after delivery?', a: 'Report within 7 days of arrival with photo/video evidence. Minor defects (interior trim, lights): replacement parts shipped within 14 days at our cost. Major defects (drivetrain, frame): factory inspection + remedy or replacement unit.' },
      { q: 'Do you offer technical training for our service team?', a: 'Yes for distributor partners. Factory training (3-5 days, in China) covers diagnostic tools, common repairs, software updates. Remote training via video also available.' },
    ],
  },
];

// Numbering: global 01-40 across all categories
const allFaqs = categories.flatMap(c => c.questions);
let globalIdx = 0;
const cats = categories.map(c => ({
  ...c,
  questions: c.questions.map(q => ({ ...q, idx: ++globalIdx })),
}));
---

<BaseLayout
  title="FAQ — EV Auto Pro"
  description="Forty common questions about sourcing and exporting Chinese new energy vehicles. Cai answers personally within 24h."
>
  {/* =================================================================
     Editorial automotive aesthetic — Instrument Serif italic display
     paired with Inter body. Monochrome ink + restrained brand-red accent.
     Generous whitespace (8pt grid, 24-96px rhythm).
     ================================================================= */}

  {/* ============ Hero ============ */}
  <section class="relative overflow-hidden bg-ink-50">
    <div class="absolute inset-0">
      <img src="/images/faq-hero.webp" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/85 via-35% to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 py-24 lg:py-36">
      <div class="max-w-md">
        <p class="text-[11px] font-medium uppercase tracking-[0.22em] text-brand-500 mb-5">
          EV Auto Pro · Help Centre
        </p>
        <h1 class="font-serif italic text-4xl lg:text-[3.25rem] leading-[1.05] text-ink-900 mb-6">
          Frequently<br/>Asked Questions
        </h1>
        <div class="w-10 h-px bg-ink-300 mb-6"></div>
        <p class="text-[15px] text-ink-600 leading-relaxed">
          Forty answers on sourcing, logistics, payment and compliance — written by the team that handles every shipment.
        </p>
      </div>
    </div>
  </section>

  {/* ============ Breadcrumb ============ */}
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-8 pb-2">
    <nav class="text-[11px] uppercase tracking-[0.18em] text-ink-400">
      <a href="/" class="hover:text-brand-500 transition-colors">Home</a>
      <span class="mx-3">/</span>
      <span class="text-ink-700">FAQ</span>
    </nav>
  </div>

  {/* ============ Main: 12-col grid, generous gap ============ */}
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-12 gap-y-16 lg:gap-x-20">

        {/* ====== Left: 7/12 — Categories ====== */}
        <div class="col-span-12 lg:col-span-7 space-y-24 lg:space-y-28">
          {cats.map((cat, catIdx) => (
            <div id={cat.id} class="scroll-mt-28">
              {/* Category header — minimal, no boxes */}
              <header class="mb-10">
                <p class="text-[11px] font-medium uppercase tracking-[0.22em] text-brand-500 mb-4">
                  {String(catIdx + 1).padStart(2, '0')} · {cat.questions.length} Questions
                </p>
                <h2 class="font-serif italic text-3xl lg:text-4xl leading-[1.1] text-ink-900 mb-4">
                  {cat.label}
                </h2>
                <p class="text-sm text-ink-500 leading-relaxed max-w-md">
                  {cat.intro}
                </p>
              </header>

              {/* Questions — hairline divider, editorial */}
              <div class="border-t border-ink-200">
                {cat.questions.map((faq, i) => (
                  <details
                    class="group border-b border-ink-200"
                    open={catIdx === 0 && i === 0}
                  >
                    <summary class="flex items-start gap-6 cursor-pointer py-6 list-none">
                      <span class="flex-shrink-0 text-xs font-medium text-ink-400 tabular-nums pt-1 w-6">
                        {String(faq.idx).padStart(2, '0')}
                      </span>
                      <span class="flex-1 text-[15px] font-medium text-ink-900 leading-snug pr-4 group-open:text-brand-500 transition-colors">
                        {faq.q}
                      </span>
                      <span class="flex-shrink-0 text-ink-400 group-open:text-brand-500 group-open:rotate-45 transition-all duration-200 mt-0.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" />
                        </svg>
                      </span>
                    </summary>
                    <div class="pl-12 pr-4 pb-7 pt-1 text-[14px] text-ink-600 leading-[1.75] max-w-2xl">
                      {faq.a}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          ))}
        </div>

        {/* ====== Right: sticky aside, 4/12 with offset ====== */}
        <aside class="col-span-12 lg:col-span-4 lg:col-start-9">
          <div class="lg:sticky lg:top-28 space-y-6">

            {/* === Contact card === */}
            <div class="bg-ink-50 rounded-2xl p-8">
              <p class="text-[11px] font-medium uppercase tracking-[0.22em] text-brand-500 mb-4">
                Talk to us
              </p>
              <h3 class="font-serif italic text-2xl leading-[1.15] text-ink-900 mb-3">
                Still curious?
              </h3>
              <p class="text-[13px] text-ink-600 leading-relaxed mb-7">
                Cai personally reviews every inquiry. Reply within 24h, in English, Chinese or Russian.
              </p>

              <a href="/contact/quote/" class="flex items-center justify-between w-full px-5 py-3 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-lg transition-colors mb-3 group">
                <span>Request a Quote</span>
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
              <a href="https://wa.me/8619912345678" target="_blank" rel="noopener" class="flex items-center justify-between w-full px-5 py-3 bg-white border border-ink-200 hover:border-ink-400 text-ink-900 text-sm font-semibold rounded-lg transition-colors group">
                <span class="flex items-center gap-2.5">
                  <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                  </svg>
                  WhatsApp
                </span>
                <svg class="w-4 h-4 text-ink-400 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>

              <div class="border-t border-ink-200 mt-7 pt-6 space-y-4">
                <div>
                  <p class="text-[10px] uppercase tracking-[0.18em] text-ink-400 mb-1">Email</p>
                  <a href="mailto:cai@evautopro.com" class="text-sm text-ink-900 hover:text-brand-500 transition-colors">cai@evautopro.com</a>
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-[0.18em] text-ink-400 mb-1">Phone</p>
                  <a href="tel:+8619912345678" class="text-sm text-ink-900 hover:text-brand-500 transition-colors tabular-nums">+86 199 1234 5678</a>
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-[0.18em] text-ink-400 mb-1">Hours</p>
                  <p class="text-sm text-ink-900 tabular-nums">Mon–Sat 09:00–18:00 (UTC+8)</p>
                </div>
              </div>
            </div>

            {/* === Section index (minimal, no emoji) === */}
            <nav class="pl-8 pr-2">
              <p class="text-[10px] uppercase tracking-[0.22em] text-ink-400 mb-4">On this page</p>
              <ol class="space-y-3">
                {cats.map((c, i) => (
                  <li>
                    <a href={`#${c.id}`} class="flex items-baseline gap-3 text-sm text-ink-600 hover:text-brand-500 transition-colors group">
                      <span class="text-[11px] text-ink-400 font-medium tabular-nums">{String(i + 1).padStart(2, '0')}</span>
                      <span class="flex-1 group-hover:underline decoration-1 underline-offset-4">{c.label}</span>
                      <span class="text-[11px] text-ink-400 tabular-nums">{c.questions.length}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {/* ============ Trust strip (minimal, no boxes) ============ */}
  <section class="border-t border-ink-200 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <p class="text-[11px] uppercase tracking-[0.22em] text-ink-400 mb-10 text-center">
        Why exporters trust EV Auto Pro
      </p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 max-w-5xl mx-auto">
        <div class="text-center">
          <p class="font-serif italic text-3xl lg:text-4xl text-brand-500 mb-2 tabular-nums">15+</p>
          <p class="text-[11px] uppercase tracking-[0.16em] text-ink-900 font-medium mb-1">Years of Export</p>
          <p class="text-xs text-ink-500 leading-relaxed">Serving 60+ countries since 2010, Russia-CIS specialist.</p>
        </div>
        <div class="text-center">
          <p class="font-serif italic text-3xl lg:text-4xl text-brand-500 mb-2 tabular-nums">200+</p>
          <p class="text-[11px] uppercase tracking-[0.16em] text-ink-900 font-medium mb-1">Units in Stock</p>
          <p class="text-xs text-ink-500 leading-relaxed">Shanghai bonded warehouse, 3-15 day ship-out window.</p>
        </div>
        <div class="text-center">
          <p class="font-serif italic text-3xl lg:text-4xl text-brand-500 mb-2 tabular-nums">5-yr</p>
          <p class="text-[11px] uppercase tracking-[0.16em] text-ink-900 font-medium mb-1">Warranty Coverage</p>
          <p class="text-xs text-ink-500 leading-relaxed">Parts depots in Moscow, Almaty and Dubai.</p>
        </div>
        <div class="text-center">
          <p class="font-serif italic text-3xl lg:text-4xl text-brand-500 mb-2 tabular-nums">24h</p>
          <p class="text-[11px] uppercase tracking-[0.16em] text-ink-900 font-medium mb-1">Reply Promise</p>
          <p class="text-xs text-ink-500 leading-relaxed">Cai personally answers every inquiry in EN / 中 / RU.</p>
        </div>
      </div>
    </div>
  </section>

  {/* FAQPage Schema (SEO) */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: allFaqs.map(f => ({
      '@type': 'Question', name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
</BaseLayout>
