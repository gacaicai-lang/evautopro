---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    slug: 'export-process',
    icon: '📋',
    iconPath: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/>',
    title: 'Export Process',
    subtitle: '8-step from inquiry to delivery',
    desc: 'Transparent timeline. Each milestone tracked. Founder-led personal review on every order.',
    days: '~30 days standard',
    ready: true,
  },
  {
    slug: 'shipping',
    icon: '🚢',
    iconPath: '<path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2s2.5 2 5 2 2.5-2 5-2c1.3 0 1.9.5 2.5 1"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/><path d="M12 10v4"/><path d="M12 2v3"/>',
    title: 'Shipping & Logistics',
    subtitle: 'RoRo / Container / Block Train / Truck',
    desc: 'All shipping modes covered. Marine cargo insurance included. GPS tracking + daily WhatsApp updates.',
    days: '18-45 days transit',
    ready: true,
  },
  {
    slug: 'inspection',
    icon: '🔍',
    iconPath: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><path d="m8 11 2 2 4-4"/>',
    title: 'Pre-Shipment Inspection',
    subtitle: 'Multi-point QC + photo/video report',
    desc: '360° inspection at our bonded warehouse. Independent third-party inspection available on request.',
    days: '3-5 days',
    ready: true,
  },
  {
    slug: 'financing',
    icon: '💰',
    iconPath: '<line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
    title: 'Payment & Financing',
    subtitle: 'T/T, L/C, OA — flexible terms',
    desc: 'T/T 30+70 standard. L/C at sight from major banks. OA credit after first successful order.',
    days: 'Same day to 30 days',
    ready: true,
  },
  {
    slug: 'after-sales',
    icon: '🛠',
    iconPath: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/><path d="M3.5 21 8 16.5"/>',
    title: 'After-Sales & Parts',
    subtitle: 'Parts depots + warranty support',
    desc: 'Spare parts depots in Moscow / Almaty / Dubai. Genuine OEM + aftermarket. Warranty coordination.',
    days: '7-14 days global delivery',
    ready: true,
  },
];
---

<BaseLayout
  title="Services | EV Auto Pro — Full China NEV Export Service Stack"
  description="End-to-end China NEV export services: 8-step process, shipping, inspection, financing, after-sales. Founder-led, transparent pricing."
>
  {/* Hero */}
  <section class="relative h-64 lg:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-ink-900">
      <img src="/images/hero-port-loading.svg" alt="" class="w-full h-full object-cover opacity-40" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-end pb-12">
      <div>
        <h1 class="text-5xl lg:text-6xl font-bold text-white mb-3">Services</h1>
        <p class="text-lg text-ink-300">End-to-end China NEV export stack</p>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <nav class="text-xs text-ink-500">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2">&gt;&gt;</span>
      <span class="text-ink-900">Services</span>
    </nav>
  </div>

  {/* Intro */}
  <section class="pt-8 pb-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-5">
        One-Stop China Car Export Services
      </h2>
      <p class="text-base text-ink-600 leading-relaxed">
        5 service modules covering every stage from inquiry to after-sales.<br/>
        Founder-led, transparent, end-to-end. No middlemen, no hidden fees.
      </p>
    </div>
  </section>

  {/* 5 Service Cards */}
  <section class="pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <a href={s.ready ? `/services/${s.slug}/` : '/contact/'} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-2xl p-8 transition-all relative">
            {!s.ready && (
              <span class="absolute top-4 right-4 px-2 py-1 bg-ink-100 text-ink-600 text-[10px] font-bold rounded">PAGE WIP</span>
            )}
            <div class="w-16 h-16 mb-5 rounded-xl bg-brand-50 group-hover:bg-brand-500 flex items-center justify-center transition-colors">
              <svg class="w-9 h-9 text-brand-500 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.iconPath} />
            </div>
            <h3 class="text-xl font-bold text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{s.title}</h3>
            <p class="text-sm text-brand-500 font-semibold mb-3">{s.subtitle}</p>
            <p class="text-sm text-ink-600 leading-relaxed mb-5">{s.desc}</p>
            <div class="flex items-center justify-between pt-4 border-t border-ink-100">
              <span class="text-xs text-ink-500">{s.days}</span>
              <span class="text-sm font-semibold text-brand-500 group-hover:translate-x-1 transition-transform">
                {s.ready ? 'Read more →' : 'Contact us →'}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-20 bg-ink-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Need a custom service combo?</h2>
      <p class="text-base text-ink-300 mb-8">Cai personally designs end-to-end plans for repeat dealer partners.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact/quote/" class="inline-flex items-center px-8 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
        <a href="https://wa.me/8613800000000" class="inline-flex items-center px-8 py-3 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
