---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services, type Service } from '../../data/services';

export function getStaticPaths() {
  return Object.values(services).map(s => ({
    params: { slug: s.slug },
    props: { service: s },
  }));
}

interface Props { service: Service; }
const { service } = Astro.props;
---

<BaseLayout
  title={`${service.title} | EV Auto Pro China NEV Export Service`}
  description={`${service.tagline}. ${service.intro.slice(0, 100)}`}
>
  {/* 1. HERO */}
  <section class="relative bg-gradient-to-br from-ink-900 via-ink-800 to-ink-900 py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <img src="/images/hero-port-loading.svg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs text-ink-400 mb-6">
        <a href="/" class="hover:text-brand-500">Home</a> ·
        <a href="/services/" class="hover:text-brand-500">Services</a> ·
        <span class="text-white">{service.title}</span>
      </nav>

      <div class="flex items-center gap-4 mb-6">
        <div class="w-20 h-20 rounded-2xl bg-brand-500 flex items-center justify-center">
          <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={service.iconPath} />
        </div>
      </div>

      <p class="text-sm font-semibold text-brand-500 uppercase tracking-wider mb-4">Service</p>
      <h1 class="text-4xl lg:text-6xl font-bold text-white leading-tight mb-6 max-w-4xl">{service.title}</h1>
      <p class="text-xl text-brand-500 font-semibold mb-3">{service.subtitle}</p>
      <p class="text-lg lg:text-xl text-ink-300 mb-10 max-w-2xl leading-relaxed">{service.tagline}</p>

      <div class="flex flex-wrap gap-3">
        {service.heroBadges.map(b => (
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm text-white">
            <span class="text-brand-500">✓</span> {b}
          </span>
        ))}
      </div>
    </div>
  </section>

  {/* 2. TRUST STATS */}
  <section class="py-16 lg:py-20 border-b border-ink-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        {service.trustStats.map(s => (
          <div>
            <div class="text-4xl lg:text-5xl font-bold text-brand-500 mb-2">{s.num}</div>
            <div class="text-sm font-semibold text-ink-900">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 3. INTRO */}
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-ink-700 leading-relaxed">{service.intro}</p>
    </div>
  </section>

  {/* 4. PHASES (if export-process) */}
  {service.phases && (
    <section class="py-20 lg:py-28 bg-ink-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Overview</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{service.phases.length} phases · {service.steps?.length || 0} milestones</h2>
        </div>
        <div class="relative">
          <div class="hidden lg:block absolute top-12 left-0 right-0 h-0.5 bg-gradient-to-r from-brand-500 to-brand-700"></div>
          <div class="grid grid-cols-2 lg:grid-cols-5 gap-6 relative z-10">
            {service.phases.map(p => (
              <div class="text-center">
                <div class="w-24 h-24 mx-auto mb-5 rounded-full bg-white border-4 border-brand-500 flex items-center justify-center text-4xl shadow-lg">{p.icon}</div>
                <div class="text-xs font-bold text-brand-500 uppercase tracking-wider mb-2">Phase {p.num}</div>
                <h3 class="text-lg font-bold text-ink-900 mb-2">{p.label}</h3>
                <p class="text-xs text-ink-600 mb-2">{p.desc}</p>
                <div class="inline-flex items-center px-2 py-0.5 bg-brand-50 text-brand-700 text-xs font-semibold rounded">{p.days}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  {/* 5. STEPS DETAILS (if export-process) */}
  {service.steps && (
    <section class="py-20 lg:py-28">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Step Breakdown</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Responsibilities at each step</h2>
        </div>
        <div class="space-y-8">
          {service.steps.map(s => (
            <div class="bg-white border border-ink-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
              <div class="grid lg:grid-cols-[160px_1fr] gap-0">
                <div class="bg-brand-500 text-white p-6 flex flex-col items-center justify-center text-center">
                  <div class="text-5xl font-bold">{s.num}</div>
                  <div class="text-xs uppercase tracking-wider mt-2 opacity-80">Step</div>
                  <div class="text-sm font-semibold mt-3 px-2 py-1 bg-white/20 rounded">{s.days}</div>
                </div>
                <div class="p-6">
                  <div class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-1">{s.phase}</div>
                  <h3 class="text-xl font-bold text-ink-900 mb-5">{s.title}</h3>
                  <div class="grid sm:grid-cols-2 gap-5">
                    <div class="bg-ink-50 rounded-lg p-4">
                      <div class="text-xs font-semibold text-ink-500 uppercase tracking-wider mb-3">👤 You do</div>
                      <ul class="space-y-2">
                        {s.youDo.map(item => (<li class="flex items-start gap-2 text-sm text-ink-700"><span class="text-ink-400 mt-0.5">•</span><span>{item}</span></li>))}
                      </ul>
                    </div>
                    <div class="bg-brand-50 rounded-lg p-4">
                      <div class="text-xs font-semibold text-brand-700 uppercase tracking-wider mb-3">🏭 EV Auto Pro handles</div>
                      <ul class="space-y-2">
                        {s.weDo.map(item => (<li class="flex items-start gap-2 text-sm text-ink-700"><span class="text-brand-500 mt-0.5">✓</span><span>{item}</span></li>))}
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* 6. FEATURES (for shipping/inspection/financing/after-sales) */}
  {service.features && (
    <section class="py-20 lg:py-28 bg-ink-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">{service.title} Features</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">What's included</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {service.features.map(f => (
            <div class="bg-white border border-ink-200 rounded-2xl p-8 hover:border-brand-500 hover:shadow-md transition-all">
              <div class="text-4xl mb-4">{f.icon}</div>
              <h3 class="text-base font-bold text-ink-900 mb-2">{f.title}</h3>
              <p class="text-sm text-ink-600 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* 7. PRICING (if applicable) */}
  {service.pricing && (
    <section class="py-20 lg:py-28">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Pricing</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{service.pricing.headline}</h2>
        </div>
        <div class="bg-white border border-ink-200 rounded-2xl overflow-hidden">
          {service.pricing.items.map((item, i) => (
            <div class:list={['grid sm:grid-cols-[1fr_auto] gap-4 p-6', i > 0 && 'border-t border-ink-200']}>
              <div>
                <h3 class="font-semibold text-base text-ink-900 mb-1">{item.name}</h3>
                <p class="text-sm text-ink-600">{item.desc}</p>
              </div>
              <div class="sm:text-right">
                <div class="text-base font-bold text-brand-500">{item.price}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* 8. FAQ */}
  <section class="py-20 lg:py-28 bg-ink-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">FAQ</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Common questions</h2>
      </div>
      <div class="space-y-3">
        {service.faqs.map(f => (
          <details class="group bg-white border border-ink-200 rounded-xl overflow-hidden hover:border-brand-500 transition-colors">
            <summary class="flex items-start justify-between gap-4 cursor-pointer p-5 list-none">
              <span class="font-semibold text-base text-ink-900 flex-1 group-open:text-brand-500 transition-colors">{f.q}</span>
              <svg class="flex-shrink-0 w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-sm text-ink-700 leading-relaxed border-t border-ink-100">
              <div class="pt-4">{f.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* 9. CTA */}
  <section class="py-20 lg:py-28 bg-ink-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/hero-port-loading.svg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">Ready to start?</h2>
      <p class="text-lg text-ink-300 mb-8 max-w-2xl mx-auto">
        Cai personally reviews every inquiry. Reply within 24h.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`/contact/quote/?service=${service.slug}`} class="inline-flex items-center px-8 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
        <a href="https://wa.me/8613800000000" class="inline-flex items-center px-8 py-4 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
      </div>
    </div>
  </section>

  {/* Schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'Service',
    name: service.title,
    description: service.tagline,
    provider: { '@type': 'Organization', name: 'EV Auto Pro', url: 'https://evautopro.com' },
  })} />
</BaseLayout>
