---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Request a Quote | EV Auto Pro China Car Exporter"
  description="Get FOB + CIF pricing for Chinese new energy vehicles. Free quote within 24 hours. MOQ 1 unit."
>
  <section class="bg-ink-50 border-b border-ink-200 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs text-ink-500 mb-3">
        <a href="/" class="hover:text-brand-500">Home</a> ·
        <a href="/contact/" class="hover:text-brand-500">Contact</a> ·
        <span class="text-ink-900">Request a Quote</span>
      </nav>
      <h1 class="text-3xl lg:text-4xl font-bold text-ink-900">Request a Quote</h1>
      <p class="text-base text-ink-600 mt-2 max-w-2xl">
        Tell us your target market and quantity. We respond within 24 hours with FOB + CIF pricing, MOQ, and lead time.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <form id="quote-form" class="bg-white border border-ink-200 rounded-2xl p-8 space-y-5" novalidate>
        {/* Honeypot for bots */}
        <input type="text" name="honeypot" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" />

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Full Name <span class="text-brand-500">*</span></label>
            <input type="text" name="name" required class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Company <span class="text-brand-500">*</span></label>
            <input type="text" name="company" required class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Business Email <span class="text-brand-500">*</span></label>
            <input type="email" name="email" required class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">WhatsApp <span class="text-brand-500">*</span></label>
            <input type="tel" name="whatsapp" required placeholder="+7 905 123 4567" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Target Market <span class="text-brand-500">*</span></label>
            <select name="target_market" required class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm bg-white">
              <option value="">— Choose country —</option>
              <option>Russia</option>
              <option>UAE</option>
              <option>Kazakhstan</option>
              <option>Uzbekistan</option>
              <option>Saudi Arabia</option>
              <option>Egypt</option>
              <option>Brazil</option>
              <option>Mexico</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Quantity <span class="text-brand-500">*</span></label>
            <input type="number" name="quantity" min="1" required placeholder="e.g. 10" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-ink-700 mb-1">Model Interested</label>
          <input type="text" name="model_interested" placeholder="e.g. Changan UNI-T, Jetour T2..." class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
        </div>

        <div>
          <label class="block text-sm font-semibold text-ink-700 mb-1">Target Delivery Time</label>
          <select name="delivery_time" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm bg-white">
            <option value="">— Optional —</option>
            <option>ASAP (within 1 month)</option>
            <option>1-2 months</option>
            <option>2-3 months</option>
            <option>Flexible</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-ink-700 mb-1">Additional Message</label>
          <textarea name="message" rows="4" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm"></textarea>
        </div>

        <label class="flex items-start gap-2 text-xs text-ink-600">
          <input type="checkbox" name="consent" required class="mt-1" />
          <span>I agree to be contacted by EV Auto Pro regarding this inquiry. We never share data with third parties.</span>
        </label>

        <button type="submit" class="w-full px-6 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Send Inquiry
        </button>

        <div id="quote-status" class="text-sm text-center hidden"></div>
      </form>

      <p class="text-xs text-ink-500 mt-4 text-center">
        Or contact us directly: <a href="mailto:cai@evautopro.com" class="text-brand-500">cai@evautopro.com</a> · WhatsApp <a href="https://wa.me/" class="text-brand-500">+86 XXX</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const status = document.getElementById('quote-status') as HTMLDivElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    status.classList.remove('hidden', 'text-green-600', 'text-red-600');
    status.classList.add('text-ink-500');
    status.textContent = 'Sending…';

    const fd = new FormData(form);
    try {
      const resp = await fetch('/api/inquiry', { method: 'POST', body: fd });
      const data = await resp.json();
      if (resp.ok) {
        status.classList.add('text-green-600');
        status.textContent = '✓ ' + (data.message ?? 'Thank you! Our team will reply within 24 hours.');
        form.reset();
      } else {
        status.classList.add('text-red-600');
        status.textContent = '⚠ ' + (data.error ?? 'Something went wrong. Please try again.');
      }
    } catch {
      status.classList.add('text-red-600');
      status.textContent = '⚠ Network error. Please try again or contact us directly.';
    }
  });
</script>
