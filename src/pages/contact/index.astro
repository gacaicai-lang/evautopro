---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { activeSocials } from '../../data/socials';
import WhatsAppField from '../../components/WhatsAppField.astro';

// 1:1 Nove Jewelry contact page layout (without address form fields)

const companyInfo = {
  phone: '+86 159 6446 7914',
  phoneTel: '+8615964467914',
  email: 'cai@evautopro.com',
  address: {
    line1: 'Tianhe District',
    line2: 'Guangzhou 510000',
    city: 'Guangdong Province, China',
  },
};

const founder = {
  name: 'Cai',
  title: 'Founder & Trade Director',
  bio: 'You get clear, fast communication and practical sourcing support at every step. From your first inquiry to final delivery, you feel guided rather than pushed. You receive clear material advice, realistic timelines, and consistent quality. When adjustments are needed, you get solutions instead of excuses, which helps you control costs, reduce risk, and launch your distribution with confidence.',
  // No verified photo yet — see /about/founder/ for the same honest-badge
  // treatment. Replace with a real photo (with consent) when supplied.
  avatarInitial: 'C',
};
---

<BaseLayout
  title="Contact EV Auto Pro | China NEV Export Inquiry"
  description="Connect for business and custom NEV procurement solutions. Email cai@evautopro.com, WhatsApp +86 159 6446 7914. 24h response guaranteed."
>
  {/* ============ 1. Banner Hero ============ */}
  <section class="relative h-64 lg:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-ink-900">
      <img src="/images/faq-logistics.webp" alt="" class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-end pb-12">
      <h1 class="text-5xl lg:text-6xl font-bold text-white">Contact</h1>
    </div>
  </section>

  {/* Breadcrumb */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <nav class="text-xs text-ink-500">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2">&gt;&gt;</span>
      <span class="text-ink-900">Contact</span>
    </nav>
  </div>

  {/* ============ 2. Title block ============ */}
  <section class="pt-8 pb-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-5">
        Connect for Business & Custom Solutions
      </h2>
      <p class="text-base text-ink-600 leading-relaxed">
        You can contact us for vehicle details, pricing, customization,<br/>
        or partnership inquiries. We respond clearly, efficiently, and with<br/>
        full professional support.
      </p>
    </div>
  </section>

  {/* ============ 3. Contact Info + Form 2 列 ============ */}
  <section class="pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        {/* Left: Contact info */}
        <div>
          <h3 class="text-2xl font-bold text-ink-900 mb-10">Contact Our Expert Team</h3>

          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-6 h-6 mt-1 text-ink-900">
                <svg fill="currentColor" viewBox="0 0 24 24"><path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 0 0-1.02.24l-2.2 2.2a15.07 15.07 0 0 1-6.59-6.58l2.2-2.21a1 1 0 0 0 .25-1A11.36 11.36 0 0 1 8.5 4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1 17 17 0 0 0 17 17 1 1 0 0 0 1-1v-3.5a1 1 0 0 0-1-1z"/></svg>
              </div>
              <div>
                <div class="font-bold text-base text-ink-900 mb-1">Phone</div>
                <a href={`tel:${companyInfo.phoneTel}`} class="text-base text-ink-700 hover:text-brand-500">{companyInfo.phone}</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-6 h-6 mt-1 text-ink-900">
                <svg fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              </div>
              <div>
                <div class="font-bold text-base text-ink-900 mb-1">Email</div>
                <a href={`mailto:${companyInfo.email}`} class="text-base text-ink-700 hover:text-brand-500">{companyInfo.email}</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-6 h-6 mt-1 text-ink-900">
                <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
              </div>
              <div>
                <div class="font-bold text-base text-ink-900 mb-1">Address</div>
                <p class="text-base text-ink-700 leading-relaxed">
                  {companyInfo.address.line1}, {companyInfo.address.line2},<br/>
                  {companyInfo.address.city}
                </p>
              </div>
            </div>

            {activeSocials.length > 0 && (
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-6 h-6 mt-1 text-ink-900">
                  <svg fill="currentColor" viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
                </div>
                <div>
                  <div class="font-bold text-base text-ink-900 mb-2">Follow Us</div>
                  <div class="flex gap-2.5">
                    {activeSocials.map(s => (
                      <a href={s.url} target="_blank" rel="noopener" aria-label={`EV Auto Pro on ${s.name}`}
                         class="w-9 h-9 rounded-md bg-ink-100 hover:bg-brand-500 flex items-center justify-center text-ink-700 hover:text-white transition-colors">
                        <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon}/></svg>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>

        {/* Right: Form */}
        <div>
          <form id="contact-form" class="space-y-6" novalidate>
            <input type="text" name="honeypot" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" />

            <div>
              <label class="block text-base text-ink-900 mb-2">Name <span class="text-brand-500">*</span></label>
              <input type="text" name="name" required placeholder="Name" class="w-full px-4 py-3 border border-ink-300 rounded-md focus:border-brand-500 focus:outline-none text-base" />
            </div>

            <div>
              <label class="block text-base text-ink-900 mb-2">Email <span class="text-brand-500">*</span></label>
              <input type="email" name="email" required placeholder="Email Address" class="w-full px-4 py-3 border border-ink-300 rounded-md focus:border-brand-500 focus:outline-none text-base" />
            </div>

            <div>
              <WhatsAppField required label="WhatsApp" />
            </div>

            <div>
              <label class="block text-base text-ink-900 mb-2">Message <span class="text-brand-500">*</span></label>
              <textarea name="message" rows="7" required placeholder="Your requirements" class="w-full px-4 py-3 border border-ink-300 rounded-md focus:border-brand-500 focus:outline-none text-base resize-y"></textarea>
            </div>

            <button type="submit" class="w-full px-6 py-4 bg-ink-900 hover:bg-brand-500 text-white font-semibold rounded-md transition-colors text-base">
              Submit Form
            </button>

            <div id="contact-status" class="text-sm text-center hidden"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 4. Founder + Map ============ */}
  <section class="pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-8 bg-ink-100 rounded-2xl p-8">
        {/* Founder bio */}
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-16 h-16 rounded-full bg-ink-900 flex items-center justify-center flex-shrink-0">
              <span class="text-2xl font-bold text-white/90">{founder.avatarInitial}</span>
            </div>
            <div>
              <div class="font-bold text-lg text-ink-900">{founder.name}</div>
              <div class="text-sm text-ink-600">{founder.title}</div>
            </div>
          </div>
          <p class="text-sm text-ink-700 leading-relaxed">{founder.bio}</p>
        </div>

        {/* Map */}
        <div class="aspect-[4/3] lg:aspect-auto rounded-lg overflow-hidden bg-ink-200 relative">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d913.7!2d113.323!3d23.135!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zR3Vhbmd6aG91IFRpYW5oZQ!5e0!3m2!1sen!2scn!4v0"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full h-full min-h-[300px]"></iframe>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 5. Contact our specialist CTA ============ */}
  <section class="py-20 bg-ink-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-3">Contact our specialist</h2>
      <p class="text-base text-ink-700 mb-8">We're here to help you</p>
      <a href="/contact/quote/" class="inline-flex items-center px-8 py-4 bg-ink-900 hover:bg-brand-500 text-white font-semibold rounded-md transition-colors">
        Get An Instant Quote
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const f = document.getElementById('contact-form') as HTMLFormElement | null;
  const st = document.getElementById('contact-status') as HTMLDivElement | null;
  f?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!st) return;
    st.classList.remove('hidden', 'text-green-600', 'text-red-600');
    st.classList.add('text-ink-500');
    st.textContent = 'Sending…';
    try {
      const r = await fetch('/api/inquiry', { method: 'POST', body: new FormData(f) });
      const d = await r.json();
      if (r.ok) {
        st.classList.add('text-green-600');
        st.textContent = '✓ ' + (d.message ?? 'Thank you! Cai will reply within 24 hours.');
        f.reset();
      } else {
        st.classList.add('text-red-600');
        st.textContent = '⚠ ' + (d.error ?? 'Something went wrong.');
      }
    } catch {
      st.classList.add('text-red-600');
      st.textContent = '⚠ Network error.';
    }
  });
</script>
