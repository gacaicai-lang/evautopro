---
import BaseLayout from '../../layouts/BaseLayout.astro';

const contactMethods = [
  {
    icon: '✉',
    label: 'Business Email',
    primary: 'cai@evautopro.com',
    href: 'mailto:cai@evautopro.com',
    sub: 'Reply within 24 hours',
  },
  {
    icon: '💬',
    label: 'WhatsApp',
    primary: '+86 138 0000 0000',
    href: 'https://wa.me/8613800000000?text=Hi,%20I\'m%20interested%20in%20Chinese%20EV%20export',
    sub: 'EN / RU / ES support',
  },
  {
    icon: '📞',
    label: 'Phone',
    primary: '+86 138 0000 0000',
    href: 'tel:+8613800000000',
    sub: 'Mon-Fri 9:00-18:00 CST',
  },
  {
    icon: '💼',
    label: 'WeChat',
    primary: 'evautopro2026',
    href: '#',
    sub: 'Scan QR or add ID',
  },
];

const channels = [
  {
    icon: '📋',
    title: 'Request a Quote',
    sub: 'FOB + CIF pricing for your target market',
    href: '/contact/quote/',
    cta: 'Get Quote',
  },
  {
    icon: '🔍',
    title: 'Pre-Shipment Inspection',
    sub: 'Independent QC + photo report before loading',
    href: '/contact/inspection/',
    cta: 'Apply',
  },
  {
    icon: '📕',
    title: 'Product Catalogue',
    sub: '50-page PDF · full specs + FOB pricing',
    href: '/contact/catalogue/',
    cta: 'Download',
  },
];

const regionalTeam = [
  {
    name: 'Anna I.',
    role: 'Russia & CIS Director',
    region: 'Moscow Office',
    langs: 'Russian · English',
    avatar: 1,
  },
  {
    name: 'Khalid M.',
    role: 'Middle East Director',
    region: 'Dubai Office',
    langs: 'Arabic · English',
    avatar: 2,
  },
  {
    name: 'Daniyar K.',
    role: 'Central Asia Director',
    region: 'Almaty Office',
    langs: 'Russian · Kazakh',
    avatar: 3,
  },
  {
    name: 'Carlos R.',
    role: 'LATAM Director',
    region: 'São Paulo Office',
    langs: 'Spanish · Portuguese',
    avatar: 4,
  },
];

const trustPoints = [
  { icon: '⚡', title: 'Reply within 24h', desc: 'Every inquiry answered same business day' },
  { icon: '🤝', title: 'Founder-led', desc: 'No layered middlemen, direct negotiation' },
  { icon: '🌐', title: '4 languages', desc: 'EN / RU / AR / ES native ops support' },
  { icon: '🔐', title: 'NDA on request', desc: 'Your sourcing list stays confidential' },
];
---

<BaseLayout
  title="Contact EV Auto Pro | China NEV Export Inquiry"
  description="Get in touch with EV Auto Pro. Email cai@evautopro.com, WhatsApp +86 138 0000 0000. Russian / Arabic / Spanish ops support. 24h reply guaranteed."
>
  {/* ====== 1. Hero ====== */}
  <section class="bg-ink-50 border-b border-ink-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs text-ink-500 mb-3">
        <a href="/" class="hover:text-brand-500">Home</a>
        <span class="mx-1">·</span>
        <span class="text-ink-900 font-medium">Contact</span>
      </nav>
      <h1 class="text-4xl lg:text-5xl font-bold text-ink-900 mb-3">Get in Touch</h1>
      <p class="text-lg text-ink-600 max-w-2xl">
        We respond to every inquiry within 24 hours. Native Russian / Arabic / Spanish ops on duty.
      </p>
      <div class="mt-8 grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-3xl">
        {trustPoints.map(t => (
          <div class="flex items-start gap-3">
            <div class="text-2xl">{t.icon}</div>
            <div>
              <div class="font-semibold text-sm text-ink-900">{t.title}</div>
              <div class="text-xs text-ink-500">{t.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 2. Contact Methods ====== */}
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Contact Information</p>
        <h2 class="text-3xl font-bold text-ink-900">Reach us your way</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {contactMethods.map(m => (
          <a href={m.href} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl p-6 transition-all">
            <div class="w-12 h-12 rounded-lg bg-brand-50 flex items-center justify-center text-2xl mb-4">
              {m.icon}
            </div>
            <div class="text-xs font-semibold text-ink-500 uppercase tracking-wider mb-1">{m.label}</div>
            <div class="font-semibold text-base text-ink-900 group-hover:text-brand-500 transition-colors break-all">
              {m.primary}
            </div>
            <div class="text-xs text-ink-500 mt-1">{m.sub}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 3. Specialized Inquiry Channels ====== */}
  <section class="py-16 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Inquiry Channels</p>
        <h2 class="text-3xl font-bold text-ink-900">Choose what you need</h2>
        <p class="text-base text-ink-600 mt-3 max-w-2xl mx-auto">
          Direct routes to specialized teams for faster, more accurate response.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {channels.map(c => (
          <a href={c.href} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-xl p-8 transition-all">
            <div class="text-4xl mb-4">{c.icon}</div>
            <h3 class="text-xl font-bold text-ink-900 group-hover:text-brand-500 mb-2 transition-colors">{c.title}</h3>
            <p class="text-sm text-ink-600 mb-5 leading-relaxed">{c.sub}</p>
            <div class="inline-flex items-center text-sm font-semibold text-brand-500 group-hover:translate-x-1 transition-transform">
              {c.cta}
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 4. Regional Team ====== */}
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Your Regional Contact</p>
        <h2 class="text-3xl font-bold text-ink-900">Native-language ops in 4 regions</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {regionalTeam.map(t => (
          <div class="bg-white border border-ink-200 rounded-xl p-6 text-center">
            <img src={`/images/testimonial-${t.avatar}.svg`} alt={t.name} class="w-20 h-20 rounded-full mx-auto mb-4 object-cover" loading="lazy" />
            <h3 class="font-bold text-base text-ink-900">{t.name}</h3>
            <div class="text-xs text-brand-500 font-semibold mt-1">{t.role}</div>
            <div class="text-xs text-ink-500 mt-2">{t.region}</div>
            <div class="text-xs text-ink-400 mt-1">{t.langs}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 5. Quick Inquiry Form ====== */}
  <section class="py-16 bg-ink-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Quick Inquiry</p>
        <h2 class="text-3xl font-bold text-ink-900">Send a message in 30 seconds</h2>
        <p class="text-base text-ink-600 mt-3">For detailed quote with FOB+CIF, use <a href="/contact/quote/" class="text-brand-500 underline">Request a Quote →</a></p>
      </div>

      <form id="quick-contact" class="bg-white border border-ink-200 rounded-2xl p-8 space-y-5" novalidate>
        <input type="text" name="honeypot" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" />

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Your Name <span class="text-brand-500">*</span></label>
            <input type="text" name="name" required class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Company</label>
            <input type="text" name="company" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">Email <span class="text-brand-500">*</span></label>
            <input type="email" name="email" required class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-ink-700 mb-1">WhatsApp</label>
            <input type="tel" name="whatsapp" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-ink-700 mb-1">Message <span class="text-brand-500">*</span></label>
          <textarea name="message" rows="4" required placeholder="What models / markets / quantities are you interested in?" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm"></textarea>
        </div>
        <button type="submit" class="w-full px-6 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Send Message
        </button>
        <div id="quick-status" class="text-sm text-center hidden"></div>
      </form>
    </div>
  </section>

  {/* ====== 6. Office Info ====== */}
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-8">
        <div>
          <h3 class="font-bold text-base text-ink-900 mb-3">🏢 Shanghai HQ</h3>
          <p class="text-sm text-ink-600 leading-relaxed">
            Bonded Warehouse Zone<br/>
            Yangshan Free Trade Port<br/>
            Shanghai 201306, China
          </p>
        </div>
        <div>
          <h3 class="font-bold text-base text-ink-900 mb-3">⏰ Operating Hours</h3>
          <ul class="text-sm text-ink-600 space-y-1">
            <li>Mon-Fri: 9:00 - 18:00 CST</li>
            <li>Sat: 9:00 - 13:00 CST</li>
            <li>Sun: Closed (WhatsApp on-call)</li>
            <li class="text-xs text-ink-500 mt-2">Russia/UAE/LATAM: 24h regional ops</li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-base text-ink-900 mb-3">🛂 Compliance Documents</h3>
          <p class="text-sm text-ink-600 leading-relaxed mb-2">
            MoFCOM Export License<br/>
            AEO Customs Certification<br/>
            ISO 9001:2015
          </p>
          <a href="/about/certifications/" class="text-sm font-semibold text-brand-500 hover:text-brand-600">View all certificates →</a>
        </div>
      </div>
    </div>
  </section>

  {/* ====== 7. Final CTA ====== */}
  <section class="py-16 bg-ink-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Need an urgent reply?</h2>
      <p class="text-base text-ink-300 mb-6">WhatsApp for fastest response — average reply 12 minutes in business hours.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="https://wa.me/8613800000000" class="inline-flex items-center px-8 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          💬 WhatsApp Now
        </a>
        <a href="/contact/quote/" class="inline-flex items-center px-8 py-3 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          📋 Detailed Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const f = document.getElementById('quick-contact') as HTMLFormElement | null;
  const st = document.getElementById('quick-status') as HTMLDivElement | null;
  f?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!st) return;
    st.classList.remove('hidden', 'text-green-600', 'text-red-600');
    st.classList.add('text-ink-500');
    st.textContent = 'Sending…';
    const fd = new FormData(f);
    try {
      const r = await fetch('/api/inquiry', { method: 'POST', body: fd });
      const d = await r.json();
      if (r.ok) {
        st.classList.add('text-green-600');
        st.textContent = '✓ ' + (d.message ?? 'Thank you! We will reply within 24 hours.');
        f.reset();
      } else {
        st.classList.add('text-red-600');
        st.textContent = '⚠ ' + (d.error ?? 'Something went wrong.');
      }
    } catch {
      st.classList.add('text-red-600');
      st.textContent = '⚠ Network error. Try WhatsApp or email directly.';
    }
  });
</script>
