---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import StatGrid from '../components/ui/StatGrid.astro';
import CardGrid from '../components/ui/CardGrid.astro';
import Card from '../components/ui/Card.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import CTAGroup from '../components/ui/CTAGroup.astro';

const topCards = [
  { slug: 'brands', icon: '🏷', title: 'All Car Brands', sub: '35 brands · 6 authorized', href: '/brands/' },
  { slug: 'cars', icon: '🚗', title: 'Hot Selling Models', sub: '50+ models in stock', href: '/cars/' },
  { slug: 'markets', icon: '🌍', title: 'Export Markets', sub: '8 countries · ready logistics', href: '/markets/' },
  { slug: 'process', icon: '📦', title: 'Export Process', sub: '5-step from quote to delivery', href: '/services/export-process/' },
];

const featuredBrands = [
  { slug: 'changan', name: 'Changan', cn: '长安' },
  { slug: 'deepal', name: 'Deepal', cn: '深蓝' },
  { slug: 'jetour', name: 'Jetour', cn: '捷途' },
  { slug: 'geely', name: 'Geely', cn: '吉利' },
  { slug: 'volkswagen', name: 'VW', cn: '大众' },
  { slug: 'byd', name: 'BYD', cn: '比亚迪' },
];

const featuredCars = [
  { slug: 'changan-uni-t', brand: 'Changan', name: 'UNI-T', body: 'Coupe SUV', fuel: 'ICE', price: '13,800' },
  { slug: 'jetour-t2', brand: 'Jetour', name: 'T2', body: '7-Seater SUV', fuel: 'PHEV', price: '22,500' },
  { slug: 'geely-coolray', brand: 'Geely', name: 'Coolray', body: 'Compact SUV', fuel: 'ICE', price: '15,200' },
  { slug: 'deepal-s07', brand: 'Deepal', name: 'S07', body: 'EREV SUV', fuel: 'EREV', price: '24,800' },
];

const useCases = [
  { slug: 'chinese-electric-suv', label: 'Electric SUV', desc: 'BEV SUVs for fleet & dealer orders' },
  { slug: 'chinese-plug-in-hybrid-cars', label: 'PHEV / Hybrid', desc: 'Plug-in hybrids for long-range markets' },
  { slug: 'chinese-pickup-trucks', label: 'Pickup Trucks', desc: 'Rugged builds for Central Asia farms' },
  { slug: 'right-hand-drive-chinese-cars', label: 'Right-Hand Drive', desc: 'UK / SA / PK / ID dealers' },
  { slug: 'chinese-cars-under-15000-usd', label: 'Under $15,000', desc: 'Entry-price for emerging markets' },
];

const advantages = [
  { icon: '🏭', title: '15+ Years Export', desc: 'Cai led $50M+ B2B trade since 2010' },
  { icon: '🤝', title: 'Founder-Led', desc: 'No layered middlemen — direct quote 24h' },
  { icon: '🇷🇺', title: 'Russia & CIS Specialist', desc: 'Native Russian ops + EAC certification' },
  { icon: '📋', title: 'Full Export Compliance', desc: 'MoFCOM / AEO / GCC / EAC / INMETRO / GSO' },
  { icon: '💰', title: 'Transparent Pricing', desc: 'FOB / CIF / EXW broken down line-by-line' },
  { icon: '🛠', title: 'Parts Network', desc: 'Moscow / Almaty / Dubai depots' },
];

const markets = [
  { code: 'RU', name: 'Russia', tagline: 'Block train + RoRo to St. Petersburg, EAC compliant' },
  { code: 'AE', name: 'UAE', tagline: 'Jebel Ali RoRo, GCC + ESMA certified' },
  { code: 'KZ', name: 'Kazakhstan', tagline: 'Direct rail via Khorgos to Almaty' },
  { code: 'UZ', name: 'Uzbekistan', tagline: 'Block train to Tashkent' },
  { code: 'SA', name: 'Saudi Arabia', tagline: 'SASO/GSO compliant, Jeddah RoRo' },
  { code: 'EG', name: 'Egypt', tagline: 'CKD program for Cairo assembly partners' },
  { code: 'BR', name: 'Brazil', tagline: 'INMETRO certified, Santos container' },
  { code: 'MX', name: 'Mexico', tagline: 'NOM-certified, Manzanillo RoRo' },
];

const liveShipments = [
  { ago: '2h ago', text: '30 units Jetour T2 → Tashkent, Uzbekistan' },
  { ago: '8h ago', text: '50 units Changan UNI-T → St. Petersburg, Russia' },
  { ago: '1d ago', text: '12 units Deepal S07 → Jebel Ali, UAE' },
  { ago: '2d ago', text: '25 units Geely Coolray → Almaty, Kazakhstan' },
];

const testimonials = [
  { name: 'Andrey K.', role: 'Dealer Principal · Moscow, Russia', quote: 'They delivered 50 Jetour T2 in 18 days via block train. EAC paperwork zero hassle.' },
  { name: 'Mohammed A.', role: 'Fleet Manager · Dubai, UAE', quote: 'Most professional China exporter we worked with. Pricing transparent, GCC complete.' },
  { name: 'Daniyar T.', role: 'Wholesale Buyer · Almaty, Kazakhstan', quote: 'Khorgos route saved 15 days vs Vladivostok. Will scale up monthly orders.' },
  { name: 'Carlos M.', role: 'Distributor · São Paulo, Brazil', quote: 'INMETRO docs handled end-to-end. First container arrived on time, no surprises.' },
];

const certifications = ['MOFCOM', 'AEO', 'ISO 9001', 'GCC', 'EAC', 'INMETRO', 'GSO', 'SASO'];

const recentBlogs = [
  { slug: 'top-7-chinese-suv-for-russia-2026', title: 'Top 7 Chinese Off-Road SUVs for Russia in 2026', date: '2026-05-10', cat: 'Buyer Guide', read: '10 min' },
  { slug: '2026-china-nev-export-rules-guide', title: "China's New NEV Export Policy 2026: Complete Guide", date: '2026-05-15', cat: 'Industry News', read: '8 min' },
  { slug: 'changan-uni-t-vs-jetour-t2-comparison', title: 'Changan UNI-T vs Jetour T2: Which Coupé SUV?', date: '2026-05-12', cat: 'Product News', read: '6 min' },
];

const faqs = [
  { q: 'What is the minimum order quantity (MOQ)?', a: 'MOQ is 1 unit for container shipment. For RoRo to Russia/UAE, we recommend ≥5 units to optimize freight cost.' },
  { q: 'How long does delivery take?', a: 'Stock units ship within 3-15 days. New-build orders take 30-60 days depending on factory schedule.' },
  { q: 'What payment terms do you accept?', a: 'T/T 30% deposit + 70% before shipment is standard. L/C at sight from major banks accepted. OA after first order.' },
  { q: 'Do you provide right-hand drive (RHD) versions?', a: 'Yes, for select models (Geely Coolray, Changan CS75 Plus, Jetour T2). We coordinate factory RHD batches.' },
  { q: 'Can you ship to my country?', a: 'We currently serve 60+ countries. Active routes: Russia, CIS, Middle East, LATAM, Africa, SE Asia.' },
  { q: 'Do you offer after-sales parts?', a: 'Yes. We maintain parts depots in Moscow, Almaty, Dubai. Other regions ship from Shanghai within 7-14 days.' },
];
---

<BaseLayout
  title="China NEV Export | Wholesale Electric Cars from Authorized Exporter"
  description="Authorized exporter of Chinese NEVs — Changan, Deepal, Jetour, Geely, VW, BYD. FOB from $13,800. Ships to Russia, UAE, Kazakhstan, Brazil. MOQ 1."
>
  {/* ============ HERO ============ */}
  <section class="relative bg-gradient-to-br from-ink-50 via-white to-ink-50 py-20 lg:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-50 text-brand-700 text-xs font-semibold rounded-full mb-6">
            <span class="w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
            45 units in stock at Shanghai warehouse
          </div>
          <h1 class="text-5xl lg:text-7xl font-bold text-ink-900 leading-[1.05] tracking-tight mb-6">
            Your Trusted China NEV Exporter <span class="text-brand-500">for Global B2B Buyers</span>
          </h1>
          <p class="text-lg lg:text-xl text-ink-600 mb-10 max-w-xl leading-relaxed">
            Direct supply of Changan, Deepal, Jetour, Geely, VW, BYD. FOB from $13,800 · MOQ 1 unit · 15-day lead time.
          </p>
          <CTAGroup buttons={[
            { label: 'Request a Quote →', href: '/contact/quote/', variant: 'primary' },
            { label: 'Browse 50+ Models', href: '/cars/', variant: 'secondary' },
          ]} />
          <div class="mt-12 pt-10 border-t border-ink-200">
            <StatGrid stats={[
              { num: '15+', label: 'Years in Export' },
              { num: '60+', label: 'Countries Served' },
              { num: '6', label: 'Authorized Brands' },
              { num: '50+', label: 'Models Available' },
            ]} />
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl bg-ink-100 border border-ink-200 overflow-hidden">
            <img src="/images/hero-port-loading.svg" alt="China NEV port loading bay" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -bottom-4 -left-4 bg-white border border-ink-200 rounded-xl shadow-lg p-4 max-w-[220px]">
            <div class="text-xs text-ink-500 mb-1">Latest shipment</div>
            <div class="text-sm font-semibold text-ink-900">50 units Jetour T2</div>
            <div class="text-xs text-ink-500 mt-1">→ Tashkent, Uzbekistan</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ TOP CARDS (4 entry points) ============ */}
  <section class="py-10 bg-white border-y border-ink-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CardGrid cols={4} gap="md">
        {topCards.map(c => (
          <Card href={c.href} padding="md">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-lg bg-ink-100 group-hover:bg-brand-50 flex items-center justify-center text-2xl transition-colors">{c.icon}</div>
              <div>
                <div class="font-semibold text-sm text-ink-900 group-hover:text-brand-500">{c.title}</div>
                <div class="text-xs text-ink-500 mt-0.5">{c.sub}</div>
              </div>
            </div>
          </Card>
        ))}
      </CardGrid>
    </div>
  </section>

  {/* ============ BRANDS ============ */}
  <Section eyebrow="Authorized & Sourced Brands" title="Direct supply from 35 Chinese OEMs">
    <CardGrid cols={6} gap="sm">
      {featuredBrands.map(b => (
        <Card href={`/brands/${b.slug}/`} padding="sm" class="text-center">
          <img src={`/images/brand-${b.slug}.svg`} alt={b.name} class="h-12 mx-auto mb-3 object-contain" />
          <div class="font-semibold text-sm text-ink-900">{b.name}</div>
          <div class="text-xs text-ink-500 mt-1">{b.cn}</div>
        </Card>
      ))}
    </CardGrid>
    <div class="text-center mt-10">
      <a href="/brands/" class="text-sm font-semibold text-brand-500 hover:text-brand-600">View all 35 brands →</a>
    </div>
  </Section>

  {/* ============ HOT MODELS ============ */}
  <Section eyebrow="Hot Selling Models" title="Top picks for export" bg="gray">
    <CardGrid cols={4} gap="md">
      {featuredCars.map(c => {
        const img = ['geely-coolray','jetour-t2'].includes(c.slug) ? `/images/真图/laundered/evautopro-${c.slug}-01.webp` : `/images/car-${c.slug}.svg`;
        return (
          <Card href={`/cars/${c.slug}/`} padding="sm">
            <div class="aspect-[16/10] bg-ink-100 rounded-lg overflow-hidden mb-4 -m-1">
              <img src={img} alt={`${c.brand} ${c.name}`} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-0.5 bg-ink-100 text-ink-600 text-xs rounded">{c.body}</span>
              <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{c.fuel}</span>
            </div>
            <div class="text-xs text-ink-500 mb-1">{c.brand}</div>
            <h3 class="font-semibold text-base text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{c.name}</h3>
            <div class="pt-3 border-t border-ink-100">
              <div class="text-xs text-ink-500">From FOB Shanghai</div>
              <div class="text-lg font-bold text-ink-900">${c.price}</div>
            </div>
          </Card>
        );
      })}
    </CardGrid>
    <div class="text-center mt-10">
      <a href="/cars/" class="text-sm font-semibold text-brand-500 hover:text-brand-600">See all 50+ models →</a>
    </div>
  </Section>

  {/* ============ USE CASES ============ */}
  <Section eyebrow="Shop by Use Case" title="Find the right car for your market" align="center">
    <CardGrid cols={5} gap="md">
      {useCases.map(u => (
        <Card href={`/collections/${u.slug}/`} padding="md">
          <h3 class="font-semibold text-base text-ink-900 group-hover:text-brand-500 mb-2">{u.label}</h3>
          <p class="text-xs text-ink-500 leading-relaxed mb-3">{u.desc}</p>
          <div class="text-xs font-semibold text-brand-500">View models →</div>
        </Card>
      ))}
    </CardGrid>
  </Section>

  {/* ============ TRUST PILLARS DARK ============ */}
  <Section bg="dark" eyebrow="3 Pillars of Trust" title="Why dealers choose us" align="center">
    <CardGrid cols={3} gap="lg">
      <Card variant="dark" hover={false} padding="lg">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-500 flex items-center justify-center text-2xl">✓</div>
          <div>
            <h3 class="font-semibold text-lg text-white mb-1">Authorized Dealer</h3>
            <p class="text-sm text-ink-400">Direct MoU with 6 OEMs · No grey market</p>
          </div>
        </div>
      </Card>
      <Card variant="dark" hover={false} padding="lg">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-500 flex items-center justify-center text-2xl">⚡</div>
          <div>
            <h3 class="font-semibold text-lg text-white mb-1">In-Stock Same-Day Ship</h3>
            <p class="text-sm text-ink-400">200+ units bonded warehouse · 3-15 day lead</p>
          </div>
        </div>
      </Card>
      <Card variant="dark" hover={false} padding="lg">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-500 flex items-center justify-center text-2xl">🚢</div>
          <div>
            <h3 class="font-semibold text-lg text-white mb-1">Door-to-Door Logistics</h3>
            <p class="text-sm text-ink-400">RoRo / Container / Block Train · 4 modes</p>
          </div>
        </div>
      </Card>
    </CardGrid>
  </Section>

  {/* ============ OUR ADVANTAGE ============ */}
  <Section eyebrow="Our Advantage" title="Why dealers pick EV Auto Pro" align="center">
    <CardGrid cols={3} gap="md">
      {advantages.map(a => (
        <Card padding="lg">
          <div class="text-3xl mb-3">{a.icon}</div>
          <h3 class="font-semibold text-base text-ink-900 mb-2">{a.title}</h3>
          <p class="text-sm text-ink-600 leading-relaxed">{a.desc}</p>
        </Card>
      ))}
    </CardGrid>
  </Section>

  {/* ============ LIVE SHIPMENTS ============ */}
  <Section bg="gray" eyebrow="Live Shipment Feed" title="Recent activity" padding="md">
    <div class="space-y-2 max-w-3xl mx-auto">
      {liveShipments.map(s => (
        <div class="flex items-center gap-4 px-5 py-4 bg-white border border-ink-200 rounded-lg hover:border-brand-500 transition-colors">
          <span class="text-xs font-mono text-ink-400 w-20 flex-shrink-0">{s.ago}</span>
          <span class="text-sm text-ink-900 flex-1">{s.text}</span>
          <a href="/case-studies/" class="text-xs font-semibold text-brand-500 hover:text-brand-600 flex-shrink-0 hidden sm:block">Details →</a>
        </div>
      ))}
    </div>
  </Section>

  {/* ============ MARKETS ============ */}
  <Section eyebrow="Key Markets" title="Built for emerging markets" subtitle="Logistics, certifications, and after-sales tailored to each destination." align="center">
    <CardGrid cols={4} gap="md">
      {markets.map(m => (
        <Card href={`/markets/${m.name.toLowerCase().replace(/\s+/g, '-')}/`} padding="md">
          <div class="w-10 h-10 rounded-lg bg-ink-100 group-hover:bg-brand-50 flex items-center justify-center mb-3 text-sm font-bold text-ink-700 group-hover:text-brand-500 transition-colors">
            {m.code}
          </div>
          <h3 class="font-semibold text-base text-ink-900 group-hover:text-brand-500 mb-2 transition-colors">{m.name}</h3>
          <p class="text-xs text-ink-600 leading-relaxed">{m.tagline}</p>
        </Card>
      ))}
    </CardGrid>
  </Section>

  {/* ============ TESTIMONIALS ============ */}
  <Section bg="gray" eyebrow="Client Voices" title="Trusted by dealers in 60+ countries" align="center">
    <CardGrid cols={4} gap="md">
      {testimonials.map((t, i) => (
        <Card padding="md">
          <div class="flex items-center gap-3 mb-4">
            <img src={`/images/testimonial-${i + 1}.svg`} alt={t.name} class="w-12 h-12 rounded-full object-cover" loading="lazy" />
            <div>
              <div class="font-semibold text-sm text-ink-900">{t.name}</div>
              <div class="text-xs text-ink-500">{t.role}</div>
            </div>
          </div>
          <p class="text-sm text-ink-700 leading-relaxed italic">"{t.quote}"</p>
        </Card>
      ))}
    </CardGrid>
  </Section>

  {/* ============ CERTIFICATIONS ============ */}
  <Section eyebrow="Trust & Compliance" title="Certified for global export" align="center" padding="md">
    <div class="grid grid-cols-4 lg:grid-cols-8 gap-4">
      {certifications.map(c => (
        <div class="bg-white border border-ink-200 rounded-lg p-4 text-center hover:border-brand-500 transition-colors">
          <div class="font-bold text-sm text-ink-900">{c}</div>
          <div class="text-[10px] text-ink-500 mt-1">CERTIFIED</div>
        </div>
      ))}
    </div>
  </Section>

  {/* ============ BLOG ============ */}
  <Section bg="gray" eyebrow="Latest from Blog" title="Export insights & buyer guides">
    <CardGrid cols={3} gap="md">
      {recentBlogs.map(b => (
        <Card href={`/news/${b.slug}/`} padding="sm">
          <div class="aspect-[16/10] bg-ink-100 rounded-lg overflow-hidden mb-4 -m-1 flex items-center justify-center text-ink-400 text-xs">
            blog-{b.slug}
          </div>
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{b.cat}</span>
            <span class="text-xs text-ink-500">{b.read}</span>
          </div>
          <h3 class="font-semibold text-base text-ink-900 group-hover:text-brand-500 transition-colors mb-2 leading-snug">{b.title}</h3>
          <div class="text-xs text-ink-500">{b.date}</div>
        </Card>
      ))}
    </CardGrid>
    <div class="text-center mt-10">
      <a href="/news/" class="text-sm font-semibold text-brand-500 hover:text-brand-600">All articles →</a>
    </div>
  </Section>

  {/* ============ FAQ ============ */}
  <Section eyebrow="FAQs" title="Common questions" align="center" maxWidth="normal">
    <FAQAccordion faqs={faqs} />
    <div class="text-center mt-10">
      <a href="/faq/" class="text-sm font-semibold text-brand-500 hover:text-brand-600">See all 40 FAQs →</a>
    </div>
  </Section>

  {/* ============ CATALOGUE PDF ============ */}
  <Section padding="md" align="center" maxWidth="normal">
    <div class="bg-gradient-to-br from-brand-50 to-white border border-brand-100 rounded-2xl p-10">
      <h2 class="text-2xl lg:text-3xl font-bold text-ink-900 mb-3">Get our 50-page model catalogue</h2>
      <p class="text-base text-ink-600 mb-6">Full specs, FOB prices, lead times for all 50+ models. PDF emailed instantly.</p>
      <form class="max-w-md mx-auto flex gap-2">
        <input type="email" placeholder="Your business email" required
               class="flex-1 px-4 py-3 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
        <button type="submit" class="btn-primary">Send PDF</button>
      </form>
      <p class="text-xs text-ink-500 mt-3">No spam · Unsubscribe anytime</p>
    </div>
  </Section>

  {/* ============ FINAL DARK CTA ============ */}
  <Section bg="dark" title="Ready to import Chinese EVs?" subtitle="Tell us your target market and quantity. We'll send FOB + CIF pricing within 24 hours." align="center" maxWidth="normal">
    <CTAGroup align="center" buttons={[
      { label: 'Request a Quote', href: '/contact/quote/', variant: 'primary' },
      { label: '💬 WhatsApp Now', href: 'https://wa.me/8613800000000', variant: 'white' },
    ]} />
  </Section>
</BaseLayout>
