---
import BaseLayout from '../../layouts/BaseLayout.astro';

const milestones = [
  { year: '2010', event: 'Founded multi-category sourcing business', detail: 'Started with textiles, home decor, industrial components for international wholesale buyers.' },
  { year: '2012', event: 'First Russia / CIS buyer relationships', detail: 'Built initial network of repeat buyers in Moscow + St. Petersburg through trade shows.' },
  { year: '2015', event: 'Expanded to Middle East + LATAM', detail: 'Added UAE / Brazil / Mexico buyer networks. Multi-category sourcing volume crossed $10M annual.' },
  { year: '2018', event: 'First China Auto OEM MoU — Changan', detail: 'Signed first authorized dealer MoU with Changan Auto for select export markets.' },
  { year: '2020', event: 'Volkswagen China authorization added', detail: 'Expanded to multi-OEM with VW China JV access for ID series EV.' },
  { year: '2022', event: 'NEV-Only Pivot', detail: 'Recognized global EV demand surge. Pivoted EV Auto Pro 100% to new energy vehicle export.' },
  { year: '2023', event: 'Deepal + Qiyuan MoUs added', detail: 'Expanded Changan group authorization to include new NEV sub-brands.' },
  { year: '2026', event: '6 authorized OEMs · 60+ countries', detail: 'EV Auto Pro now serves dealer/distributor partners across 60+ countries, 6 directly authorized brands.' },
];

const principles = [
  { icon: '🤝', title: 'Founder-Led Direct Trade', desc: 'I personally review every quote, every order, every shipment. No layered intermediaries between you and the factory floor.' },
  { icon: '🔍', title: 'Transparent Pricing', desc: 'I share factory invoice on request. FOB / CIF / EXW broken down line-by-line. No hidden fees. Margin is explicit.' },
  { icon: '🇷🇺', title: 'Russia / CIS Specialist', desc: '15 years of repeat buyer relationships. Native Russian-speaking operations. EAC paperwork mastered. We are not a generalist.' },
  { icon: '📋', title: 'Authorized Only', desc: 'Only OEM-authorized brands. Factory invoice for every unit. Zero grey market. We refuse opportunistic deals that compromise dealer trust.' },
];
---

<BaseLayout
  title="About the Founder | Cai · EV Auto Pro — 15+ Years China Export"
  description="Meet Cai, founder of EV Auto Pro. 15+ years China export trade. Founder-led China NEV exporter to Russia, CIS, Middle East, LATAM, Africa."
>
  {/* Hero */}
  <section class="relative h-64 lg:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-ink-900">
      <img src="/images/faq-sourcing.webp" alt="" class="w-full h-full object-cover opacity-40" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-end pb-12">
      <div>
        <p class="text-sm font-semibold text-brand-500 uppercase tracking-wider mb-2">About</p>
        <h1 class="text-5xl lg:text-6xl font-bold text-white">Meet the Founder</h1>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <nav class="text-xs text-ink-500">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2">·</span>
      <a href="/about/" class="hover:text-brand-500">About</a>
      <span class="mx-2">·</span>
      <span class="text-ink-900">Founder</span>
    </nav>
  </div>

  {/* Bio */}
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[280px_1fr] gap-12 items-start">
        {/* No verified photo of the founder yet — an honest initial badge,
            not a stock/placeholder image dressed up as a real photo. Swap
            for a real photo (with consent) as soon as one is supplied. */}
        <div class="aspect-square rounded-2xl overflow-hidden border border-ink-200 bg-ink-900 flex items-center justify-center">
          <span class="text-6xl font-bold text-white/90">C</span>
        </div>
        <div>
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-3">Founder & Trade Director</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-6">Cai · 15 Years China Export</h2>
          <div class="space-y-4 text-base text-ink-700 leading-relaxed">
            <p>
              I founded EV Auto Pro in 2022 after 12 years of multi-category sourcing for international wholesale buyers — textiles, home decor, industrial components — primarily serving Russia, CIS, Middle East, and LATAM markets.
            </p>
            <p>
              The pivot to new energy vehicles came from watching my long-term buyers ask, year after year: <em>"Cai, can you also help with Chinese cars?"</em> By 2022, the answer was yes. I obtained my first authorized dealer MoU with Changan Auto, then added Volkswagen China, Geely, Jetour, Deepal, and Qiyuan.
            </p>
            <p>
              Today EV Auto Pro is founder-led, no middle layers. Every quote I review personally. Every shipment I track end-to-end. Every dealer partner has my direct WhatsApp.
            </p>
            <p>
              <strong>This is not a generic sourcing company.</strong> This is 15 years of cross-border trust translated into China NEV export.
            </p>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="https://wa.me/8615964467914" class="btn-primary">💬 WhatsApp Cai Direct</a>
            <a href="/contact/" class="btn-secondary">All contact methods</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Operating Principles */}
  <section class="py-20 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">How I Operate</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">4 principles that guide every decision</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {principles.map(p => (
          <div class="bg-white border border-ink-200 rounded-2xl p-8">
            <div class="text-4xl mb-4">{p.icon}</div>
            <h3 class="text-xl font-bold text-ink-900 mb-3">{p.title}</h3>
            <p class="text-base text-ink-700 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Timeline */}
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Career Timeline</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">2010 → 2026</h2>
      </div>
      <div class="space-y-8">
        {milestones.map(m => (
          <div class="grid sm:grid-cols-[120px_1fr] gap-6 items-start">
            <div class="text-3xl font-bold text-brand-500">{m.year}</div>
            <div class="pb-6 border-l-2 border-ink-200 pl-6 relative">
              <span class="absolute -left-2 top-1 w-3 h-3 bg-brand-500 rounded-full"></span>
              <h3 class="font-semibold text-lg text-ink-900 mb-2">{m.event}</h3>
              <p class="text-sm text-ink-600 leading-relaxed">{m.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Final CTA */}
  <section class="py-20 bg-ink-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Work with Cai directly</h2>
      <p class="text-base text-ink-300 mb-8">No layered middlemen. No call center. Direct trade with a founder who has 15 years of skin in the game.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="https://wa.me/8615964467914" class="inline-flex items-center px-8 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
        <a href="/contact/quote/" class="inline-flex items-center px-8 py-3 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          📋 Request a Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
