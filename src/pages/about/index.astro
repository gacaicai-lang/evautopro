---
import BaseLayout from '../../layouts/BaseLayout.astro';

const stats = [
  { num: '15+', label: 'Years in Export Trade' },
  { num: '6', label: 'Authorized OEM Brands' },
  { num: '60+', label: 'Countries Served' },
  { num: '200+', label: 'Units Bonded Stock' },
];

const services = [
  { icon: '📦', title: 'Sourcing & Procurement', desc: 'Direct factory negotiation across 35 Chinese OEMs' },
  { icon: '🔍', title: 'Pre-Shipment Inspection', desc: 'Multi-point QC + photo report before container loading' },
  { icon: '📋', title: 'Export Documentation', desc: 'MoFCOM, EAC, GCC, INMETRO, SASO certs handled in-house' },
  { icon: '🚢', title: 'Door-to-Port Logistics', desc: 'RoRo, Container, Block Train, Truck — all modes' },
  { icon: '🛠', title: 'After-Sales Parts', desc: 'Spare parts shipped within 7-14 days globally' },
];

const authorizedBrands = [
  { slug: 'changan', name: 'Changan', cn: '长安', since: 2018 },
  { slug: 'deepal', name: 'Deepal', cn: '深蓝', since: 2023 },
  { slug: 'qiyuan', name: 'Qiyuan', cn: '启源', since: 2023 },
  { slug: 'geely', name: 'Geely', cn: '吉利', since: 2016 },
  { slug: 'volkswagen', name: 'VW China', cn: '大众', since: 2020 },
  { slug: 'jetour', name: 'Jetour', cn: '捷途', since: 2021 },
];

const trustPillars = [
  { icon: '🔐', title: 'Founder-Led Direct Trade', desc: 'Single point of accountability. No layered middlemen. Founder responds to inquiries personally within 24h.' },
  { icon: '🇷🇺', title: 'Russian & CIS Trade Network', desc: '15 years of repeat buyer relationships in Russia, Kazakhstan, Uzbekistan. EAC paperwork mastered.' },
  { icon: '🏭', title: 'Direct OEM Authorization', desc: 'Signed dealer MoUs with 6 China brands. No grey-market sourcing — every unit traceable.' },
  { icon: '💰', title: 'Transparent Pricing', desc: 'FOB / CIF / EXW broken down line-by-line. No hidden fees. We share factory invoice on request.' },
];

const certifications = [
  { code: 'MOFCOM', label: 'Export License', desc: '商务部批准对外贸易经营资格' },
  { code: 'AEO', label: 'Customs AEO', desc: '海关高级认证企业 (顶级信用)' },
  { code: 'ISO 9001', label: '2015 Certified', desc: '质量管理体系认证' },
  { code: 'EAC', label: 'Eurasian Conformity', desc: 'Russia / CIS region certification' },
  { code: 'GCC', label: 'Gulf Standard', desc: 'UAE / Saudi import compliance' },
  { code: 'INMETRO', label: 'Brazil Standard', desc: 'LATAM market compliance' },
];

const timeline = [
  { year: '2010', title: 'Founded', desc: 'Cai launched multi-category sourcing for international buyers' },
  { year: '2018', title: 'Changan Dealer MoU', desc: 'First China OEM authorization signed' },
  { year: '2022', title: 'NEV Pivot', desc: 'Pivoted exclusively to new energy vehicles export' },
  { year: '2023', title: 'Deepal + Qiyuan Added', desc: 'Authorized dealer of Changan affiliate brands' },
  { year: '2026', title: '60+ Countries', desc: 'Active dealer relationships across 6 continents' },
];
---

<BaseLayout
  title="About EV Auto Pro | 15 Years China Export, NEV Specialist Since 2022"
  description="Authorized exporter of Chinese new energy vehicles. Founded 2010 by Cai with 15 years export trade experience. 6 authorized OEM brands, 60+ countries served."
>
  {/* ====== 1. Hero ====== */}
  <section class="bg-gradient-to-br from-ink-50 to-white border-b border-ink-200 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs text-ink-500 mb-3">
        <a href="/" class="hover:text-brand-500">Home</a> · <span class="text-ink-900">About</span>
      </nav>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-3">About EV Auto Pro</p>
          <h1 class="text-4xl lg:text-5xl font-bold text-ink-900 leading-tight mb-5">
            Your Trusted Partner for <span class="text-brand-500">China NEV Export</span>
          </h1>
          <p class="text-lg text-ink-600 mb-6 leading-relaxed">
            Founder-led, authorized China NEV exporter. 15 years in trade. Direct OEM MoUs. Native Russian / CIS trade network. Zero middlemen.
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {stats.map(s => (
              <div>
                <div class="text-3xl font-bold text-ink-900">{s.num}</div>
                <div class="text-xs text-ink-500 mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-ink-200">
            <img src="/images/about-team.svg" alt="EV Auto Pro founder + operation" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ====== 2. Company Overview (Story) ====== */}
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-3">Company Overview</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-6">15 years building cross-border trust</h2>
      <div class="space-y-4 text-base text-ink-700 leading-relaxed">
        <p>
          EV Auto Pro was founded by <strong>Cai</strong>, a 15-year veteran of Chinese export trade. From 2010 to 2022, Cai operated a multi-category sourcing business serving international wholesale buyers across textiles, home decor, and industrial components — accumulating a dense buyer network in <strong>Russia, the CIS region, the Middle East, and LATAM</strong>.
        </p>
        <p>
          In 2022, recognizing the surge in global demand for affordable Chinese electric vehicles, we <strong>pivoted exclusively to NEV export</strong>. Today we hold direct authorized-dealer MoUs with six Chinese OEMs: <strong>Changan, Deepal, Qiyuan, Geely, Volkswagen China, and Jetour</strong> — plus active sourcing relationships across 35 additional brands.
        </p>
        <p>
          We are <strong>founder-led, no middle layers</strong>. Every quote is reviewed by Cai personally. Every shipment is tracked end-to-end. This is how we keep response time under 24 hours and pricing transparent down to the line item.
        </p>
      </div>
    </div>
  </section>

  {/* ====== 3. What We Do (5 services) ====== */}
  <section class="py-16 lg:py-20 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">One-Stop China Car Export Services</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">From factory to your dealership</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-5">
        {services.map(s => (
          <div class="bg-white border border-ink-200 rounded-xl p-6 hover:border-brand-500 hover:shadow-md transition-all">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="font-semibold text-base text-ink-900 mb-2">{s.title}</h3>
            <p class="text-sm text-ink-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 4. Authorized Brands ====== */}
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Direct OEM Partnerships</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-3">6 brands. Signed dealer MoUs. Zero grey market.</h2>
        <p class="text-base text-ink-600 max-w-2xl mx-auto">
          Plus active sourcing across 35 additional Chinese OEMs — see <a href="/brands/" class="text-brand-500 underline">all 35 brands</a>.
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {authorizedBrands.map(b => (
          <a href={`/brands/${b.slug}/`} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl p-5 text-center transition-all">
            <img src={`/images/brand-${b.slug}.svg`} alt={b.name} class="h-12 mx-auto mb-3 object-contain" />
            <div class="text-xs text-ink-500 mb-1">{b.cn}</div>
            <div class="text-[10px] text-brand-500 font-semibold mt-2">Dealer since {b.since}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 5. Behind the Trust (4 Pillars) ====== */}
  <section class="py-16 lg:py-20 bg-ink-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Behind the Trust</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-3">Why dealers choose us over competing exporters</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {trustPillars.map(p => (
          <div class="bg-ink-800 rounded-xl p-6 border border-ink-700">
            <div class="text-3xl mb-3">{p.icon}</div>
            <h3 class="font-semibold text-base text-white mb-2">{p.title}</h3>
            <p class="text-sm text-ink-400 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 6. Certifications ====== */}
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Certified Compliance</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-3">Quality you can verify</h2>
        <p class="text-base text-ink-600">All certificates available on request</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {certifications.map(c => (
          <div class="bg-white border border-ink-200 rounded-xl p-5 flex items-start gap-4 hover:border-brand-500 transition-colors">
            <div class="w-16 h-12 flex-shrink-0 bg-ink-50 border border-ink-200 rounded flex items-center justify-center text-xs font-bold text-ink-900">
              {c.code}
            </div>
            <div>
              <div class="font-semibold text-sm text-ink-900">{c.label}</div>
              <div class="text-xs text-ink-500 mt-1">{c.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 7. Timeline ====== */}
  <section class="py-16 lg:py-20 bg-ink-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Our Journey</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">From 2010 to today</h2>
      </div>
      <div class="space-y-6">
        {timeline.map(t => (
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-20 text-right">
              <div class="text-2xl font-bold text-brand-500">{t.year}</div>
            </div>
            <div class="flex-1 pb-6 border-l-2 border-ink-200 pl-6 relative">
              <span class="absolute -left-2 top-1 w-3 h-3 bg-brand-500 rounded-full"></span>
              <h3 class="font-semibold text-base text-ink-900 mb-1">{t.title}</h3>
              <p class="text-sm text-ink-600">{t.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====== 8. Final CTA (双 CTA) ====== */}
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-brand-500 rounded-2xl p-8 text-white">
          <h3 class="text-2xl font-bold mb-2">Let's start your project</h3>
          <p class="text-base text-white/90 mb-5">Get FOB + CIF pricing within 24 hours. MOQ 1 unit.</p>
          <a href="/contact/quote/" class="inline-flex items-center px-5 py-3 bg-white text-brand-500 font-semibold rounded-lg hover:bg-ink-100 transition-colors">
            Request a Quote →
          </a>
        </div>
        <div class="bg-ink-900 rounded-2xl p-8 text-white">
          <h3 class="text-2xl font-bold mb-2">Download Catalogue</h3>
          <p class="text-base text-ink-300 mb-5">50-page PDF · all 50+ models · FOB pricing + specs.</p>
          <a href="/contact/catalogue/" class="inline-flex items-center px-5 py-3 bg-brand-500 text-white font-semibold rounded-lg hover:bg-brand-600 transition-colors">
            Get PDF →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
