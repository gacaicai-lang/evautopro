---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WhatsAppField from '../../components/WhatsAppField.astro';

// 1:1 ihkaauto.com/about visual layout (keeping evautopro brand-red palette)
// 9 section structure matching ihka's actual visual hierarchy

const aboutStats = [
  { num: '3,000+', label: 'Export Orders', sub: 'Since 2010' },
  { num: '60+', label: 'Countries Served', sub: 'Active Markets' },
  { num: '6', label: 'Authorized Brands', sub: 'Direct OEM MoUs' },
  { num: '15+', label: 'Years in Export', sub: 'Founder-Led' },
  { num: '5', label: 'Key Employees', sub: 'Guangzhou HQ' },
  { num: '200+', label: 'Bonded Stock', sub: 'Ready to Ship' },
];

// Cooperation stats — values aligned with the claims made site-wide
// (60+ markets, 15+ years, 6 authorized brands, 24h quote) rather than
// unverifiable precise percentages.
const cooperationStats = [
  { value: '360°', label: 'Pre-Shipment Inspection', sub: 'Photo & video report' },
  { value: '24/7', label: 'WhatsApp Support', sub: 'Direct to our team' },
  { value: '60+', label: 'Export Markets', sub: 'Countries served' },
  { value: '24h', label: 'Quotation Turnaround', sub: 'FOB + CIF pricing' },
  { value: '15+', label: 'Years in Export', sub: 'Founder-led trade' },
  { value: '6', label: 'Authorized OEM Brands', sub: 'Direct dealer MoUs' },
];

const businessLines = [
  {
    img: '/images/vehicles/evautopro-changan-uni-t-01.webp',
    title: 'Brand-New Vehicles',
    bullets: ['Latest Model · Immediate Shipment', '6 Authorized OEM Brands', '45+ Models Available', 'No Dealer Markups'],
    cta: 'Browse Cars',
    href: '/cars/',
  },
  {
    img: '/images/vehicles/evautopro-deepal-s07-01.webp',
    title: 'OEM & Aftermarket Spare Parts',
    bullets: ['95% Availability Rate', '24/7 Worldwide Delivery', 'Genuine OEM Parts', 'Aftermarket Quality'],
    cta: 'Inquire Parts',
    href: '/contact/quote/?type=parts',
  },
  {
    img: '/images/vehicles/evautopro-jetour-t2-01.webp',
    title: 'Certified Used Cars',
    bullets: ['All-round Quality Check', 'Full VIN Check & History', 'No Hidden Fees', 'Photo + Video Inspection'],
    cta: 'Coming Q3 2026',
    href: '/contact/',
    coming: true,
  },
];

const exportProcess = [
  { step: 1, img: '/images/vehicles/evautopro-deepal-s05-01.webp', title: 'Instant Inquiry Response', day: '< 24 hrs' },
  { step: 2, img: '/images/vehicles/evautopro-jetour-t2-02.webp', title: 'Contract Execution', day: '1-2 days' },
  { step: 3, img: '/images/faq-sourcing.webp', title: 'Vehicle Sourcing', day: '2-3 days' },
  { step: 4, img: '/images/vehicles/evautopro-geely-coolray-02.webp', title: 'Inspection & Certification', day: '3-5 days' },
  { step: 5, img: '/images/vehicles/evautopro-geely-emgrand-01.webp', title: 'Vehicle Readiness', day: '5-10 days' },
  { step: 6, img: '/images/vehicles/evautopro-jetour-t2-01.webp', title: 'Logistics Coordination', day: '3-5 days' },
  { step: 7, img: '/images/vehicles/evautopro-jetour-x70plus-01.webp', title: 'Sea / Rail Transit', day: '18-45 days' },
  { step: 8, img: '/images/vehicles/evautopro-geely-coolray-01.webp', title: 'Door Delivery', day: 'Arrival' },
];

const trustedMarkets = [
  { region: 'Russia & CIS', subtitle: 'Compact EV Plans', img: '/images/vehicles/evautopro-jetour-t2-01.webp' },
  { region: 'Middle East', subtitle: 'New Energy MPV', img: '/images/vehicles/evautopro-geely-coolray-01.webp' },
  { region: 'Central Asia', subtitle: 'Kazakhstan/Uzbek Dealer', img: '/images/vehicles/evautopro-jetour-x70plus-01.webp' },
  { region: 'Africa', subtitle: 'East African Logistics', img: '/images/vehicles/evautopro-changan-cs55-plus-01.webp' },
];

// Team function summary — no invented names/photos/direct lines here.
// Swap in real staff bios + photos (with their consent) when the customer
// supplies them; see /contact/ for the one verified contact channel.
const teamFunctions = [
  { role: 'Order Fulfillment', desc: 'Confirms stock, pricing and configuration for every inquiry.' },
  { role: 'Shipping & Customs', desc: 'Coordinates export documents, loading and customs clearance.' },
  { role: 'CIS & Regional Sales', desc: 'Handles market-specific sourcing across our active regions.' },
  { role: 'OEM Spare Parts', desc: 'Sources genuine and aftermarket parts for shipped vehicles.' },
];
---

<BaseLayout
  title="About EV Auto Pro | China NEV Export Specialist — Founder-Led Since 2010"
  description="Authorized exporter of Chinese new energy vehicles. Guangzhou HQ. 15+ years export trade, 6 OEM dealer MoUs, 60+ countries served."
>
  {/* ============ 1. HERO (深色全屏车型背景 + 标语 overlay) ============ */}
  <section class="relative bg-ink-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/faq-logistics.webp" alt="" class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 lg:py-40">
      <nav class="text-xs text-ink-400 mb-6">
        <a href="/" class="hover:text-brand-500">Home</a> · <span class="text-white">About</span>
      </nav>
      <h1 class="text-4xl lg:text-6xl font-bold text-white leading-tight mb-6 max-w-4xl">
        Your Trusted Partner for China NEV Procurement & Global Distribution
      </h1>
      <p class="text-lg lg:text-xl text-ink-300 max-w-2xl leading-relaxed">
        EV Auto Pro — Your one-stop hub for sourcing Chinese auto products
      </p>
    </div>
  </section>

  {/* ============ 2. ABOUT EV Auto Pro + 6 数据卡 + Video ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-16">
        {/* Left: Story + 6 stats */}
        <div class="lg:col-span-7">
          <p class="text-sm font-semibold text-brand-500 uppercase tracking-wider mb-4">About EV Auto Pro</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-8 leading-tight">A founder-led China NEV exporter</h2>
          <p class="text-base lg:text-lg text-ink-700 leading-relaxed mb-12">
            EV Auto Pro is a professional Chinese new energy vehicle exporter, specializing in global dealer partnerships for high-quality new vehicles, quality used cars, and OEM spare parts. With direct partnerships spanning <strong>6 authorized OEMs (Changan, Deepal, Qiyuan, Geely, VW China, Jetour)</strong> plus 35 additional brands, we deliver one-stop sourcing solutions for international buyers. Founded in Guangzhou by Cai with 15 years of cross-border trade experience, we pivoted to NEV export in 2022.
          </p>
          <div class="grid grid-cols-3 gap-6">
            {aboutStats.map(s => (
              <div class="border-l-2 border-brand-500 pl-4 py-2">
                <div class="text-3xl lg:text-4xl font-bold text-ink-900">{s.num}</div>
                <div class="text-sm text-ink-700 font-semibold mt-2">{s.label}</div>
                <div class="text-xs text-ink-500 mt-1">{s.sub}</div>
              </div>
            ))}
          </div>
        </div>
        {/* Right: video placeholder */}
        <div class="lg:col-span-5">
          <div class="aspect-video rounded-xl overflow-hidden border border-ink-200 bg-ink-900 relative group">
            <img src="/images/faq-logistics.webp" alt="Why import cars from EV Auto Pro" class="w-full h-full object-cover opacity-70" />
            <div class="absolute inset-0 flex items-center justify-center">
              <button class="w-16 h-16 bg-brand-500 hover:bg-brand-600 rounded-full flex items-center justify-center text-white text-2xl transition-colors">▶</button>
            </div>
            <div class="absolute bottom-4 left-4 right-4 text-white">
              <div class="text-xs font-semibold text-brand-500 uppercase">Watch the story</div>
              <div class="text-lg font-bold mt-1">Why Import Cars from China — EV Auto Pro</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 3. GLOBAL COOPERATION (real photo + clean stats) ============ */}
  <section class="py-24 lg:py-32 bg-ink-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        {/* Real logistics photo */}
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3] lg:aspect-auto lg:h-full lg:min-h-[420px]">
          <img src="/images/faq-sourcing.webp" alt="Row of export-ready vehicles in stock"
               class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-900/50 to-transparent"></div>
        </div>

        {/* Copy + stats */}
        <div>
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Global Cooperation</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-4">
            Built for long-term dealer partnerships
          </h2>
          <p class="text-base text-ink-300 leading-relaxed mb-10">
            From your first inquiry to delivery at your port, one team handles sourcing, inspection,
            documents and shipping — so every order runs the same, order after order.
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-8">
            {cooperationStats.map(s => (
              <div>
                <div class="text-3xl lg:text-4xl font-bold text-brand-500 tabular-nums leading-none">{s.value}</div>
                <div class="text-sm font-semibold text-white mt-2 leading-tight">{s.label}</div>
                <div class="text-xs text-ink-400 mt-1">{s.sub}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 4. WHAT WE HAVE (3 业务大卡 + 图) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">New cars · Quality used cars · Reliable spare parts</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {businessLines.map(b => (
          <div class="bg-white rounded-xl overflow-hidden border border-ink-200 hover:border-brand-500 hover:shadow-lg transition-all">
            <div class="aspect-[16/10] bg-ink-100 overflow-hidden relative">
              <img src={b.img} alt={b.title} class="w-full h-full object-cover" />
              {b.coming && (
                <span class="absolute top-3 right-3 px-2 py-1 bg-ink-900 text-white text-[10px] font-bold rounded">Q3 2026</span>
              )}
            </div>
            <div class="p-6">
              <h3 class="text-lg font-bold text-ink-900 mb-4">{b.title}</h3>
              <ul class="space-y-2 mb-5">
                {b.bullets.map(item => (
                  <li class="flex items-start gap-2 text-sm text-ink-700">
                    <span class="text-brand-500 mt-0.5 flex-shrink-0">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <a href={b.href} class={b.coming ? 'inline-flex items-center text-sm font-semibold text-ink-500' : 'inline-flex items-center text-sm font-semibold text-brand-500 hover:text-brand-600'}>
                {b.cta} →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 5. ONE-STOP EXPORT (8-step grid with images) ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">One-Stop China Car Export Services</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">From Order to Delivery — No Surprises</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {exportProcess.map(p => (
          <div class="bg-white rounded-xl overflow-hidden border border-ink-200 hover:border-brand-500 hover:shadow-md transition-all">
            <div class="aspect-[4/3] bg-ink-100 overflow-hidden relative">
              <img src={p.img} alt={p.title} class="w-full h-full object-cover" />
              <span class="absolute top-2 left-2 w-8 h-8 rounded-full bg-brand-500 text-white font-bold flex items-center justify-center text-sm">{p.step}</span>
            </div>
            <div class="p-4">
              <div class="text-[10px] text-brand-500 font-semibold uppercase">{p.day}</div>
              <h3 class="text-sm font-semibold text-ink-900 mt-1">{p.title}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 6. TRUSTED BY GLOBAL DEALERS (4 区域 + 大图) ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Trusted by Global Dealers</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Asia · Africa · Middle East · Europe · LATAM</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {trustedMarkets.map(m => (
          <div class="bg-white rounded-xl overflow-hidden border border-ink-200 hover:border-brand-500 hover:shadow-md transition-all group">
            <div class="aspect-[4/3] bg-ink-100 overflow-hidden">
              <img src={m.img} alt={m.region} class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
            <div class="p-5">
              <h3 class="text-lg font-bold text-ink-900">{m.region}</h3>
              <p class="text-xs text-ink-500 mt-1">{m.subtitle}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 7. TEAM FUNCTIONS ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Our Team</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Founder-led, Guangzhou HQ</h2>
        <p class="text-sm text-ink-500 mt-2 max-w-2xl mx-auto">
          Every inquiry is handled by our own team, not a call center. Meet the founder on our
          <a href="/about/founder/" class="text-brand-500 hover:underline font-semibold">Founder page</a>,
          or <a href="/contact/" class="text-brand-500 hover:underline font-semibold">contact us directly</a>.
        </p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
        {teamFunctions.map(f => (
          <div class="text-center bg-ink-50 rounded-xl p-6">
            <h3 class="font-bold text-sm text-ink-900">{f.role}</h3>
            <p class="text-xs text-ink-600 mt-2 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 8. CTA Banner (双车图 + 询盘) ============ */}
  <section class="py-24 lg:py-32 bg-ink-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img src="/images/vehicles/evautopro-changan-uni-t-01.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="text-brand-500 font-bold text-lg mb-2">EV AUTO PRO</div>
        <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-4">
          Import Cars from China
        </h2>
        <p class="text-base text-ink-300 mb-6">
          6 authorized brands · 200+ in bonded stock · 60+ countries served · 24h quote
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 bg-white/10 rounded-full text-xs text-white">95% Models In-Stock</span>
          <span class="px-3 py-1 bg-white/10 rounded-full text-xs text-white">Full Certified</span>
          <span class="px-3 py-1 bg-white/10 rounded-full text-xs text-white">Guangzhou HQ</span>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-6">
        <h3 class="text-xl font-bold text-ink-900 mb-2">Get a quote</h3>
        <p class="text-xs text-ink-500 mb-4">Reply within 24h</p>
        <form id="about-quote" class="space-y-3" novalidate>
          <input type="text" name="honeypot" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" />
          <input type="text" name="name" required placeholder="Name *" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          <WhatsAppField required
            fieldClass="px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm bg-white" />
          <input type="email" name="email" required placeholder="Email *" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm" />
          <textarea name="message" rows="2" placeholder="Model / Quantity / Market" class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:border-brand-500 focus:outline-none text-sm"></textarea>
          <button type="submit" class="w-full px-6 py-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">Submit</button>
          <div id="about-status" class="text-xs text-center hidden"></div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const f = document.getElementById('about-quote') as HTMLFormElement | null;
  const st = document.getElementById('about-status') as HTMLDivElement | null;
  f?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!st) return;
    st.classList.remove('hidden', 'text-green-600', 'text-red-600');
    st.classList.add('text-ink-500');
    st.textContent = 'Sending…';
    try {
      const r = await fetch('/api/inquiry', { method: 'POST', body: new FormData(f) });
      const d = await r.json();
      if (r.ok) {
        st.classList.add('text-green-600');
        st.textContent = '✓ ' + (d.message ?? 'Thank you!');
        f.reset();
      } else {
        st.classList.add('text-red-600');
        st.textContent = '⚠ ' + (d.error ?? 'Try again');
      }
    } catch {
      st.classList.add('text-red-600');
      st.textContent = '⚠ Network error';
    }
  });
</script>
