                <div class="pb-3 text-xs text-ink-600 leading-relaxed">{f.a}</div>
              </details>
            ))}
          </div>
          <button class="w-full mt-4 py-2.5 border border-ink-300 hover:border-brand-500 text-ink-700 hover:text-brand-500 text-xs font-semibold rounded-md transition-colors">View More Questions</button>
