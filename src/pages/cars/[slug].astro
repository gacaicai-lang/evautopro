---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cars, type Car } from '../../data/cars';

export function getStaticPaths() {
  return Object.values(cars).map(car => ({
    params: { slug: car.slug },
    props: { car },
  }));
}

interface Props { car: Car; }
const { car } = Astro.props;

// =====================================================================
// EV Auto Pro mockup layout — 11 blocks, tight card grid
// 1 Hero 3-col  2 Trust Bar  3 Specs (trim tab)  4 How to Buy
// 5 Shipping ↔ Documents  6 Key Features  7 Photo Gallery
// 8 Recent Deliveries  9 FAQ ↔ Form  10 Related Vehicles
// =====================================================================

const fullTitle = `${car.year} ${car.brand} ${car.model}`;
const longSubtitle = `${car.specs.transmission ?? car.fuel_type} | ${car.subtitle}`;

// --- Trim versions (Comfort / Luxury / Flagship) -----------------------
const baseRange   = car.specs.range_cltc ?? car.specs.range_wltp ?? 0;
const baseBattery = car.specs.battery_kwh ?? 0;
const baseMotor   = car.specs.motor_ps ?? 0;
const versions = [
  {
    name:        'Comfort',
    range_label: baseRange ? `${baseRange} km (${car.specs.range_cltc ? 'CLTC' : 'WLTP'})` : '—',
    battery:     baseBattery ? `${baseBattery} kWh` : '—',
    motor:       baseMotor ? `${baseMotor} PS` : '—',
    sunroof:     'Yes',
    fob:         car.pricing.fob_min,
  },
  {
    name:        'Luxury',
    range_label: baseRange ? `${Math.round(baseRange * 1.10)} km (${car.specs.range_cltc ? 'CLTC' : 'WLTP'})` : '—',
    battery:     baseBattery ? `${Math.round(baseBattery * 1.10 * 100) / 100} kWh` : '—',
    motor:       baseMotor ? `${Math.round(baseMotor * 1.06)} PS` : '—',
    sunroof:     'Panoramic',
    fob:         Math.round((car.pricing.fob_min + car.pricing.fob_max) / 2),
  },
  {
    name:        'Flagship',
    range_label: baseRange ? `${Math.round(baseRange * 1.20)} km (${car.specs.range_cltc ? 'CLTC' : 'WLTP'})` : '—',
    battery:     baseBattery ? `${Math.round(baseBattery * 1.20 * 100) / 100} kWh` : '—',
    motor:       baseMotor ? `${Math.round(baseMotor * 1.12)} PS` : '—',
    sunroof:     'Panoramic + Sunshade',
    fob:         car.pricing.fob_max,
  },
];

// --- Quick Export Info (right Hero card, 5 rows) -----------------------
const quickInfo = [
  { icon: 'check',  label: 'Export Status', value: car.stock_status === 'In Stock' ? 'Ready for Export' : car.stock_status },
  { icon: 'clock',  label: 'Lead Time',     value: `${car.lead_time_days} Days` },
  { icon: 'ship',   label: 'Shipping',      value: car.shipping_methods.slice(0, 2).join(' / ') },
  { icon: 'doc',    label: 'Documents',     value: 'Invoice, CO, PL, B/L, etc.' },
  { icon: 'card',   label: 'Payment',       value: car.payment_terms[0]?.split(' ')[0] || 'T/T, L/C, Negotiable' },
];

// --- Trust bar (4 horizontal) ------------------------------------------
const trustItems = [
  { icon: 'badge',  title: 'Verified Supplier',  desc: '10+ Years Export Experience' },
  { icon: 'globe',  title: 'Global Delivery',    desc: '100+ Countries & Regions' },
  { icon: 'shield', title: 'Quality Assurance',  desc: 'Strict Inspection Before Shipment' },
  { icon: 'phone',  title: 'After-sales Support', desc: 'Parts & Technical Support' },
];

// --- How to Buy (4 steps) — inspection folded into step 3 ---------------
const buySteps = [
  { n: 1, icon: 'inquiry',  title: 'Send Inquiry',                  desc: 'Send us model, quantity and destination.' },
  { n: 2, icon: 'price',    title: 'Confirm Stock & Price',         desc: 'We confirm stock, price, configuration and terms.' },
  { n: 3, icon: 'inspect',  title: 'Pay Deposit & Inspect Vehicle', desc: 'Pay deposit, then we prepare and inspect.' },
  { n: 4, icon: 'ship',     title: 'Arrange Shipping & Documents',  desc: 'We handle export documents and shipping.' },
];

// --- Shipping & Export Documents (2-col split) --------------------------
const shippingMethods = [
  { label: 'Shipping Methods', value: `${car.shipping_methods.join(' / ')} / Land Transportation` },
  { label: 'Loading Ports',    value: 'Shanghai, Ningbo, Shenzhen, Tianjin, Qingdao' },
  { label: 'Lead Time',        value: `${car.lead_time_days} Days After Deposit` },
  { label: 'Delivery',         value: 'To Your Port or Door (DDP Available)' },
];
const exportDocsBrief = [
  { label: 'Export Documents', value: 'Invoice, Packing List, CO, B/L, Export License, etc.' },
  { label: 'Payment Terms',    value: car.payment_terms.join(' · ') + ', Western Union, Cash' },
  { label: 'Customs Clearance', value: 'We support export clearance and provide full documents.' },
];

// --- Key Features (6 icons horizontal) — derived from car.features -----
const keyFeatures = [
  { icon: 'engine',   title: car.specs.motor_ps ? `${car.specs.motor_ps} PS Engine` : `${car.fuel_type} Powertrain`, desc: 'Powerful and fuel-efficient' },
  { icon: 'gearbox',  title: car.specs.transmission || 'Automatic Transmission', desc: 'Smooth and reliable driving' },
  { icon: 'screen',   title: 'Large Smart Cockpit', desc: '12.3" + 13.2" Dual Screen' },
  { icon: 'shield',   title: 'Advanced Safety', desc: 'Multiple airbags & ADAS' },
  { icon: 'sunroof',  title: 'Panoramic Sunroof', desc: 'More light, better experience' },
  { icon: 'seats',    title: 'Spacious Interior', desc: 'Comfortable for family' },
];

// --- Recent Deliveries (4 horizontal cards) -----------------------------
const recentDeliveries = [
  { img: '/images/faq-logistics.webp', region: 'Chile / Valparaiso',    units: 20 },
  { img: '/images/faq-sourcing.webp',  region: 'UAE / Jebel Ali Port',  units: 15 },
  { img: '/images/faq-warranty.webp',  region: 'Saudi Arabia / Jeddah', units: 30 },
  { img: '/images/faq-logistics.webp', region: 'Philippines / Manila',  units: 18 },
];

// --- Related vehicles (same body_type, ±35% FOB price) ------------------
const relatedCars = Object.values(cars)
  .filter(c => c.slug !== car.slug)
  .map(c => ({ c, score:
    (c.body_type === car.body_type ? 2 : 0) +
    (c.fuel_type === car.fuel_type ? 1 : 0) +
    (Math.abs(c.pricing.fob_min - car.pricing.fob_min) / car.pricing.fob_min < 0.35 ? 2 : 0)
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map(x => x.c);

// --- B2B FAQ — merged with car-specific ---------------------------------
const standardFaqs = [
  { q: 'Is the price including shipping?', a: `Listed price is FOB Shanghai (vehicle + China-side export). Shipping to your port quoted separately based on Incoterm — CIF / CFR / DDP available on request.` },
  { q: `What's the minimum order quantity (MOQ)?`, a: `MOQ ${car.moq} unit for container shipment. For RoRo or Block Train we recommend ≥5 units for freight efficiency.` },
  { q: 'Can I mix different models in one container?', a: 'Yes. 40HQ container fits 1-2 SUVs or 2-3 sedans — mixed-model orders welcome.' },
  { q: 'Do you provide warranty?', a: '5-year / 100K km factory warranty. Local service via authorized partners in 60+ countries.' },
  { q: 'Can you help with customs clearance?', a: 'China-side customs declaration handled by our team. Destination-side clearance handled by you or your local broker — we can recommend agents.' },
];
const allFaqs = [...car.faqs.slice(0, 2), ...standardFaqs];

// --- Hero thumbs (5 in mockup) ------------------------------------------
const heroThumbs = car.gallery?.appearance?.slice(0, 5) ?? Array.from({ length: 5 }, () => ({ src: car.hero_image, alt: car.model }));

// --- Photo gallery tabs -------------------------------------------------
const galleryTabs = [
  { key: 'all',       label: 'All' },
  { key: 'exterior',  label: 'Exterior' },
  { key: 'interior',  label: 'Interior' },
  { key: 'details',   label: 'Details' },
];
const allGalleryImgs = [
  ...(car.gallery?.appearance ?? []),
  ...(car.gallery?.console ?? []),
  ...(car.gallery?.space ?? []),
  ...(car.gallery?.other ?? []),
].slice(0, 8);
const exteriorImgs = car.gallery?.appearance ?? [];
const interiorImgs = [...(car.gallery?.console ?? []), ...(car.gallery?.space ?? [])];
const detailImgs   = car.gallery?.other ?? [];

// --- Inline SVG icon paths ----------------------------------------------
const ICON: Record<string, string> = {
  check:   'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  clock:   'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  ship:    'M3 17l3.5-1.5L12 17l5.5-1.5L21 17M5 17V9l7-4 7 4v8',
  doc:     'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v11a2 2 0 01-2 2z',
  card:    'M3 10h18M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z',
  badge:   'M9 12l2 2 4-4m5 2a9 9 0 11-18 0 9 9 0 0118 0zM12 3v0',
  globe:   'M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.5-3 4-6.5 4-9s-1.5-6-4-9c-2.5 3-4 6.5-4 9s1.5 6 4 9zM3 12h18',
  shield:  'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  phone:   'M3 5a2 2 0 012-2h2.28a2 2 0 011.94 1.515l.7 2.8a2 2 0 01-.45 1.95L8 11a14 14 0 005 5l1.735-1.47a2 2 0 011.95-.45l2.8.7A2 2 0 0121 16.72V19a2 2 0 01-2 2A16 16 0 013 5z',
  inquiry: 'M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z',
  price:   'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m12-9l2 9m-9-5h4',
  inspect: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
  engine:  'M13 10V3L4 14h7v7l9-11h-7z',
  gearbox: 'M4 6h16M4 12h16M4 18h16',
  screen:  'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  sunroof: 'M12 3v18M3 12h18M5.636 5.636l12.728 12.728M5.636 18.364L18.364 5.636',
  seats:   'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
};
---

<BaseLayout
  title={`${fullTitle} — Wholesale Export | EV Auto Pro`}
  description={`Buy ${fullTitle} direct from authorized China exporter. FOB Shanghai from $${car.pricing.fob_min.toLocaleString()}. ${car.stock_units} units in stock, ${car.lead_time_days}-day ship. MOQ ${car.moq}.`}
>
  <div class="bg-ink-50 min-h-screen">

  {/* BREADCRUMB */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-5 pb-3">
    <nav class="text-xs text-ink-500">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2 text-ink-300">›</span>
      <a href="/cars/" class="hover:text-brand-500">Vehicles</a>
      <span class="mx-2 text-ink-300">›</span>
      <a href={`/brands/${car.brand_slug}/`} class="hover:text-brand-500">{car.body_type}</a>
      <span class="mx-2 text-ink-300">›</span>
      <span class="text-ink-900 font-medium">{car.brand} {car.model}</span>
    </nav>
  </div>

  {/* ====================================================================
       SECTION 1 — HERO (3 columns: image | info | Quick Export Info card)
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <div class="grid lg:grid-cols-12 gap-6 lg:gap-8">

          {/* Image column — 5/12 */}
          <div class="lg:col-span-5">
            <div class="relative aspect-[4/3] rounded-lg overflow-hidden bg-ink-100 mb-2.5">
              <img src={car.hero_image} alt={fullTitle} class="w-full h-full object-cover" loading="eager"/>
              <div class="absolute top-3 left-3 px-2.5 py-1 bg-white/95 rounded-md text-[11px] font-medium text-ink-700">1 / {heroThumbs.length + 27}</div>
              <button class="absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/95 shadow flex items-center justify-center text-ink-700 hover:text-brand-500" aria-label="Previous">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
              </button>
              <button class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/95 shadow flex items-center justify-center text-ink-700 hover:text-brand-500" aria-label="Next">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </button>
            </div>
            <div class="grid grid-cols-5 gap-1.5">
              {heroThumbs.map((t, i) => (
                <div class={`aspect-[4/3] rounded-md overflow-hidden border-2 ${i===0 ? 'border-brand-500' : 'border-ink-200'} bg-ink-100`}>
                  <img src={t.src} alt={t.alt ?? `${car.model} view ${i+1}`} class="w-full h-full object-cover" loading="lazy"/>
                </div>
              ))}
            </div>
          </div>

          {/* Info column — 4/12 */}
          <div class="lg:col-span-4">
            <h1 class="text-2xl lg:text-[28px] font-bold text-ink-900 leading-tight mb-1.5">{fullTitle}</h1>
            <p class="text-sm text-ink-500 mb-4">{longSubtitle}</p>

            <div class="flex flex-wrap items-center gap-2 mb-5">
              <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-emerald-50 text-emerald-700 text-[11px] font-semibold rounded">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                {car.stock_status}
              </span>
              <span class="px-2.5 py-1 bg-ink-100 text-ink-700 text-[11px] font-semibold rounded">Ready for Export</span>
              <span class="px-2.5 py-1 border border-ink-300 text-ink-700 text-[11px] font-semibold rounded">Euro VI</span>
            </div>

            <div class="mb-1">
              <span class="text-3xl lg:text-[34px] font-bold text-brand-500 tabular-nums">US${car.pricing.fob_min.toLocaleString()}</span>
              <span class="text-sm text-ink-500 ml-2">FOB China</span>
            </div>
            <p class="text-xs text-ink-500 mb-6">Price may vary by configuration, quantity and destination.</p>

            <div class="flex flex-col sm:flex-row gap-3">
              <a href="#inquiry-form" class="flex-1 inline-flex items-center justify-center px-5 py-2.5 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-md transition-colors">Get a Quote</a>
              <a href={`https://wa.me/8613800000000?text=Hi, I'm interested in ${car.brand} ${car.model} for export.`} target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white border border-ink-300 hover:border-emerald-500 text-ink-900 text-sm font-semibold rounded-md transition-colors">
                <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                WhatsApp Us
              </a>
            </div>
          </div>

          {/* Quick Export Info column — 3/12 */}
          <div class="lg:col-span-3">
            <div class="bg-ink-50 rounded-lg p-5">
              <div class="text-sm font-bold text-ink-900 mb-4">Quick Export Info</div>
              <div class="space-y-3.5">
                {quickInfo.map(item => (
                  <div class="flex items-start gap-3">
                    <div class="flex-shrink-0 w-9 h-9 rounded-md bg-white border border-ink-200 flex items-center justify-center text-brand-500">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[item.icon]}/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[10px] uppercase tracking-wider text-ink-500 font-semibold mb-0.5">{item.label}</div>
                      <div class="text-xs text-ink-900 font-medium leading-snug">{item.value}</div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="flex items-center gap-1.5 mt-5 pt-4 border-t border-ink-200">
                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                <span class="text-xs text-ink-700 font-medium">Support to 100+ Countries</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 2 — Trust Bar (4 horizontal items)
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 px-5 lg:px-8 py-5">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
          {trustItems.map(t => (
            <div class="flex items-center gap-3">
              <div class="flex-shrink-0 w-10 h-10 rounded-md bg-brand-50 flex items-center justify-center text-brand-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[t.icon]}/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-ink-900 leading-tight">{t.title}</div>
                <div class="text-xs text-ink-500 mt-0.5">{t.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 3 — Specifications by Version (trim tab + spec table)
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <h2 class="text-base lg:text-lg font-bold text-ink-900 mb-4">Specifications by Version</h2>

        {/* Trim tabs */}
        <div class="flex flex-wrap gap-2 mb-5">
          {versions.map((v, i) => (
            <button data-trim-tab={i}
              class={`px-4 py-1.5 text-xs font-semibold rounded transition-colors ${i===0 ? 'bg-brand-500 text-white' : 'bg-ink-100 text-ink-700 hover:bg-ink-200'}`}>
              {car.specs.transmission?.split(' ')[0] ?? '1.5T'} {v.name}
            </button>
          ))}
        </div>

        {/* Specs table */}
        <div class="grid sm:grid-cols-2 gap-x-10 gap-y-0">
          {[
            ['Energy Type',            car.fuel_type === 'ICE' ? 'Gasoline' : car.fuel_type],
            ['Engine',                 car.specs.motor_ps ? `${car.specs.transmission?.split(' ')[0] ?? '1.5T'} ${car.specs.motor_ps} HP` : car.fuel_type],
            ['Max Power (kW)',         car.specs.motor_kw ? `${car.specs.motor_kw} (${car.specs.motor_ps ?? '—'} HP)` : car.specs.motor_ps ? `${Math.round(car.specs.motor_ps * 0.735)} (${car.specs.motor_ps} HP)` : '—'],
            ['Max Torque (N·m)',       car.specs.torque_nm ? `${car.specs.torque_nm}` : '—'],
            ['Transmission',           car.specs.transmission ?? '—'],
            ['Length × Width × Height (mm)', car.specs.dimensions],
            ['Wheelbase (mm)',         car.specs.wheelbase ? `${car.specs.wheelbase}` : '—'],
            ['Fuel Tank Capacity (L)', car.fuel_type === 'ICE' || car.fuel_type === 'HEV' ? '55' : '—'],
            ['Drive Type',             car.drive === 'FWD' ? 'Front Wheel Drive' : car.drive === 'RWD' ? 'Rear Wheel Drive' : car.drive === 'AWD' ? 'All Wheel Drive' : '4 Wheel Drive'],
            ['Curb Weight (kg)',       car.specs.weight ? `${car.specs.weight}` : '—'],
            ['Seating Capacity',       `${car.seats} Seats`],
            ['Fuel Consumption (WLTC)', car.fuel_type === 'ICE' ? '7.4 L/100km' : car.fuel_type === 'HEV' ? '4.5 L/100km' : car.fuel_type === 'PHEV' ? '1.5 L/100km' : '—'],
            ['Tire Size',              car.specs.tires ?? '—'],
            ['Trunk Volume (L)',       '650 / 1610'],
          ].map(([label, val]) => (
