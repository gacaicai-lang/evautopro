                  <svg class="w-6 h-6 text-ink-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <h3 class="text-base font-bold text-ink-900 mb-2">{tab === 'console' ? 'Interior & Console Photos' : tab === 'space' ? 'Cabin & Trunk Space Photos' : 'Additional Detail Photos'} Available on Request</h3>
                <p class="text-sm text-ink-600 mb-6 max-w-md mx-auto leading-relaxed">
                  We share high-resolution {tab === 'console' ? 'dashboard, infotainment screen and cockpit' : tab === 'space' ? 'rear cabin, seat layout and cargo space' : 'wheel, badge and detail close-up'} photos directly with serious buyers. Contact us with your destination market and we'll send the full photo + video pack within 12 hours.
                </p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                  <a href={`https://wa.me/8619912345678?text=Hi, please send me ${tab} photos for the ${car.brand} ${car.model}.`} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    Request via WhatsApp
                  </a>
                  <a href={`/contact/quote/?model=${car.slug}&request=photos`} class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white border border-ink-300 hover:border-ink-500 text-ink-900 text-sm font-semibold rounded-lg transition-colors">
                    Request via Form
                  </a>
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </section>

  {/* Gallery tab switcher (vanilla JS, no framework) */}
  <script is:inline>
    document.querySelectorAll('[data-gallery-tab]').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-gallery-tab');
        document.querySelectorAll('[data-gallery-tab]').forEach(b => {
          const active = b.getAttribute('data-gallery-tab') === tab;
          b.classList.toggle('text-brand-500', active);
          b.classList.toggle('border-b-2', active);
          b.classList.toggle('border-brand-500', active);
          b.classList.toggle('-mb-px', active);
          b.classList.toggle('text-ink-500', !active);
        });
        document.querySelectorAll('[data-gallery-panel]').forEach(p => {
          p.classList.toggle('hidden', p.getAttribute('data-gallery-panel') !== tab);
        });
      });
    });
  </script>

