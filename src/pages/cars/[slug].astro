  <script>
    // Brochure lead-capture modal — the PDF unlocks only after the form
    // submits. If the inquiry API is unreachable the download still unlocks
    // (never dead-end a buyer), but the happy path records the lead first.
    const modal = document.getElementById('brochure-modal');
    const stepForm = document.getElementById('brochure-step-form');
    const stepDone = document.getElementById('brochure-step-done');
    const brochureForm = document.getElementById('brochure-form') as HTMLFormElement | null;
    const brochureStatus = document.getElementById('brochure-status');

    document.querySelectorAll('[data-brochure-open]').forEach(btn => {
      btn.addEventListener('click', () => {
        modal?.classList.remove('hidden');
        stepForm?.classList.remove('hidden');
        stepDone?.classList.add('hidden');
        document.body.style.overflow = 'hidden';
      });
    });
    const closeModal = () => {
      modal?.classList.add('hidden');
      document.body.style.overflow = '';
    };
    document.querySelectorAll('[data-brochure-close]').forEach(el => el.addEventListener('click', closeModal));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    brochureForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!brochureForm.reportValidity()) return;
      if (brochureStatus) {
        brochureStatus.classList.remove('hidden', 'text-red-600');
        brochureStatus.classList.add('text-ink-500');
        brochureStatus.textContent = 'Sending…';
      }
      try {
        await fetch('/api/inquiry', { method: 'POST', body: new FormData(brochureForm) });
      } catch { /* still unlock — never dead-end a buyer */ }
      stepForm?.classList.add('hidden');
      stepDone?.classList.remove('hidden');
    });

    // Hero thumbnail switcher
    const mainImg = document.getElementById('hero-main-img') as HTMLImageElement | null;
    const thumbs = document.querySelectorAll<HTMLButtonElement>('.hero-thumb');
    thumbs.forEach(btn => {
      btn.addEventListener('click', () => {
        if (!mainImg || !btn.dataset.heroThumb) return;
        mainImg.src = btn.dataset.heroThumb;
        thumbs.forEach(b => b.classList.replace('border-brand-500', 'border-ink-200'));
        btn.classList.replace('border-ink-200', 'border-brand-500');
      });
    });

    // Gallery tabs
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-gallery-tab]');
    const panels = document.querySelectorAll<HTMLElement>('[data-gallery-panel]');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('text-brand-500', 'border-b-2', 'border-brand-500', '-mb-px'));
        tabs.forEach(t => t.classList.add('text-ink-500'));
        tab.classList.remove('text-ink-500');
        tab.classList.add('text-brand-500', 'border-b-2', 'border-brand-500', '-mb-px');
        panels.forEach(p => p.classList.toggle('hidden', p.dataset.galleryPanel !== tab.dataset.galleryTab));
      });
    });

    // Inquiry form
    const carForm = document.getElementById('car-inquiry-form') as HTMLFormElement | null;
    const carStatus = document.getElementById('car-inquiry-status');
    carForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!carStatus) return;
      if (!carForm.reportValidity()) return;
      carStatus.classList.remove('hidden', 'text-green-600', 'text-red-600');
      carStatus.classList.add('text-ink-500');
      carStatus.textContent = 'Sending…';
      try {
        const res = await fetch('/api/inquiry', { method: 'POST', body: new FormData(carForm) });
        const json = await res.json();
        if (res.ok) {
          carStatus.classList.add('text-green-600');
          carStatus.textContent = '✓ ' + (json.message ?? 'Thank you! Our team will reply within 24 hours.');
          carForm.reset();
        } else {
          carStatus.classList.add('text-red-600');
          carStatus.textContent = '⚠ ' + (json.error ?? 'Something went wrong. Please try again.');
        }
      } catch {
        carStatus.classList.add('text-red-600');
        carStatus.textContent = '⚠ Network error. Please email us directly at cai@evautopro.com';
      }
    });
  </script>
</BaseLayout>
