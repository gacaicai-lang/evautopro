---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cars, type Car } from '../../data/cars';
import WhatsAppField from '../../components/WhatsAppField.astro';

export function getStaticPaths() {
  return Object.values(cars).map(car => ({
    params: { slug: car.slug },
    props: { car },
  }));
}

interface Props { car: Car; }
const { car } = Astro.props;

// =====================================================================
// Vehicle product page — B2B export buyer decision flow
// Hero (gallery + price + quick export) → Trust bar → Why this vehicle
// → Full specs + equipment → Destination pricing (FOB/CIF) → Gallery
// → Export process timeline → Shipping & documents → Warranty
// → Market fit → FAQ → Inquiry form → Related vehicles
// Every number on this page comes from cars.ts — no invented figures.
// =====================================================================

const fullTitle = `${car.year} ${car.brand} ${car.model}`;
const isElectrified = ['BEV', 'PHEV', 'EREV', 'HEV'].includes(car.fuel_type);
const brochureUrl = `/brochures/evautopro-${car.slug}.pdf`;
const buildDate = new Date().toISOString().slice(0, 10);

// Container capacity from real vehicle length: 40HQ interior floor ≈ 12,032 mm,
// ~150 mm handling gap per unit, floor loading (no racking).
const CONTAINER_MM = 12032;
const vehicleLength = parseInt(car.specs.dimensions.split('×')[0], 10);
const unitsPerContainer = Math.max(1, Math.floor(CONTAINER_MM / (vehicleLength + 150)));

// Loading diagram geometry (side view, drawn to scale in a 640×150 viewBox)
const DIAG = (() => {
  const x0 = 36, innerW = 560, boxTop = 34, boxH = 78;
  const pxPerMm = innerW / CONTAINER_MM;
  const carW = vehicleLength * pxPerMm;
  const gapW = 150 * pxPerMm;
  const carH = 44;
  const cars = Array.from({ length: unitsPerContainer }, (_, i) => ({
    x: x0 + 6 + i * (carW + gapW),
    y: boxTop + boxH - carH - 4,
    w: carW,
    h: carH,
  }));
  return { x0, innerW, boxTop, boxH, carW, cars, carH };
})();

// RHD availability — stated in the per-car FAQs where confirmed
const RHD: Record<string, string> = {
  'geely-coolray': 'Factory RHD batch — MOQ 20, 45–60 days',
  'changan-cs55-plus': 'Factory RHD batch — MOQ 20, 45–60 days',
  'geely-atlas': 'Factory RHD batch — MOQ 20, 45–60 days',
  'deepal-s07': 'LHD standard — factory RHD in development (2026 Q4)',
};
const rhdNote = RHD[car.slug] ?? 'LHD standard — RHD availability on request';

// EV Auto Pro Export PDI — pre-shipment inspection program
const pdiChecks = [
  { icon: 'car',     title: 'Body & Paint',          desc: 'Panel gaps, paint depth, glass, lights and trim checked on every unit' },
  { icon: 'engine',  title: 'Powertrain & Battery',  desc: isElectrified ? 'Battery health report, charging test, drive test' : 'Engine, transmission and drive test' },
  { icon: 'screen',  title: 'Electronics & Software', desc: 'Infotainment, ADAS sensors, language settings for your market' },
  { icon: 'seats',   title: 'Interior & Equipment',  desc: 'Seats, trim and every listed equipment item verified against the order' },
  { icon: 'doc',     title: 'Documents & VIN',       desc: 'VIN match across vehicle, export certificate and Certificate of Conformity' },
  { icon: 'ship',    title: 'Loading Supervision',   desc: 'Lashing and protection checked at port, photographed before the container seals' },
];

// --- Hero stat chips (only real values) ---------------------------------
const rangeLabel = car.specs.range_cltc
  ? `${car.specs.range_cltc} km CLTC`
  : car.specs.range_wltp ? `${car.specs.range_wltp} km WLTP` : null;
const heroStats = [
  car.specs.motor_ps ? { label: 'Power', value: `${car.specs.motor_ps} PS` } : null,
  rangeLabel && isElectrified ? { label: 'EV Range', value: rangeLabel } : null,
  car.specs.accel ? { label: '0–100 km/h', value: `${car.specs.accel} s` } : null,
  { label: 'Seats', value: `${car.seats}` },
  { label: 'Drive', value: car.drive },
].filter(Boolean) as { label: string; value: string }[];

// --- Quick Export card ---------------------------------------------------
const quickInfo = [
  { icon: 'check', label: 'Availability', value: car.stock_status === 'In Stock' ? `${car.stock_units} units ready` : car.stock_status },
  { icon: 'clock', label: 'Lead Time', value: `${car.lead_time_days} days after deposit` },
  { icon: 'cart',  label: 'MOQ', value: `${car.moq} unit${car.moq > 1 ? 's' : ''}` },
  { icon: 'ship',  label: 'Shipping', value: car.shipping_methods.join(' / ') },
  { icon: 'card',  label: 'Payment', value: car.payment_terms.join(' · ') },
  { icon: 'doc',   label: 'Certification', value: car.certifications.join(' · ') },
];

// --- Trust bar (consistent with site-wide claims) ------------------------
const trustItems = [
  { icon: 'badge',  title: 'Authorized Dealer', desc: `Direct ${car.brand} supply channel` },
  { icon: 'globe',  title: '60+ Export Markets', desc: '5,000+ vehicles delivered' },
  { icon: 'shield', title: 'Pre-Shipment Inspection', desc: 'Photo & video report before loading' },
  { icon: 'phone',  title: 'After-Sales Support', desc: 'Parts supply & technical assistance' },
];

// --- Why this vehicle — per-model selling points --------------------------
const HIGHLIGHTS: Record<string, { title: string; desc: string }[]> = {
  'changan-uni-t': [
    { title: 'Design That Sells Itself', desc: 'The UNI-T\'s coupé-SUV styling is a proven showroom traffic driver — a distinctive silhouette in a segment full of look-alike compact SUVs.' },
    { title: '188 PS + 7DCT Proven Drivetrain', desc: 'Changan\'s Blue Core 1.5T with 300 N·m torque — millions of units on the road across CIS and MENA, with established parts supply.' },
    { title: 'Fast-Moving Stock', desc: `${car.stock_units} units in bonded stock with ${car.lead_time_days}-day dispatch — one of our quickest-turnaround Changan models.` },
  ],
  'jetour-t2': [
    { title: 'Highest Buyer Search Demand of Any Jetour Model', desc: '33,100 monthly searches in the UAE alone — the T2 i-DM is what buyers are actively looking for before they find us.' },
    { title: 'Genuine PHEV, Not a Badge', desc: '26.7 kWh LFP battery, dual front motors (165 kW / 390 N·m combined), 139 km NEDC pure-electric range extending to 1,000+ km combined — with the steel-cage off-road hardware to back up the adventure styling.' },
    { title: 'Proven in Central Asia & Russia', desc: 'The boxy adventure design is a hit in Uzbekistan, Kazakhstan and interior Russia — strong resale and instant brand recognition.' },
  ],
  'geely-coolray': [
    { title: 'Volvo CMA Platform', desc: 'Same architecture family as the Volvo XC40 — a European-engineered safety story your retail customers already understand and trust.' },
    { title: '#1 Chinese Compact SUV in UAE', desc: 'Proven sell-through in the Gulf and top-3 in Russia. INMETRO certification opens Brazil without extra homologation cost.' },
    { title: 'Wide Certification Coverage', desc: 'GCC, EAC and INMETRO already in place — clear the paperwork faster in three major regions.' },
  ],
  'deepal-s07': [
    { title: 'EREV Solves Charging Anxiety', desc: '200 km CLTC pure-electric commuting plus a range extender for 1,000+ km trips — the EV story that works in markets with thin charging networks.' },
    { title: 'CATL Battery, Desert-Rated', desc: 'LFP cells stable to 60°C ambient — the chemistry and supplier your buyers ask for by name.' },
    { title: 'Li Auto Alternative at Lower FOB', desc: 'Premium EREV positioning with Snapdragon 8295 cockpit and Level 2+ assist, at a significantly lower landed cost than the obvious competitor.' },
  ],
  'deepal-s05': [
    { title: '510 km CLTC Urban BEV', desc: 'The range/price ratio that works for city fleets and first-time EV retail buyers alike.' },
    { title: 'CCS2 + GB/T Charging', desc: 'Compatible with both charging standards out of the box — no adapter drama at destination.' },
    { title: 'CATL LFP + 8-Year Battery Warranty', desc: 'The battery brand and warranty length that close retail sales.' },
  ],
  'deepal-s09': [
    { title: 'Flagship Kit as Standard', desc: 'Triple 15.6" screens, 21-speaker audio, air suspension, zero-gravity rear seats — VIP-segment equipment without the VIP-segment FOB.' },
    { title: '30–40% Below the Obvious Rival', desc: 'Same EREV flagship 6-seater formula as the Li Auto L9 at a substantially lower entry price.' },
    { title: 'Executive & Family Dual Use', desc: '2+2+2 captain layout for chauffeur duty, optional 7-seat for family retail — one vehicle, two customer profiles.' },
  ],
  'changan-cs55-plus': [
    { title: 'Changan\'s Global Best Seller', desc: 'The volume model with the fastest replenishment cycle — 50+ units in stock and a 12-day dispatch, our quickest of any model.' },
    { title: 'Proven in Your Market Already', desc: 'Top-5 Chinese SUV in Russia, established in Kazakhstan via Khorgos block train, CKD partner in Egypt — parts and brand awareness solved.' },
    { title: 'RHD Factory Batches', desc: 'Factory right-hand-drive available at MOQ 20 — a compact SUV you can also sell in RHD markets.' },
  ],
  'geely-atlas': [
    { title: 'Volvo XC40 Architecture', desc: 'CMA platform with the safety cell story premium buyers respond to — at mid-SUV money.' },
    { title: 'Gulf-Ready Paperwork', desc: 'GCC and SASO certification in place — Saudi and UAE clearance without homologation delays.' },
    { title: 'BOSE + Leather as Standard', desc: 'Equipment level that photographs well and demos even better in the showroom.' },
  ],
};
const highlights = HIGHLIGHTS[car.slug] ?? [
  { title: `${car.brand} Quality, Export Ready`, desc: `${car.subtitle} with full export documentation and ${car.certifications.join(' / ')} certification.` },
  { title: 'Ready Stock', desc: `${car.stock_units} units available with ${car.lead_time_days}-day lead time and MOQ ${car.moq}.` },
  { title: 'Full Export Support', desc: 'Inspection, documents, shipping and after-sales parts supply handled by one team.' },
];

// --- Full specification rows (real fields only) ---------------------------
const specRows = [
  ['Fuel Type', car.fuel_type === 'ICE' ? 'Gasoline (ICE)' : car.fuel_type],
  car.specs.motor_ps ? ['Max Power', `${car.specs.motor_ps} PS${car.specs.motor_kw ? ` / ${car.specs.motor_kw} kW` : ''}`] : null,
  car.specs.torque_nm ? ['Max Torque', `${car.specs.torque_nm} N·m`] : null,
  car.specs.accel ? ['0–100 km/h', `${car.specs.accel} s`] : null,
  car.specs.top_speed ? ['Top Speed', `${car.specs.top_speed} km/h`] : null,
  car.specs.transmission ? ['Transmission', car.specs.transmission] : null,
  ['Drive Type', { FWD: 'Front-Wheel Drive', RWD: 'Rear-Wheel Drive', AWD: 'All-Wheel Drive', '4WD': 'Four-Wheel Drive' }[car.drive]],
  car.specs.battery_kwh ? ['Battery Capacity', `${car.specs.battery_kwh} kWh`] : null,
  car.specs.range_cltc ? ['Electric Range (CLTC)', `${car.specs.range_cltc} km`] : null,
  car.specs.range_wltp ? ['Electric Range (WLTP)', `${car.specs.range_wltp} km`] : null,
  ['Dimensions (L×W×H)', `${car.specs.dimensions} mm`],
  car.specs.wheelbase ? ['Wheelbase', `${car.specs.wheelbase} mm`] : null,
  car.specs.weight ? ['Curb Weight', `${car.specs.weight} kg`] : null,
  car.specs.tires ? ['Tires', car.specs.tires] : null,
  ['Seating', `${car.seats} seats`],
  ['Steering', rhdNote],
].filter(Boolean) as [string, string][];

const equipmentCols = [
  { title: 'Exterior', icon: 'car', items: car.features.exterior },
  { title: 'Interior & Comfort', icon: 'seats', items: car.features.interior },
  { title: 'Safety & Assistance', icon: 'shield', items: car.features.safety },
];

// --- Destination pricing --------------------------------------------------
const CERT_LABELS: Record<string, string> = {
  GCC: 'GCC — Gulf states',
  EAC: 'EAC — Russia & CIS',
  SASO: 'SASO — Saudi Arabia',
  INMETRO: 'INMETRO — Brazil',
};

// --- Export process timeline ----------------------------------------------
const processSteps = [
  { day: 'Day 0',   title: 'Inquiry & Quotation',    desc: 'Send model, quantity and destination. FOB / CIF quote with configuration options within 24 hours.' },
  { day: 'Day 1–3', title: 'PI & Deposit',           desc: 'Proforma invoice issued. 30% T/T deposit (or L/C at sight) locks stock and price.' },
  { day: `Day 3–${Math.max(car.lead_time_days - 5, 5)}`, title: 'Preparation & Inspection', desc: 'Vehicle prepared, PDI completed. You receive a photo & video inspection report before loading.' },
  { day: `Day ${Math.max(car.lead_time_days - 4, 6)}–${car.lead_time_days}`, title: 'Loading & Documents', desc: 'Balance payment, loading supervised. Full document set couriered: Invoice, Packing List, B/L, CO and certificates.' },
  { day: 'Transit', title: 'Shipping & Arrival',     desc: `${car.shipping_methods.join(' / ')} to your port. Tracking updates until arrival and destination clearance support.` },
];

// --- Shipping & documents ---------------------------------------------------
const shippingInfo = [
  { icon: 'ship',  label: 'Shipping Methods', value: car.shipping_methods.join(' / ') },
  { icon: 'cart',  label: 'Container Loading (40HQ)', value: `${unitsPerContainer} units floor-loaded per 40HQ container — RoRo usually more economical from 5+ units` },
  { icon: 'globe', label: 'Loading Ports', value: 'Shanghai · Ningbo · Shenzhen · Tianjin · Qingdao' },
  { icon: 'clock', label: 'Lead Time', value: `${car.lead_time_days} days after deposit confirmation` },
  { icon: 'check', label: 'Incoterms', value: 'FOB / CIF / CFR / EXW — DDP on request' },
];
const documentsInfo = [
  { icon: 'doc',   label: 'Documents Provided', value: 'Commercial Invoice, Packing List, Bill of Lading, Certificate of Origin, Export License, Certificate of Conformity' },
  { icon: 'card',  label: 'Payment Terms', value: car.payment_terms.join(' · ') },
  { icon: 'badge', label: 'Certifications', value: car.certifications.map(c => CERT_LABELS[c] ?? c).join(' · ') },
];

// --- Warranty & after-sales -------------------------------------------------
const afterSales = [
  { icon: 'shield', title: 'Factory Warranty', desc: '5-year / 100,000 km vehicle warranty honored via authorized partners.' },
  ...(isElectrified ? [{ icon: 'battery', title: 'Battery & Drivetrain', desc: '8-year / 160,000 km battery and drivetrain warranty on new-energy models.' }] : []),
  { icon: 'wrench', title: 'Spare Parts Supply', desc: 'Consolidated parts orders shipped with your vehicles or air-freighted separately.' },
  { icon: 'phone',  title: 'Technical Support', desc: 'Diagnostic guidance, service documentation and software support for your workshop.' },
];

// --- FAQ (all real per-car FAQs + standard B2B) -----------------------------
const standardFaqs = [
  { q: 'Is the listed price including shipping?', a: 'Listed prices are FOB China (vehicle + China-side export costs). CIF / CFR to your port is quoted separately — see the destination pricing table above for reference lanes.' },
  { q: 'Can I mix different models in one container?', a: 'Yes. A 40HQ container fits 1–2 SUVs or 2–3 sedans; mixed-model orders are welcome and common for dealer stock orders.' },
  { q: 'How do I verify the vehicle before shipment?', a: 'Every unit gets a pre-shipment inspection with a photo and video report sent to you before loading. Third-party inspection (SGS or similar) can be arranged at cost.' },
];
const allFaqs = [...car.faqs, ...standardFaqs];

// --- Related vehicles --------------------------------------------------------
const relatedCars = Object.values(cars)
  .filter(c => c.slug !== car.slug)
  .map(c => ({ c, score:
    (c.body_type === car.body_type ? 2 : 0) +
    (c.fuel_type === car.fuel_type ? 1 : 0) +
    (c.brand === car.brand ? 1 : 0) +
    (Math.abs(c.pricing.fob_min - car.pricing.fob_min) / car.pricing.fob_min < 0.35 ? 2 : 0)
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map(x => x.c);

// --- Gallery ------------------------------------------------------------------
const heroThumbs = (car.gallery?.appearance ?? []).slice(0, 5);
const galleryGroups = [
  { key: 'exterior', label: 'Exterior', imgs: car.gallery?.appearance ?? [] },
  { key: 'interior', label: 'Interior', imgs: [...(car.gallery?.console ?? []), ...(car.gallery?.space ?? [])] },
  { key: 'details',  label: 'Details',  imgs: car.gallery?.other ?? [] },
].filter(g => g.imgs.length > 0);
const totalPhotos = galleryGroups.reduce((n, g) => n + g.imgs.length, 0);

// --- Structured data -----------------------------------------------------------
const productSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: fullTitle,
  description: `${car.subtitle}. Wholesale export from China with ${car.certifications.join(', ')} certification.`,
  image: [car.hero_image, ...heroThumbs.map(t => t.src)].map(p => new URL(p, Astro.site).href),
  brand: { '@type': 'Brand', name: car.brand },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'USD',
    lowPrice: car.pricing.fob_min,
    highPrice: car.pricing.fob_max,
    offerCount: car.stock_units,
    availability: car.stock_status === 'In Stock' ? 'https://schema.org/InStock' : 'https://schema.org/PreOrder',
    seller: { '@type': 'Organization', '@id': 'https://evautopro.com/#organization', name: 'EV Auto Pro' },
  },
});
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://evautopro.com/' },
    { '@type': 'ListItem', position: 2, name: 'Cars', item: 'https://evautopro.com/cars/' },
    { '@type': 'ListItem', position: 3, name: fullTitle, item: new URL(`/cars/${car.slug}/`, Astro.site).href },
  ],
});
const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});

// --- Icons ----------------------------------------------------------------------
const ICON: Record<string, string> = {
  check:   'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  clock:   'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  ship:    'M3 17l3.5-1.5L12 17l5.5-1.5L21 17M5 17V9l7-4 7 4v8',
  doc:     'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v11a2 2 0 01-2 2z',
  card:    'M3 10h18M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z',
  badge:   'M9 12l2 2 4-4m5 2a9 9 0 11-18 0 9 9 0 0118 0z',
  globe:   'M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.5-3 4-6.5 4-9s-1.5-6-4-9c-2.5 3-4 6.5-4 9s1.5 6 4 9zM3 12h18',
  shield:  'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  phone:   'M3 5a2 2 0 012-2h2.28a2 2 0 011.94 1.515l.7 2.8a2 2 0 01-.45 1.95L8 11a14 14 0 005 5l1.735-1.47a2 2 0 011.95-.45l2.8.7A2 2 0 0121 16.72V19a2 2 0 01-2 2A16 16 0 013 5z',
  cart:    'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m12-9l2 9m-9-5h4',
  car:     'M5 17h14M5 17l-1-4 1-3h14l1 3-1 4M5 17v2a1 1 0 001 1h1a1 1 0 001-1v-2M16 17v2a1 1 0 001 1h1a1 1 0 001-1v-2M7 13h10',
  seats:   'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  wrench:  'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
  engine:  'M13 10V3L4 14h7v7l9-11h-7z',
  screen:  'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  download:'M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3',
  video:   'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z',
  battery: 'M21 10v4M3 8a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8zm4 2v4m4-4v4',
};

const WHATSAPP_SVG_PATH = 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z';
