        {/* Form right */}
        <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
          <h2 class="text-base lg:text-lg font-bold text-ink-900 mb-1">Get FOB / CIF Price for {car.brand} {car.model}</h2>
          <p class="text-xs text-ink-500 mb-4">Send us your requirements and we will reply within 12 hours.</p>
          <form id="car-inquiry-form" class="space-y-3" novalidate>
            <input type="text" name="honeypot" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true"/>
            <input type="hidden" name="model_interested" value={fullTitle}/>
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-[11px] font-medium text-ink-700 mb-1">Your Name <span class="text-brand-500">*</span></label>
