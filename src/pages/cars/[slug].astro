---

<BaseLayout
  title={`${fullTitle} — Wholesale Export Price & Specs | EV Auto Pro`}
  description={`Buy ${fullTitle} direct from an authorized China exporter. FOB from $${car.pricing.fob_min.toLocaleString()}, CIF quotes for ${car.supported_markets.slice(0, 3).join(', ')}. ${car.stock_units} units in stock, ${car.lead_time_days}-day dispatch, MOQ ${car.moq}.`}
  ogImage={car.hero_image}
>
  <script slot="head" type="application/ld+json" set:html={productSchema} />
  <script slot="head" type="application/ld+json" set:html={faqSchema} />
  <script slot="head" type="application/ld+json" set:html={breadcrumbSchema} />

  <div class="bg-ink-50 min-h-screen pb-20 lg:pb-0">

  {/* BREADCRUMB */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-5 pb-3">
    <nav class="text-xs text-ink-500">
      <a href="/" class="hover:text-brand-500">Home</a>
      <span class="mx-2 text-ink-300">›</span>
      <a href="/cars/" class="hover:text-brand-500">Vehicles</a>
      <span class="mx-2 text-ink-300">›</span>
      <a href={`/brands/${car.brand_slug}/`} class="hover:text-brand-500">{car.brand}</a>
      <span class="mx-2 text-ink-300">›</span>
      <span class="text-ink-900 font-medium">{car.model}</span>
    </nav>
  </div>

  {/* ====================================================================
       SECTION 1 — HERO: gallery + core offer + quick export card
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <div class="grid lg:grid-cols-12 gap-6 lg:gap-8">

          {/* Gallery column */}
          <div class="lg:col-span-5">
            <div class="relative aspect-[4/3] rounded-lg overflow-hidden bg-ink-100 mb-2.5">
              <img id="hero-main-img" src={car.hero_image} alt={fullTitle} class="w-full h-full object-cover" loading="eager"/>
              {totalPhotos > 0 && (
                <a href="#gallery" class="absolute bottom-3 right-3 px-2.5 py-1 bg-ink-900/80 hover:bg-ink-900 rounded-md text-[11px] font-medium text-white transition-colors">
                  {totalPhotos} photos ↓
                </a>
              )}
            </div>
            {heroThumbs.length > 1 && (
              <div class="grid grid-cols-5 gap-1.5">
                {heroThumbs.map((t, i) => (
                  <button data-hero-thumb={t.src} aria-label={`View photo ${i + 1}`}
                    class={`hero-thumb aspect-[4/3] rounded-md overflow-hidden border-2 ${i === 0 ? 'border-brand-500' : 'border-ink-200'} bg-ink-100 cursor-pointer`}>
                    <img src={t.src} alt={t.alt ?? `${car.model} view ${i + 1}`} class="w-full h-full object-cover pointer-events-none" loading="lazy"/>
                  </button>
                ))}
              </div>
            )}
            {/* TODO(customer): add a 30–60s walkaround video here — video sells
                vehicles 3-4x better than photos for remote B2B buyers */}
          </div>

          {/* Offer column */}
          <div class="lg:col-span-4">
            <h1 class="text-2xl lg:text-[28px] font-bold text-ink-900 leading-tight mb-1.5">{fullTitle}</h1>
            <p class="text-sm text-ink-500 mb-4">{car.subtitle}</p>

            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-emerald-50 text-emerald-700 text-[11px] font-semibold rounded">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                {car.stock_status === 'In Stock' ? `In Stock · ${car.stock_units} units` : car.stock_status}
              </span>
              {car.certifications.map(c => (
                <span class="px-2.5 py-1 border border-ink-300 text-ink-700 text-[11px] font-semibold rounded">{c} Certified</span>
              ))}
            </div>

            <div class="mb-1">
              <span class="text-3xl lg:text-[34px] font-bold text-brand-500 tabular-nums">US${car.pricing.fob_min.toLocaleString()}</span>
              <span class="text-lg text-ink-400 font-semibold">– ${car.pricing.fob_max.toLocaleString()}</span>
              <span class="text-sm text-ink-500 ml-2">FOB China</span>
            </div>
            <p class="text-xs text-ink-500 mb-4">Range covers trim levels. Volume pricing from 5+ units — final quote within 24h.</p>

            {/* Key stat chips */}
            <div class="flex flex-wrap gap-2 mb-6">
              {heroStats.map(s => (
                <div class="px-3 py-1.5 bg-ink-50 rounded-md">
                  <div class="text-[10px] uppercase tracking-wider text-ink-500 font-semibold">{s.label}</div>
                  <div class="text-sm font-bold text-ink-900 tabular-nums">{s.value}</div>
                </div>
              ))}
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
              <a href="#inquiry-form" class="flex-1 inline-flex items-center justify-center px-5 py-2.5 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-md transition-colors">Get FOB / CIF Quote</a>
              <a href={waLink(`Hi, I'm interested in the ${fullTitle} for export. Please send price and availability.`)} target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-white border border-ink-300 hover:border-emerald-500 text-ink-900 text-sm font-semibold rounded-md transition-colors">
                <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d={WHATSAPP_SVG_PATH}/></svg>
                WhatsApp Us
              </a>
            </div>
            <button type="button" data-brochure-open class="inline-flex items-center gap-1.5 mt-3 text-xs font-semibold text-brand-500 hover:text-brand-600 cursor-pointer">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON.download}/></svg>
              Download {car.model} brochure (PDF, specs + export pricing)
            </button>
            <p class="text-[11px] text-ink-500 mt-2">✓ Reply within 24 hours &nbsp;·&nbsp; ✓ Video walkaround of your actual units before shipment</p>
          </div>

          {/* Quick Export card */}
          <div class="lg:col-span-3">
            <div class="bg-ink-50 rounded-lg p-5">
              <div class="text-sm font-bold text-ink-900 mb-4">Quick Export Facts</div>
              <div class="space-y-3.5">
                {quickInfo.map(item => (
                  <div class="flex items-start gap-3">
                    <div class="flex-shrink-0 w-9 h-9 rounded-md bg-white border border-ink-200 flex items-center justify-center text-brand-500">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[item.icon]}/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-[10px] uppercase tracking-wider text-ink-500 font-semibold mb-0.5">{item.label}</div>
                      <div class="text-xs text-ink-900 font-medium leading-snug">{item.value}</div>
                    </div>
                  </div>
                ))}
              </div>
              <p class="text-[10px] text-ink-500 mt-4 pt-3 border-t border-ink-200">Stock & pricing last updated {buildDate}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 2 — Trust bar
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 px-5 lg:px-8 py-5">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
          {trustItems.map(t => (
            <div class="flex items-center gap-3">
              <div class="flex-shrink-0 w-10 h-10 rounded-md bg-brand-50 flex items-center justify-center text-brand-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[t.icon]}/></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-ink-900 leading-tight">{t.title}</div>
                <div class="text-xs text-ink-500 mt-0.5">{t.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 3 — Why this vehicle (selling points)
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <h2 class="text-base lg:text-lg font-bold text-ink-900 mb-1">Why Dealers Choose the {car.model}</h2>
        <p class="text-xs text-ink-500 mb-5">What makes this model move in {car.supported_markets.slice(0, 3).join(', ')} and beyond.</p>
        <div class="grid md:grid-cols-3 gap-5">
          {highlights.map((h, i) => (
            <div class="relative bg-ink-50 rounded-lg p-5">
              <div class="text-[28px] font-bold text-brand-500/20 absolute top-3 right-4 tabular-nums">{`0${i + 1}`}</div>
              <div class="text-sm font-bold text-ink-900 mb-2 pr-8">{h.title}</div>
              <div class="text-xs text-ink-600 leading-relaxed">{h.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 4 — Full specifications + equipment checklist
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <div class="flex flex-wrap items-center justify-between gap-2 mb-4">
          <h2 class="text-base lg:text-lg font-bold text-ink-900">Technical Specifications</h2>
          <a href="#inquiry-form" class="text-xs font-semibold text-brand-500 hover:text-brand-600">Request full configuration sheet →</a>
        </div>

        <div class="grid sm:grid-cols-2 gap-x-10 gap-y-0 mb-8">
          {specRows.map(([label, val]) => (
            <div class="flex items-center justify-between py-3 border-b border-ink-100">
              <span class="text-xs text-ink-500 font-medium">{label}</span>
              <span class="text-sm text-ink-900 font-semibold text-right tabular-nums">{val}</span>
            </div>
          ))}
        </div>

        <h3 class="text-sm font-bold text-ink-900 mb-4">Standard & Available Equipment</h3>
        <div class="grid md:grid-cols-3 gap-6">
          {equipmentCols.map(col => (
            <div>
              <div class="flex items-center gap-2 mb-3">
                <div class="w-7 h-7 rounded-md bg-brand-50 flex items-center justify-center text-brand-500">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[col.icon]}/></svg>
                </div>
                <div class="text-xs font-bold text-ink-900 uppercase tracking-wider">{col.title}</div>
              </div>
              <ul class="space-y-2">
                {col.items.map(item => (
                  <li class="flex items-start gap-2 text-xs text-ink-700">
                    <svg class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <p class="text-[11px] text-ink-500 mt-6 pt-4 border-t border-ink-100">
          Multiple factory trim levels and colors are available for the {car.model}. Equipment varies by trim and production batch —
          <a href="#inquiry-form" class="text-brand-500 hover:underline font-medium">request the current configuration & color sheet</a> for your target market.
        </p>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 5 — Destination pricing (FOB / CIF)
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <h2 class="text-base lg:text-lg font-bold text-ink-900 mb-1">Export Pricing by Destination</h2>
        <p class="text-xs text-ink-500 mb-5">Reference ranges across trim levels — final quote depends on configuration, quantity and current freight rates.</p>

        <div class="overflow-x-auto -mx-5 px-5 lg:mx-0 lg:px-0">
          <table class="w-full min-w-[560px] text-sm">
            <thead>
              <tr class="border-b-2 border-ink-200">
                <th class="text-left py-2.5 pr-4 text-xs font-bold text-ink-500 uppercase tracking-wider">Incoterm / Destination</th>
                <th class="text-right py-2.5 pl-4 text-xs font-bold text-ink-500 uppercase tracking-wider">Price Range (USD)</th>
                <th class="text-right py-2.5 pl-4 text-xs font-bold text-ink-500 uppercase tracking-wider hidden sm:table-cell">Note</th>
              </tr>
            </thead>
            <tbody>
              {car.pricing.exw_min && (
                <tr class="border-b border-ink-100">
                  <td class="py-3 pr-4 font-semibold text-ink-900">EXW China</td>
                  <td class="py-3 pl-4 text-right font-bold text-ink-900 tabular-nums">${car.pricing.exw_min.toLocaleString()} – ${car.pricing.exw_max?.toLocaleString()}</td>
                  <td class="py-3 pl-4 text-right text-xs text-ink-500 hidden sm:table-cell">Ex-works, buyer arranges export</td>
                </tr>
              )}
              <tr class="border-b border-ink-100 bg-brand-50/40">
                <td class="py-3 pr-4 font-semibold text-ink-900">FOB China <span class="ml-1 px-1.5 py-0.5 bg-brand-500 text-white text-[10px] font-bold rounded">BASE</span></td>
                <td class="py-3 pl-4 text-right font-bold text-brand-500 tabular-nums">${car.pricing.fob_min.toLocaleString()} – ${car.pricing.fob_max.toLocaleString()}</td>
                <td class="py-3 pl-4 text-right text-xs text-ink-500 hidden sm:table-cell">Incl. China customs & loading</td>
              </tr>
              {car.pricing.cif.map(row => (
                <tr class="border-b border-ink-100">
                  <td class="py-3 pr-4 text-ink-700">CIF {row.country}</td>
                  <td class="py-3 pl-4 text-right font-semibold text-ink-900 tabular-nums">${row.min.toLocaleString()} – ${row.max.toLocaleString()}</td>
                  <td class="py-3 pl-4 text-right text-xs text-ink-500 hidden sm:table-cell">Incl. freight & insurance</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mt-5 pt-4 border-t border-ink-100">
          <p class="text-xs text-ink-600">Your port not listed? We ship to 60+ countries — send your destination for a same-day CIF calculation.</p>
          <a href="#inquiry-form" class="inline-flex items-center px-4 py-2 bg-brand-500 hover:bg-brand-600 text-white text-xs font-semibold rounded-md transition-colors whitespace-nowrap">Get CIF for My Port</a>
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 6 — Photo gallery
       ==================================================================== */}
  {galleryGroups.length > 0 && (
    <section class="pb-6" id="gallery">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
          <h2 class="text-base lg:text-lg font-bold text-ink-900 mb-3">Photo Gallery <span class="text-ink-400 font-medium text-sm">({totalPhotos})</span></h2>
          <div class="flex gap-5 mb-4 border-b border-ink-200">
            {galleryGroups.map((g, i) => (
              <button data-gallery-tab={g.key}
                class={`pb-2 text-sm font-medium transition-colors ${i === 0 ? 'text-brand-500 border-b-2 border-brand-500 -mb-px' : 'text-ink-500 hover:text-ink-900'}`}>
                {g.label} ({g.imgs.length})
              </button>
            ))}
          </div>
          {galleryGroups.map((g, i) => (
            <div data-gallery-panel={g.key} class={i === 0 ? '' : 'hidden'}>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                {g.imgs.map(img => (
                  <div class="aspect-[4/3] rounded-lg overflow-hidden bg-ink-100">
                    <img src={img.src} alt={img.alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy"/>
                  </div>
                ))}
              </div>
            </div>
          ))}
          <p class="text-[11px] text-ink-500 mt-4">Need photos of a specific color or trim? We send live warehouse photos and video of your actual units before shipment.</p>
        </div>
      </div>
    </section>
  )}

  {/* ====================================================================
       SECTION 6b — EV Auto Pro Export PDI (named inspection program)
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <div class="flex flex-wrap items-center gap-3 mb-1">
          <h2 class="text-base lg:text-lg font-bold text-ink-900">EV Auto Pro Export PDI</h2>
          <span class="px-2 py-0.5 bg-brand-500 text-white text-[10px] font-bold rounded uppercase tracking-wider">Every unit, before loading</span>
        </div>
        <p class="text-xs text-ink-500 mb-5">
          Our six-area pre-delivery inspection runs on your actual units — not showroom samples. You receive the
          full photo set and a video walkaround before the container seals, so what arrives is what you approved.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-5">
          {pdiChecks.map(c => (
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-9 h-9 rounded-md bg-brand-50 flex items-center justify-center text-brand-500">
                <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[c.icon]}/></svg>
              </div>
              <div>
                <div class="text-xs font-bold text-ink-900 leading-tight mb-0.5">{c.title}</div>
                <div class="text-[11px] text-ink-500 leading-snug">{c.desc}</div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-[11px] text-ink-500 mt-5 pt-4 border-t border-ink-100">
          Independent third-party inspection (SGS or equivalent) can be arranged in addition, at cost.
        </p>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 7 — Export process timeline
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <h2 class="text-base lg:text-lg font-bold text-ink-900 mb-1">From Inquiry to Your Port</h2>
        <p class="text-xs text-ink-500 mb-6">Typical timeline for the {car.model} at current stock levels.</p>
        <div class="grid md:grid-cols-5 gap-5">
          {processSteps.map((s, i) => (
            <div class="relative">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-7 h-7 rounded-full bg-brand-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">{i + 1}</div>
                {i < processSteps.length - 1 && <div class="hidden md:block flex-1 h-px bg-ink-200"></div>}
              </div>
              <div class="text-[10px] uppercase tracking-wider text-brand-500 font-bold mb-1">{s.day}</div>
              <div class="text-sm font-bold text-ink-900 mb-1.5">{s.title}</div>
              <div class="text-xs text-ink-600 leading-relaxed">{s.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ====================================================================
       SECTION 8 — Shipping & documents
       ==================================================================== */}
  <section class="pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl border border-ink-200 p-5 lg:p-6">
        <h2 class="text-base lg:text-lg font-bold text-ink-900 mb-5">Shipping, Documents & Payment</h2>
        <div class="grid md:grid-cols-2 gap-x-10 gap-y-5">
          <div class="space-y-4">
            {shippingInfo.map(item => (
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-8 h-8 rounded-md bg-brand-50 flex items-center justify-center text-brand-500 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[item.icon]}/></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-bold text-ink-900 mb-0.5">{item.label}</div>
                  <div class="text-xs text-ink-600 leading-relaxed">{item.value}</div>
                </div>
              </div>
            ))}
          </div>
          <div class="space-y-4">
            {documentsInfo.map(item => (
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-8 h-8 rounded-md bg-brand-50 flex items-center justify-center text-brand-500 mt-0.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={ICON[item.icon]}/></svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm font-bold text-ink-900 mb-0.5">{item.label}</div>
                  <div class="text-xs text-ink-600 leading-relaxed">{item.value}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Container loading diagram — drawn to scale from real vehicle length */}
        <div class="mt-6 pt-5 border-t border-ink-100">
          <div class="flex flex-wrap items-baseline justify-between gap-2 mb-3">
            <h3 class="text-sm font-bold text-ink-900">40HQ Container Loading — {car.brand} {car.model}</h3>
            <span class="text-[11px] text-ink-500">Drawn to scale · vehicle {(vehicleLength / 1000).toFixed(2)} m · container interior 12.03 m</span>
          </div>
          <svg viewBox="0 0 640 150" class="w-full max-w-3xl" role="img" aria-label={`${unitsPerContainer} ${car.model} units floor-loaded in a 40HQ container, drawn to scale`}>
            {/* dimension arrow: container interior */}
            <line x1={DIAG.x0} y1="20" x2={DIAG.x0 + DIAG.innerW} y2="20" stroke="#a1a1aa" stroke-width="1"/>
            <line x1={DIAG.x0} y1="14" x2={DIAG.x0} y2="26" stroke="#a1a1aa" stroke-width="1"/>
            <line x1={DIAG.x0 + DIAG.innerW} y1="14" x2={DIAG.x0 + DIAG.innerW} y2="26" stroke="#a1a1aa" stroke-width="1"/>
            <text x={DIAG.x0 + DIAG.innerW / 2} y="16" text-anchor="middle" font-size="10" fill="#71717a" font-family="sans-serif">12.03 m usable interior</text>

            {/* container body */}
            <rect x={DIAG.x0} y={DIAG.boxTop} width={DIAG.innerW} height={DIAG.boxH} fill="#fafafa" stroke="#18181b" stroke-width="2"/>
            {Array.from({ length: 13 }, (_, i) => (
              <line x1={DIAG.x0 + (i + 1) * (DIAG.innerW / 14)} y1={DIAG.boxTop} x2={DIAG.x0 + (i + 1) * (DIAG.innerW / 14)} y2={DIAG.boxTop + 6} stroke="#e4e4e7" stroke-width="1"/>
            ))}
            {/* container door (right end) */}
            <rect x={DIAG.x0 + DIAG.innerW} y={DIAG.boxTop} width="7" height={DIAG.boxH} fill="#18181b"/>

            {/* vehicles, to scale */}
            {DIAG.cars.map(c => (
