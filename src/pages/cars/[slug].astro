  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'Vehicle',
    name: fullTitle,
    brand: { '@type': 'Brand', name: car.brand },
    model: car.model, modelDate: car.year,
    bodyType: car.body_type, fuelType: car.fuel_type,
    driveWheelConfiguration: car.drive, seatingCapacity: car.seats,
    offers: {
      '@type': 'AggregateOffer', priceCurrency: 'USD',
      lowPrice: car.pricing.fob_min, highPrice: car.pricing.fob_max,
