                       class="w-full px-3 py-2 border border-ink-200 focus:border-brand-500 focus:outline-none rounded-md text-sm placeholder:text-ink-400"/>
              </div>
              <div>
                <label class="block text-[11px] font-medium text-ink-700 mb-1">Country / Region <span class="text-brand-500">*</span></label>
                <select name="country" required class="w-full px-3 py-2 border border-ink-200 focus:border-brand-500 focus:outline-none rounded-md text-sm bg-white text-ink-700">
                  <option value="">Select your destination</option>
                  {car.supported_markets.map(m => <option value={m}>{m}</option>)}
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label class="block text-[11px] font-medium text-ink-700 mb-1">Email / WhatsApp <span class="text-brand-500">*</span></label>
                <input type="text" name="contact" required placeholder="Enter email or WhatsApp"
                       class="w-full px-3 py-2 border border-ink-200 focus:border-brand-500 focus:outline-none rounded-md text-sm placeholder:text-ink-400"/>
              </div>
              <div>
                <label class="block text-[11px] font-medium text-ink-700 mb-1">Model & Version</label>
                <input type="text" name="trim" placeholder={`e.g. ${car.year} ${car.brand} ${car.model} ${versions[0].name}`}
                       class="w-full px-3 py-2 border border-ink-200 focus:border-brand-500 focus:outline-none rounded-md text-sm placeholder:text-ink-400"/>
              </div>
            </div>
            <div>
              <label class="block text-[11px] font-medium text-ink-700 mb-1">Message</label>
              <textarea name="message" rows="3" placeholder="Tell us more about your request..."
                        class="w-full px-3 py-2 border border-ink-200 focus:border-brand-500 focus:outline-none rounded-md text-sm placeholder:text-ink-400 resize-none"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-3 pt-1">
              <button type="submit" class="px-4 py-2.5 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-md transition-colors">Send Inquiry Now</button>
              <a href={`https://wa.me/8613800000000?text=Hi, I'm interested in ${car.brand} ${car.model}.`} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-1.5 px-4 py-2.5 bg-white border border-ink-300 hover:border-emerald-500 text-ink-900 text-sm font-semibold rounded-md transition-colors">
                <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                WhatsApp Us
              </a>
            </div>
            <p class="text-[10px] text-ink-500 text-center pt-1">We respect your privacy. Your information will not be shared.</p>
            <p id="car-inquiry-status" class="hidden text-sm text-center" role="status"></p>
          </form>
          <script>
            const carForm = document.getElementById('car-inquiry-form') as HTMLFormElement | null;
            const carStatus = document.getElementById('car-inquiry-status');
            carForm?.addEventListener('submit', async (e) => {
              e.preventDefault();
              if (!carStatus) return;
              if (!carForm.reportValidity()) return;
              carStatus.classList.remove('hidden', 'text-green-600', 'text-red-600');
              carStatus.classList.add('text-ink-500');
              carStatus.textContent = 'Sending…';
              try {
                const res = await fetch('/api/inquiry', { method: 'POST', body: new FormData(carForm) });
                const json = await res.json();
                if (res.ok) {
                  carStatus.classList.add('text-green-600');
                  carStatus.textContent = '✓ ' + (json.message ?? 'Thank you! Our team will reply within 24 hours.');
                  carForm.reset();
                } else {
                  carStatus.classList.add('text-red-600');
                  carStatus.textContent = '⚠ ' + (json.error ?? 'Something went wrong. Please try again.');
                }
              } catch {
                carStatus.classList.add('text-red-600');
                carStatus.textContent = '⚠ Network error. Please email us directly at cai@evautopro.com';
              }
            });
          </script>
        </div>
      </div>
    </div>
