---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cars, type Car } from '../../data/cars';

export function getStaticPaths() {
  return Object.values(cars).map(car => ({
    params: { slug: car.slug },
    props: { car },
  }));
}

interface Props { car: Car; }
const { car } = Astro.props;
const fullTitle = `${car.year} ${car.brand} ${car.model} — Wholesale Export from China`;
---

<BaseLayout
  title={fullTitle}
  description={`Buy ${car.year} ${car.brand} ${car.model} direct from authorized China exporter. FOB Shanghai from $${car.pricing.fob_min.toLocaleString()}. ${car.stock_units} units in stock. Ships to Russia, UAE, Kazakhstan. MOQ ${car.moq}.`}
>
  {/* H1 + Breadcrumb */}
  <section class="bg-ink-50 border-b border-ink-200 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs text-ink-500 mb-3">
        <a href="/" class="hover:text-brand-500">Home</a> ·
        <a href="/cars/" class="hover:text-brand-500">Cars</a> ·
        <a href={`/brands/${car.brand_slug}/`} class="hover:text-brand-500">{car.brand}</a> ·
        <span class="text-ink-900">{car.model}</span>
      </nav>
      <h1 class="text-3xl lg:text-4xl font-bold text-ink-900">{fullTitle}</h1>
      <p class="text-base text-ink-600 mt-2">{car.subtitle}</p>
    </div>
  </section>

  {/* Hero + Quick Specs */}
  <section class="py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10">
        <div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-ink-200 mb-3">
            <img src={car.hero_image} alt={`${car.year} ${car.brand} ${car.model}`} class="w-full h-full object-cover" />
          </div>
          <div class="grid grid-cols-4 gap-2">
            {[1,2,3,4].map(i => (
              <div class="aspect-square bg-ink-100 rounded-lg overflow-hidden">
                <img src={car.hero_image} alt={`view ${i}`} class="w-full h-full object-cover" loading="lazy" />
              </div>
            ))}
          </div>
        </div>

        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="px-2 py-0.5 bg-ink-100 text-ink-700 text-xs rounded">{car.body_type}</span>
            <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{car.fuel_type}</span>
            <span class="px-2 py-0.5 bg-green-50 text-green-700 text-xs rounded">★ Authorized Dealer</span>
          </div>

          <div class="border-t border-b border-ink-200 py-6 my-6">
            <div class="text-xs text-ink-500 mb-1">FOB Shanghai · USD</div>
            <div class="text-4xl font-bold text-ink-900">${car.pricing.fob_min.toLocaleString()} – ${car.pricing.fob_max.toLocaleString()}</div>
            <div class="text-sm text-ink-500 mt-2">Per unit · Container shipment</div>
          </div>

          <dl class="grid grid-cols-2 gap-4 text-sm mb-6">
            <div><dt class="text-ink-500 text-xs">Year</dt><dd class="font-semibold text-ink-900">{car.year}</dd></div>
            <div><dt class="text-ink-500 text-xs">Body</dt><dd class="font-semibold text-ink-900">{car.body_type}</dd></div>
            <div><dt class="text-ink-500 text-xs">Drive</dt><dd class="font-semibold text-ink-900">{car.drive}</dd></div>
            <div><dt class="text-ink-500 text-xs">Seats</dt><dd class="font-semibold text-ink-900">{car.seats}</dd></div>
            <div><dt class="text-ink-500 text-xs">Stock</dt><dd class="font-semibold text-ink-900">{car.stock_units} units</dd></div>
            <div><dt class="text-ink-500 text-xs">Lead time</dt><dd class="font-semibold text-ink-900">{car.lead_time_days} days</dd></div>
            <div><dt class="text-ink-500 text-xs">MOQ</dt><dd class="font-semibold text-ink-900">{car.moq} unit</dd></div>
            <div><dt class="text-ink-500 text-xs">Fuel</dt><dd class="font-semibold text-ink-900">{car.fuel_type}</dd></div>
          </dl>

          <div class="flex flex-wrap gap-2">
            <a href={`/contact/quote/?model=${car.slug}`} class="btn-primary">Get Best Price</a>
            <a href={`https://wa.me/8613800000000?text=Hi, I'm interested in ${car.brand} ${car.model} for export`} class="btn-secondary">WhatsApp Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Description */}
  <section class="py-12 bg-ink-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-ink-900 mb-4">About the {car.year} {car.brand} {car.model}</h2>
      <p class="text-base text-ink-700 leading-relaxed mb-4">
        EV Auto Pro is an <a href={`/brands/${car.brand_slug}/`} class="text-brand-500 underline">authorized {car.brand} exporter</a>. We currently have <strong>{car.stock_units} units in stock</strong> at our Shanghai bonded warehouse with delivery within <strong>{car.lead_time_days} days</strong> via {car.shipping_methods.join(', ')}.
      </p>
      <p class="text-base text-ink-700 leading-relaxed">
        {car.subtitle}. Best-suited for dealer markets in {car.supported_markets.join(', ')}.
      </p>
    </div>
  </section>

  {/* Specifications */}
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-ink-900 mb-6">Key Specifications</h2>
      <div class="grid sm:grid-cols-2 gap-x-12 gap-y-3 text-sm">
        <dl class="contents">
          {car.specs.motor_ps && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Max Power</dt><dd class="font-semibold text-ink-900">{car.specs.motor_ps} PS</dd></>}
          {car.specs.torque_nm && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Max Torque</dt><dd class="font-semibold text-ink-900">{car.specs.torque_nm} Nm</dd></>}
          {car.specs.battery_kwh && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Battery</dt><dd class="font-semibold text-ink-900">{car.specs.battery_kwh} kWh</dd></>}
          {car.specs.range_wltp && <><dt class="text-ink-500 col-span-2 sm:col-span-1">WLTP Range</dt><dd class="font-semibold text-ink-900">{car.specs.range_wltp} km</dd></>}
          {car.specs.range_cltc && <><dt class="text-ink-500 col-span-2 sm:col-span-1">CLTC Range</dt><dd class="font-semibold text-ink-900">{car.specs.range_cltc} km</dd></>}
          {car.specs.top_speed && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Top Speed</dt><dd class="font-semibold text-ink-900">{car.specs.top_speed} km/h</dd></>}
          {car.specs.accel && <><dt class="text-ink-500 col-span-2 sm:col-span-1">0–100 km/h</dt><dd class="font-semibold text-ink-900">{car.specs.accel} sec</dd></>}
          {car.specs.transmission && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Transmission</dt><dd class="font-semibold text-ink-900">{car.specs.transmission}</dd></>}
          <dt class="text-ink-500 col-span-2 sm:col-span-1">Dimensions (L×W×H)</dt><dd class="font-semibold text-ink-900">{car.specs.dimensions} mm</dd>
          {car.specs.wheelbase && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Wheelbase</dt><dd class="font-semibold text-ink-900">{car.specs.wheelbase} mm</dd></>}
          {car.specs.weight && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Curb Weight</dt><dd class="font-semibold text-ink-900">{car.specs.weight} kg</dd></>}
          {car.specs.tires && <><dt class="text-ink-500 col-span-2 sm:col-span-1">Tires</dt><dd class="font-semibold text-ink-900">{car.specs.tires}</dd></>}
        </dl>
      </div>
    </div>
  </section>

  {/* Features */}
  <section class="py-12 bg-ink-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-ink-900 mb-6">Features & Configuration</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {Object.entries(car.features).map(([cat, items]) => (
          <div class="bg-white border border-ink-200 rounded-xl p-5">
            <h3 class="font-semibold text-sm text-brand-500 uppercase tracking-wider mb-3">{cat}</h3>
            <ul class="space-y-2">
              {items.map(item => (
                <li class="flex items-start gap-2 text-sm text-ink-700">
                  <span class="text-brand-500 mt-0.5">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Pricing & Trade Terms */}
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-ink-900 mb-6">Pricing & Trade Terms</h2>

      <h3 class="font-semibold text-base text-ink-900 mb-3">FOB Shanghai (USD per unit)</h3>
      <div class="bg-white border border-ink-200 rounded-xl p-5 mb-6">
        <div class="text-3xl font-bold text-ink-900">${car.pricing.fob_min.toLocaleString()} – ${car.pricing.fob_max.toLocaleString()}</div>
        <div class="text-sm text-ink-500 mt-1">Container shipment · MOQ {car.moq}</div>
      </div>

      <h3 class="font-semibold text-base text-ink-900 mb-3">CIF to Major Markets</h3>
      <div class="bg-white border border-ink-200 rounded-xl overflow-hidden mb-6">
        <table class="w-full text-sm">
          <thead class="bg-ink-50 text-ink-500 text-xs uppercase">
            <tr><th class="text-left px-4 py-3">Destination</th><th class="text-right px-4 py-3">USD</th></tr>
          </thead>
          <tbody>
            {car.pricing.cif.map(c => (
              <tr class="border-t border-ink-200"><td class="px-4 py-3 text-ink-900">{c.country}</td><td class="px-4 py-3 text-right font-semibold text-ink-900">${c.min.toLocaleString()} – ${c.max.toLocaleString()}</td></tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="font-semibold text-base text-ink-900 mb-3">Payment Terms</h3>
      <div class="flex flex-wrap gap-2">
        {car.payment_terms.map(p => (
          <span class="px-3 py-1 bg-ink-100 text-ink-700 text-sm rounded-full">{p}</span>
        ))}
      </div>
    </div>
  </section>

  {/* Export Services */}
  <section class="py-12 bg-ink-900">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-6">Export Services Included</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-ink-800 rounded-xl p-5"><div class="text-brand-500 text-2xl mb-2">🔍</div><h3 class="font-semibold text-white text-sm mb-1">Third-Party Inspection</h3><p class="text-xs text-ink-400">Multi-point QC before container loading</p></div>
        <div class="bg-ink-800 rounded-xl p-5"><div class="text-brand-500 text-2xl mb-2">📋</div><h3 class="font-semibold text-white text-sm mb-1">Export License</h3><p class="text-xs text-ink-400">MoFCOM full document package</p></div>
        <div class="bg-ink-800 rounded-xl p-5"><div class="text-brand-500 text-2xl mb-2">🚢</div><h3 class="font-semibold text-white text-sm mb-1">Door-to-Port Logistics</h3><p class="text-xs text-ink-400">{car.shipping_methods.join(' / ')}</p></div>
        <div class="bg-ink-800 rounded-xl p-5"><div class="text-brand-500 text-2xl mb-2">🛠</div><h3 class="font-semibold text-white text-sm mb-1">After-Sales Parts</h3><p class="text-xs text-ink-400">Moscow / Almaty / Dubai depots</p></div>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-ink-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {car.faqs.map(f => (
          <details class="group bg-white border border-ink-200 rounded-xl p-5 hover:border-brand-500 transition-colors">
            <summary class="flex items-center justify-between cursor-pointer font-semibold text-sm text-ink-900">
              <span>{f.q}</span>
              <svg class="w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 text-sm text-ink-600 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* Bottom Brand-Red CTA */}
  <section class="py-16 bg-brand-500">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Ready to import the {car.model}?</h2>
      <p class="text-base text-white/90 mb-6">Get FOB + CIF quote within 24 hours. {car.stock_units} units in stock now.</p>
      <a href={`/contact/quote/?model=${car.slug}`} class="inline-flex items-center px-8 py-3 bg-white hover:bg-ink-100 text-brand-500 font-semibold rounded-lg transition-colors">
        Request a Quote
      </a>
    </div>
  </section>

  {/* Vehicle Schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'Vehicle',
    name: fullTitle,
    brand: { '@type': 'Brand', name: car.brand },
    model: car.model, modelDate: car.year,
    bodyType: car.body_type, fuelType: car.fuel_type,
    driveWheelConfiguration: car.drive, seatingCapacity: car.seats,
    offers: {
      '@type': 'AggregateOffer', priceCurrency: 'USD',
      lowPrice: car.pricing.fob_min, highPrice: car.pricing.fob_max,
      availability: 'https://schema.org/InStock',
      seller: { '@type': 'Organization', name: 'EV Auto Pro', url: 'https://evautopro.com' },
    },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: car.faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  })} />
</BaseLayout>
