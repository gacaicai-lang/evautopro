    <a href={waLink(`Hi, I'm interested in the ${fullTitle}.`)} target="_blank" rel="noopener" aria-label="WhatsApp" class="flex-shrink-0 w-10 h-10 flex items-center justify-center border border-ink-300 rounded-md">
