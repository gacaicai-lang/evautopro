---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cars as carsData } from '../../data/cars';

// 单一事实源：从 cars.ts 派生，只渲染有详情页的车型（避免死链）
const cars = Object.values(carsData).map(c => ({
  slug:        c.slug,
  brand:       c.brand,
  name:        c.model,
  body:        c.body_type,
  fuel:        c.fuel_type,
  price_min:   c.pricing.fob_min,
  price_max:   c.pricing.fob_max,
  moq:         c.moq,
  stock:       c.stock_units,
  authorized:  true,
  hero_image:  c.hero_image,
}));

// Filters
const bodyTypes = [...new Set(cars.map(c => c.body))].sort();
const fuelTypes = [...new Set(cars.map(c => c.fuel))].sort();
const brands = [...new Set(cars.map(c => c.brand))].sort();
---

<BaseLayout
  title="All Cars for Export from China | EV Auto Pro"
  description="Browse 50+ Chinese new energy and ICE vehicles available for export. Filter by body type, fuel, brand. Direct FOB pricing, MOQ 1."
>
  <section class="bg-ink-50 border-b border-ink-200 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs text-ink-500 mb-3">
        <a href="/" class="hover:text-brand-500">Home</a>
        <span class="mx-1">·</span>
        <span class="text-ink-900 font-medium">All Cars</span>
      </nav>
      <h1 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-3">All Cars for Export</h1>
      <p class="text-base text-ink-600 max-w-2xl">
        {cars.length} models available. FOB from $11,500 · MOQ 1-5 units · Lead time 3-30 days · RoRo / Container / Block Train / Truck.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[240px_1fr] gap-8">
        {/* Sidebar filters */}
        <aside class="space-y-6">
          <div>
            <h3 class="font-semibold text-sm text-ink-900 mb-3 uppercase tracking-wider">Body Type</h3>
            <ul class="space-y-1">
              {bodyTypes.map(b => (
                <li><a href={`/cars/?body=${b}`} class="text-sm text-ink-600 hover:text-brand-500">{b}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-sm text-ink-900 mb-3 uppercase tracking-wider">Fuel Type</h3>
            <ul class="space-y-1">
              {fuelTypes.map(f => (
                <li><a href={`/cars/?fuel=${f}`} class="text-sm text-ink-600 hover:text-brand-500">{f}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-sm text-ink-900 mb-3 uppercase tracking-wider">Brand</h3>
            <ul class="space-y-1">
              {brands.map(b => (
                <li><a href={`/brands/${b.toLowerCase()}/`} class="text-sm text-ink-600 hover:text-brand-500">{b}</a></li>
              ))}
            </ul>
          </div>
        </aside>

        {/* Car grid */}
        <div>
          <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-6">
            {cars.map(c => (
              <a href={`/cars/${c.slug}/`} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-xl overflow-hidden transition-all">
                <div class="aspect-[16/10] bg-ink-100 overflow-hidden">
                  <img src={c.hero_image} alt={`${c.brand} ${c.name}`} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="px-2 py-0.5 bg-ink-100 text-ink-600 text-xs rounded">{c.body}</span>
                    <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{c.fuel}</span>
                    {c.authorized && <span class="px-2 py-0.5 bg-brand-500 text-white text-[10px] font-bold rounded">★</span>}
                  </div>
                  <div class="text-xs text-ink-500 mb-1">{c.brand}</div>
                  <h3 class="font-semibold text-base text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{c.name}</h3>
                  <div class="flex items-end justify-between">
                    <div>
                      <div class="text-xs text-ink-500">From</div>
                      <div class="text-lg font-bold text-ink-900">${c.price_min.toLocaleString()}</div>
                      <div class="text-xs text-ink-400">FOB Shanghai</div>
                    </div>
                    <div class="text-right">
                      <div class="text-xs text-ink-500">In stock</div>
                      <div class="text-sm font-semibold text-ink-900">{c.stock} units</div>
                      <div class="text-xs text-ink-400">MOQ {c.moq}</div>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
