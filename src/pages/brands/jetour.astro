---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Single brand master template — Jetour
// Reusable for 5 other authorized brands (Deepal/Qiyuan/Geely/VW/Jetour)
// Structure synthesized from cars-in-china/byd + ihka about + Mercedes whitespace aesthetic

const brand = {
  name: 'Jetour',
  cn: '捷途',
  slug: 'jetour',
  tagline: 'Adventure SUV Specialist of Chery Group',
  hero_image: '/images/faq-sourcing.webp',
  logo: '/images/brand-jetour.svg',
  authorized_since: 2021,
  founded: 2018,
  annual_production: '500K units',
  export_countries: '50+',
  in_stock: '50+ units',
};

const heroBadges = [
  'Authorized Dealer Since 2021',
  '6 SUV Models Available',
  'PHEV + ICE Off-Road Lineup',
];

const stats = [
  { num: '2018', label: 'Brand Founded', sub: 'Wuhu, China' },
  { num: '500K', label: 'Annual Production', sub: 'units / year' },
  { num: '50+', label: 'Export Countries', sub: 'Growing Network' },
  { num: '50+', label: 'In Bonded Stock', sub: 'Ready to Ship' },
];

const brandStory = `Jetour Auto (捷途汽车), launched 2018 by Chery Group, is China's fastest-growing SUV specialist. Focused exclusively on SUV / Adventure / off-road vehicles, Jetour combines Chery's mature powertrain engineering with adventure-themed styling. T2 (旅行者) is the flagship export hit, with T1 gaining fast in Russia/CIS and the new G700 flagship expanding into UAE, Qatar and Latin America.

EV Auto Pro is an authorized Jetour exporter since 2021. We hold direct dealer MoUs covering Jetour's real export lineup — T2 i-DM PHEV, T1 and T1 i-DM, X70 Plus, Dashing, and the new G700 luxury off-road PHEV flagship. Every unit traceable to factory invoice. Zero grey market.`;

const models = [
  { slug: 'jetour-t2', name: 'T2 i-DM', body: 'Adventure SUV', fuel: 'PHEV', price_min: 22500, stock: 30, ready: true },
  { slug: 'jetour-t1', name: 'T1', body: 'Compact SUV', fuel: 'ICE', price_min: 18700, stock: 0, ready: true },
  { slug: 'jetour-t1-idm', name: 'T1 i-DM', body: 'Compact SUV', fuel: 'PHEV', price_min: 21700, stock: 0, ready: true },
  { slug: 'jetour-x70-plus', name: 'X70 Plus', body: 'Big Family SUV', fuel: 'ICE', price_min: 11000, stock: 0, ready: true },
  { slug: 'jetour-dashing', name: 'Dashing', body: 'Compact SUV', fuel: 'ICE', price_min: 13000, stock: 0, ready: true },
  { slug: 'jetour-g700', name: 'G700', body: 'Full-size Off-Road SUV', fuel: 'PHEV', price_min: 46300, stock: 0, ready: true },
];

const subBrands = [
  { slug: 'chery', name: 'Chery', cn: '奇瑞', desc: 'Parent brand · China\'s largest auto exporter since 1997', models: 12 },
  { slug: 'exeed', name: 'Exeed', cn: '星途', desc: 'Sibling premium brand · TXL/LX/RX models', models: 4 },
];

const advantages = [
  { icon: '🏔', title: 'Adventure SUV DNA', desc: 'Every Jetour model designed for off-road / adventure / family travel. 7-seater layouts standard.' },
  { icon: '🏭', title: 'Chery Group Engineering', desc: 'Backed by China\'s #1 auto exporter Chery. Shared 1.5T/2.0T turbo engines, mature global supply chain.' },
  { icon: '🌄', title: 'Best for Central Asia / GCC', desc: 'Jetour T2 + Dashing dominate Kazakhstan / UAE / Saudi adventure SUV markets — desert and snow tested.' },
  { icon: '⚡', title: 'PHEV Tech Leader', desc: 'Jetour T2 i-DM / G700 PHEV — up to 139km pure electric on T2 i-DM, 1000km combined on G700. LFP battery on both.' },
  { icon: '👨‍👩‍👧', title: '7-Seater Family Focus', desc: 'Roomy interior + flexible 2+3+2 seating. Best ROI for fleet operators / large family markets.' },
  { icon: '✅', title: 'Direct OEM Pricing', desc: 'EV Auto Pro is authorized exporter via Chery group MoU. Factory MSRP, no dealer markup.' },
];

const markets = [
  { code: 'RU', name: 'Russia', stat: '#1 Chinese ICE brand', img: '/images/vehicles/evautopro-jetour-t2-01.webp' },
  { code: 'KZ', name: 'Kazakhstan', stat: '12,000+ units / year', img: '/images/vehicles/evautopro-jetour-x70-plus-01.webp' },
  { code: 'AE', name: 'UAE', stat: 'Top 5 imported Chinese', img: '/images/vehicles/evautopro-geely-coolray-01.webp' },
  { code: 'EG', name: 'Egypt', stat: 'CKD assembly partner', img: '/images/vehicles/evautopro-changan-cs55-plus-01.webp' },
];

const cases = [
  { headline: '50 Units Jetour T2 i-DM → Tashkent, Uzbekistan', client: 'Uzbek Auto Group', stars: 5, quote: 'T2 i-DM PHEV adventure SUV perfect for Central Asia families. Block train via Khorgos in 18 days.' },
  { headline: '30 Units X70 Plus → Riyadh, Saudi Arabia', client: 'Gulf Family Fleet', stars: 5, quote: 'GCC + SASO complete. 7-seater for large families — desert-tested suspension.' },
  { headline: '20 Units Dashing → Moscow', client: 'Moscow Adventure Dealer', stars: 5, quote: 'Compact SUV with strong winter performance — Vanguard Technology positioning fits younger CIS buyers.' },
];

const brandFaqs = [
  { q: 'Is EV Auto Pro really an authorized Jetour exporter?', a: 'Yes. We hold a signed dealer MoU with Jetour (via parent Chery Group) since 2021. We share the MoU scan on request. Factory invoice provided for every unit.' },
  { q: 'Which Jetour models are best for export to Central Asia / GCC?', a: 'Jetour T2 i-DM PHEV (旅行者) has the highest search demand of any Jetour model and leads in Uzbekistan + Kazakhstan. X70 Plus (5/6/7-seat configurable) dominates GCC family fleet. Dashing is growing fast in the Saudi youth segment.' },
  { q: 'Does Jetour support right-hand drive (RHD)?', a: 'Yes for T2, X70 Plus. Factory RHD batch MOQ: 20 units. Lead time 45-60 days. Suitable for UK / SA / PK / ID / KE markets.' },
  { q: 'What is the warranty for Jetour exported vehicles?', a: '5-year / 100,000 km vehicle warranty. 8-year / 160,000 km on PHEV battery + electric drivetrain. Local warranty via Jetour authorized partners.' },
  { q: 'Can I order custom configuration (paint / interior / off-road kit)?', a: 'Yes. Custom paint codes (10+ colors incl. desert tan / arctic white), interior trim (cloth/leather), off-road accessories (skid plate / roof rack). MOQ varies.' },
  { q: 'How fast can Jetour models ship?', a: 'In-stock units: 3-15 days from PI signing. Custom factory orders: 30-45 days. We maintain 50+ Jetour units in Shanghai bonded warehouse.' },
];
---

<BaseLayout
  title="Jetour Export | EV Auto Pro Authorized Dealer Since 2021"
  description="Buy Jetour from authorized China exporter. T2 i-DM / T1 / X70 Plus / Dashing / G700 — 6 real export models. FOB from $11,000. MOQ 1. Ships to 60+ countries."
>
  {/* ============ 1. HERO 全屏大图 ============ */}
  <section class="relative bg-ink-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={brand.hero_image} alt={`${brand.name} brand`} class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-40">
      <nav class="text-xs text-ink-400 mb-6">
        <a href="/" class="hover:text-brand-500">Home</a> ·
        <a href="/brands/" class="hover:text-brand-500">Brands</a> ·
        <span class="text-white">{brand.name}</span>
      </nav>
      <div class="flex items-center gap-4 mb-6">
        <div class="w-20 h-20 lg:w-24 lg:h-24 rounded-2xl bg-white p-3 flex items-center justify-center">
          <img src={brand.logo} alt={brand.name} class="w-full h-full object-contain" />
        </div>
        <div class="inline-flex items-center px-3 py-1 bg-brand-500 text-white text-xs font-bold rounded-full">
          ★ AUTHORIZED EXPORTER
        </div>
      </div>
      <h1 class="text-5xl lg:text-7xl font-bold text-white leading-tight mb-3">{brand.name}</h1>
      <p class="text-2xl text-brand-500 font-semibold mb-3">{brand.cn}</p>
      <p class="text-lg lg:text-xl text-ink-300 max-w-2xl mb-10">{brand.tagline}</p>
      <div class="flex flex-wrap gap-3 mb-10">
        {heroBadges.map(b => (
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm text-white">
            <span class="text-brand-500">✓</span> {b}
          </span>
        ))}
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="#models" class="btn-primary">Browse {models.length} Models</a>
        <a href="/contact/quote/?brand=jetour" class="inline-flex items-center px-6 py-3 bg-white text-ink-900 hover:bg-ink-100 font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
      </div>
    </div>
  </section>

  {/* ============ 2. STATS Strip ============ */}
  <section class="py-16 lg:py-20 border-b border-ink-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        {stats.map(s => (
          <div class="text-center lg:text-left">
            <div class="text-4xl lg:text-5xl font-bold text-brand-500 mb-2">{s.num}</div>
            <div class="text-base font-semibold text-ink-900">{s.label}</div>
            <div class="text-xs text-ink-500 mt-1">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 3. BRAND STORY 双列 (奔驰式大留白) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_1.5fr] gap-16 items-start">
        <div class="sticky top-24">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-3">The Brand</p>
          <h2 class="text-4xl lg:text-5xl font-bold text-ink-900 leading-tight">{brand.founded} — the story so far</h2>
        </div>
        <div class="space-y-6 text-base lg:text-lg text-ink-700 leading-relaxed">
          {brandStory.split('\n\n').map(para => <p>{para}</p>)}
          <a href="https://www.jetour.com.cn" target="_blank" rel="noopener" class="inline-flex items-center text-sm font-semibold text-brand-500 hover:text-brand-600 mt-4">
            Visit Jetour official site ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 4. AUTHORIZED DEALER STATEMENT ============ */}
  <section class="py-16 bg-ink-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-[80px_1fr] gap-6 items-start">
        <div class="w-20 h-20 rounded-2xl bg-brand-500 flex items-center justify-center text-4xl">★</div>
        <div>
          <h3 class="text-2xl font-bold text-ink-900 mb-2">EV Auto Pro is an authorized Jetour exporter</h3>
          <p class="text-base text-ink-700 leading-relaxed">
            We hold a signed dealer MoU with Jetour Automobile since <strong>{brand.authorized_since}</strong>. Every unit shipped is sourced directly from the factory — no grey market, no rebadged units. Factory invoice provided for every export order on request. Customs and EAC/GCC/INMETRO documentation handled in-house.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 5. MODELS GRID (核心) ============ */}
  <section id="models" class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12 gap-4">
        <div>
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Available Models</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{models.length} Jetour models for export</h2>
        </div>
        <a href="/cars/?brand=jetour" class="text-sm font-semibold text-brand-500 hover:text-brand-600">All Jetour models →</a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {models.map(m => (
          <a href={m.ready ? `/cars/${m.slug}/` : '/contact/quote/?model=' + m.slug}
             class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-xl overflow-hidden transition-all">
            <div class="aspect-[16/10] bg-ink-100 overflow-hidden">
              <img src={['jetour-t2','jetour-dashing','jetour-x70-plus','jetour-t1','jetour-t1-idm','jetour-g700'].includes(m.slug) ? `/images/vehicles/evautopro-${m.slug}-01.webp` : '/images/vehicles/evautopro-jetour-t2-other-01.webp'} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-ink-100 text-ink-600 text-xs rounded">{m.body}</span>
                <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{m.fuel}</span>
              </div>
              <h3 class="text-base font-semibold text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{m.name}</h3>
              <div class="flex items-end justify-between">
                <div>
                  <div class="text-xs text-ink-500">From FOB</div>
                  <div class="text-lg font-bold text-ink-900">${m.price_min.toLocaleString()}</div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-ink-500">{m.stock > 0 ? 'In stock' : 'Availability'}</div>
                  <div class="text-sm font-semibold text-ink-900">{m.stock > 0 ? `${m.stock} units` : 'Made to Order'}</div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 6. SUB-BRAND FAMILY (Jetour 旗下子品牌) ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Jetour Family</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Sub-brands under Jetour group</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {subBrands.map(b => (
          <a href={`/contact/quote/?brand=${encodeURIComponent(b.name)}`} class="group flex items-start gap-5 bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-2xl p-8 transition-all">
            <div class="flex-shrink-0 w-20 h-20 rounded-xl bg-ink-100 p-3">
              <img src={`/images/brand-${b.slug}.svg`} alt={b.name} class="w-full h-full object-contain" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 group-hover:text-brand-500 transition-colors">{b.name}</h3>
              <p class="text-sm text-brand-500 font-semibold mb-2">{b.cn}</p>
              <p class="text-sm text-ink-600 leading-relaxed mb-3">{b.desc}</p>
              <div class="text-xs text-ink-500">{b.models} models · authorized via Jetour MoU</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 7. WHY CHANGAN FROM EV AUTO PRO (6 卖点) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Why Choose Jetour</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">6 reasons dealers pick Jetour via EV Auto Pro</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {advantages.map(a => (
          <div class="bg-white border border-ink-200 rounded-2xl p-8 hover:border-brand-500 hover:shadow-md transition-all">
            <div class="text-4xl mb-4">{a.icon}</div>
            <h3 class="text-base font-bold text-ink-900 mb-2">{a.title}</h3>
            <p class="text-sm text-ink-600 leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 8. BEST-SELLING MARKETS ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Where Jetour Wins</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Top markets for Jetour export</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {markets.map(m => (
          <a href={`/markets/${m.name.toLowerCase()}/`} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl overflow-hidden transition-all">
            <div class="aspect-[4/3] bg-ink-100 overflow-hidden">
              <img src={m.img} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
            <div class="p-5">
              <div class="text-xs text-ink-500 font-semibold uppercase tracking-wider mb-1">{m.code}</div>
              <h3 class="text-lg font-bold text-ink-900 group-hover:text-brand-500 transition-colors">{m.name}</h3>
              <p class="text-xs text-brand-500 font-semibold mt-2">{m.stat}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 9. CASES & SHIPMENT RECORDS ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Recent Jetour Shipments</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Your Jetour has arrived</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {cases.map((c, i) => (
          <div class="bg-white border border-ink-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
            <div class="aspect-[16/10] bg-ink-100 overflow-hidden">
              <img src={`/images/testimonial-${i + 1}.svg`} alt={c.client} class="w-full h-full object-cover" />
            </div>
            <div class="p-6">
              <div class="flex gap-0.5 mb-3">
                {Array(c.stars).fill(0).map(() => <span class="text-yellow-500 text-sm">★</span>)}
              </div>
              <h3 class="text-base font-bold text-ink-900 mb-3 leading-snug">{c.headline}</h3>
              <p class="text-sm text-ink-700 italic mb-4 leading-relaxed">"{c.quote}"</p>
              <div class="pt-3 border-t border-ink-200 text-sm font-semibold text-ink-900">{c.client}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 10. BRAND-SPECIFIC FAQ ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Jetour FAQ</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Common Jetour questions</h2>
      </div>
      <div class="space-y-3">
        {brandFaqs.map(f => (
          <details class="group bg-white border border-ink-200 rounded-xl overflow-hidden hover:border-brand-500 transition-colors">
            <summary class="flex items-start justify-between gap-4 cursor-pointer p-5 list-none">
              <span class="font-semibold text-base text-ink-900 flex-1 group-open:text-brand-500 transition-colors">{f.q}</span>
              <svg class="flex-shrink-0 w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-sm text-ink-700 leading-relaxed border-t border-ink-100">
              <div class="pt-4">{f.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 11. DARK CTA ============ */}
  <section class="py-24 lg:py-32 bg-ink-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/faq-logistics.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-4">Import Jetour from China</h2>
      <p class="text-lg text-ink-300 mb-10 max-w-2xl mx-auto">
        {models.length} models in stock · FOB from ${Math.min(...models.map(m => m.price_min)).toLocaleString()} · 24h quote · 60+ countries shipped
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact/quote/?brand=jetour" class="inline-flex items-center px-8 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
        <a href="https://wa.me/8615964467914?text=Jetour%20inquiry" class="inline-flex items-center px-8 py-4 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
        <a href="/contact/quote/?brand=jetour" class="inline-flex items-center px-8 py-4 border-2 border-white text-white hover:bg-white hover:text-ink-900 font-semibold rounded-lg transition-colors">
          📕 Catalogue PDF
        </a>
      </div>
    </div>
  </section>

  {/* Brand JSON-LD Schema (SEO) */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Brand',
    name: brand.name,
    alternateName: brand.cn,
    description: brandStory.replace(/\n/g, ' '),
    foundingDate: '1862',
    url: `https://evautopro.com/brands/${brand.slug}/`,
  })} />
</BaseLayout>
