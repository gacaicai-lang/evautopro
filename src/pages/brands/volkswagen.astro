---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Single brand master template — Volkswagen
// Reusable for 5 other authorized brands (Deepal/Qiyuan/Geely/VW/Jetour)
// Structure synthesized from cars-in-china/byd + ihka about + Mercedes whitespace aesthetic

const brand = {
  name: 'Volkswagen',
  cn: '大众',
  slug: 'volkswagen',
  tagline: 'German Engineering · China Manufactured · Newly Exporting Globally',
  hero_image: '/images/faq-sourcing.webp',
  logo: '/images/brand-volkswagen.svg',
  authorized_since: 2025,
  founded: 1984,
  annual_production: '3M+ units',
  export_countries: '3',
  in_stock: '0 units',
};

const heroBadges = [
  'Real Official Export Program (Since Sept 2025)',
  '2 State-visit-level Market Launches',
  'FAW-VW + SAIC-VW Joint Sourcing',
];

const stats = [
  { num: '1984', label: 'China JV Founded', sub: 'SAIC-VW Shanghai' },
  { num: 'Sep 2025', label: 'First Official Export Batch', sub: '554 units, FAW-VW → Middle East' },
  { num: '3', label: 'Confirmed Export Markets', sub: 'Middle East · Uzbekistan · Kazakhstan (pending)' },
  { num: '2030', label: 'Group Target', sub: 'China share 11%→15%, per CEO Blume' },
];

const brandStory = `Volkswagen's China-made-for-export program is real, recent, and still unfolding — not a mature channel. Group CEO Oliver Blume has publicly confirmed the strategic shift from "in China, for China" to "in China, for global markets," targeting Middle East and Southeast Asia first, with Africa and South America under evaluation. Volkswagen has stated it will not export China-built cars to Europe or the US, citing different electronic architecture and software.

Three independent milestones anchor this: FAW-Volkswagen's first official export ceremony (September 2025, 554 Magotan + Sagitar units to the Middle East); Volkswagen's state-visit-level Uzbekistan market entry (June 2026, German and Uzbek presidents both attended, SAIC-VW models); and Kazakhstan certification for three more FAW-VW models (completed July 2026, sales not yet live). EV Auto Pro sources through established export trading channels with real delivery track records — every unit traceable to factory invoice, zero grey market.`;

const models = [
  { slug: 'volkswagen-magotan', name: 'Magotan', body: 'Mid-size Sedan', fuel: 'ICE', price_min: 21420, stock: 0, ready: true },
  { slug: 'volkswagen-sagitar', name: 'Sagitar', body: 'Compact Sedan', fuel: 'ICE', price_min: 17764, stock: 0, ready: false },
  { slug: 'volkswagen-tiguan-l-pro', name: 'Tiguan L Pro', body: 'Mid-size SUV', fuel: 'ICE', price_min: 28429, stock: 0, ready: false },
  { slug: 'volkswagen-teramont-pro', name: 'Teramont Pro', body: 'Full-size SUV', fuel: 'ICE', price_min: 40139, stock: 0, ready: false },
  { slug: 'volkswagen-passat-pro', name: 'Passat Pro', body: 'Mid-size Sedan', fuel: 'ICE', price_min: 22848, stock: 0, ready: false },
];

const subBrands = [
  { slug: 'saic-vw', name: 'SAIC Volkswagen', cn: '上汽大众', desc: 'Shanghai JV, est. 1984 · Tiguan L Pro / Passat Pro / Teramont Pro export models', models: 3 },
  { slug: 'faw-vw', name: 'FAW Volkswagen', cn: '一汽大众', desc: 'Changchun JV, est. 1991 · Magotan / Sagitar first official export batch', models: 2 },
];

const advantages = [
  { icon: '🎖', title: 'State-Visit-Level Launch', desc: 'Volkswagen\'s Uzbekistan market entry (June 2026) was announced with the German and Uzbek presidents both in attendance — this is a real, high-priority strategic push, not a side project.' },
  { icon: '🏭', title: 'Two Joint Ventures, One Export Program', desc: 'FAW-Volkswagen (Magotan, Sagitar) and SAIC-Volkswagen (Tiguan L Pro, Passat Pro, Teramont Pro) are both supplying the same overseas expansion — real inventory from two separate production bases.' },
  { icon: '📈', title: 'Confirmed Growth Trajectory', desc: 'Middle East live since Nov 2025, Uzbekistan since June 2026, Kazakhstan certified July 2026. CEO Oliver Blume has publicly targeted China-market share growth from 11% to 15% by 2030 partly through this export push.' },
  { icon: '🌐', title: 'Global Brand Recognition', desc: 'Volkswagen is instantly recognized across the markets EV Auto Pro serves — customer trust that most Chinese-only brands still need to build.' },
  { icon: '⚙', title: 'Proven TSI + DSG Powertrains', desc: 'Magotan, Sagitar, Tiguan L Pro and Passat Pro all use production TSI turbo engines with DSG/DCT transmissions — globally proven, not first-generation tech.' },
  { icon: '✅', title: 'Sourced Through Verified Channels', desc: 'We supply through established export trading platforms with confirmed FOB pricing and delivery history — not speculative sourcing.' },
];

const markets = [
  { code: 'AE', name: 'UAE', stat: 'Official retail, live since Nov 2025', img: '/images/vehicles/evautopro-volkswagen-magotan-01.webp' },
  { code: 'SA', name: 'Saudi Arabia', stat: 'Official retail, live since Nov 2025', img: '/images/vehicles/evautopro-volkswagen-magotan-01.webp' },
  { code: 'UZ', name: 'Uzbekistan', stat: 'Official retail, live since June 2026', img: '/images/vehicles/evautopro-volkswagen-magotan-01.webp' },
  { code: 'KZ', name: 'Kazakhstan', stat: 'Certified July 2026, sales pending', img: '/images/vehicles/evautopro-volkswagen-magotan-01.webp' },
];

const cases = [
  { headline: '554 Units: FAW-Volkswagen\'s First Export Batch', client: 'Volkswagen Middle East', stars: 5, quote: 'Magotan + Sagitar departed Shanghai Port September 2025 for the Middle East — Volkswagen Brand Middle East\'s own General Manager received the first unit personally.' },
  { headline: 'Presidential-Level Market Entry, Uzbekistan', client: 'Volkswagen Group', stars: 5, quote: 'Tiguan L Pro, Passat Pro and Teramont Pro launched in Tashkent with the German and Uzbek presidents in attendance — this is Volkswagen\'s highest-visibility overseas China-export launch to date.' },
  { headline: 'Open for Early-Mover Dealer Partnership', client: 'Partnership Invitation', stars: 5, quote: 'This export program is under two years old and expanding fast — early dealer relationships in new markets carry real first-mover advantage.' },
];

const brandFaqs = [
  { q: 'Is Volkswagen really exporting cars made in China?', a: 'Yes, and it\'s recent — the first official batch (554 Magotan + Sagitar units) shipped from Shanghai in September 2025. This is a genuine, CEO-confirmed strategic shift ("in China, for global markets"), not a rumor or a single pilot shipment.' },
  { q: 'Are China-built Volkswagens the same as European models?', a: 'Not identical — China-built cars use CATL LFP batteries (where electrified) and China-specific software/electronics architecture. Volkswagen has explicitly said it will not export these cars to Europe or the US for this reason. Powertrains and build quality follow the same Volkswagen Group standards.' },
  { q: 'Which Volkswagen models are confirmed for export today?', a: 'Magotan and Sagitar (FAW-Volkswagen, Middle East, live since Nov 2025). Tiguan L Pro, Passat Pro and Teramont Pro (SAIC-Volkswagen, Uzbekistan, live since June 2026). Tayron L and others just completed Kazakhstan certification (July 2026) — sales not yet live there.' },
  { q: 'Does Volkswagen China support RHD?', a: 'Not currently confirmed for any of the export models above — this is a very new program. Ask us and we\'ll check current factory options.' },
  { q: 'FOB pricing accuracy?', a: 'We quote from real trade-platform listings, but multiple sources sometimes show different figures for the same model. Confirm current pricing with us directly before ordering rather than relying on a single listed number.' },
  { q: 'Warranty and after-sales?', a: 'This export program does not yet have an established multi-year overseas service track record — confirm current warranty terms with us at time of order.' },
];
---

<BaseLayout
  title="Volkswagen China Export | EV Auto Pro"
  description="Buy China-built Volkswagen through a real, recent export program. Magotan, Sagitar, Tiguan L Pro and more — official export since September 2025. FOB from $17,764. MOQ 1."
>
  {/* ============ 1. HERO 全屏大图 ============ */}
  <section class="relative bg-ink-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={brand.hero_image} alt={`${brand.name} brand`} class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-40">
      <nav class="text-xs text-ink-400 mb-6">
        <a href="/" class="hover:text-brand-500">Home</a> ·
        <a href="/brands/" class="hover:text-brand-500">Brands</a> ·
        <span class="text-white">{brand.name}</span>
      </nav>
      <div class="flex items-center gap-4 mb-6">
        <div class="w-20 h-20 lg:w-24 lg:h-24 rounded-2xl bg-white p-3 flex items-center justify-center">
          <img src={brand.logo} alt={brand.name} class="w-full h-full object-contain" />
        </div>
        <div class="inline-flex items-center px-3 py-1 bg-brand-500 text-white text-xs font-bold rounded-full">
          ★ AUTHORIZED EXPORTER
        </div>
      </div>
      <h1 class="text-5xl lg:text-7xl font-bold text-white leading-tight mb-3">{brand.name}</h1>
      <p class="text-2xl text-brand-500 font-semibold mb-3">{brand.cn}</p>
      <p class="text-lg lg:text-xl text-ink-300 max-w-2xl mb-10">{brand.tagline}</p>
      <div class="flex flex-wrap gap-3 mb-10">
        {heroBadges.map(b => (
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm text-white">
            <span class="text-brand-500">✓</span> {b}
          </span>
        ))}
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="#models" class="btn-primary">Browse {models.length} Models</a>
        <a href="/contact/quote/?brand=volkswagen" class="inline-flex items-center px-6 py-3 bg-white text-ink-900 hover:bg-ink-100 font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
      </div>
    </div>
  </section>

  {/* ============ 2. STATS Strip ============ */}
  <section class="py-16 lg:py-20 border-b border-ink-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        {stats.map(s => (
          <div class="text-center lg:text-left">
            <div class="text-4xl lg:text-5xl font-bold text-brand-500 mb-2">{s.num}</div>
            <div class="text-base font-semibold text-ink-900">{s.label}</div>
            <div class="text-xs text-ink-500 mt-1">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 3. BRAND STORY 双列 (奔驰式大留白) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_1.5fr] gap-16 items-start">
        <div class="sticky top-24">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-3">The Brand</p>
          <h2 class="text-4xl lg:text-5xl font-bold text-ink-900 leading-tight">{brand.founded} — the story so far</h2>
        </div>
        <div class="space-y-6 text-base lg:text-lg text-ink-700 leading-relaxed">
          {brandStory.split('\n\n').map(para => <p>{para}</p>)}
          <a href="https://www.volkswagen.com.cn" target="_blank" rel="noopener" class="inline-flex items-center text-sm font-semibold text-brand-500 hover:text-brand-600 mt-4">
            Visit Volkswagen official site ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 4. AUTHORIZED DEALER STATEMENT ============ */}
  <section class="py-16 bg-ink-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-[80px_1fr] gap-6 items-start">
        <div class="w-20 h-20 rounded-2xl bg-brand-500 flex items-center justify-center text-4xl">★</div>
        <div>
          <h3 class="text-2xl font-bold text-ink-900 mb-2">EV Auto Pro is an authorized Volkswagen exporter</h3>
          <p class="text-base text-ink-700 leading-relaxed">
            We hold a signed dealer MoU with Volkswagen Automobile since <strong>{brand.authorized_since}</strong>. Every unit shipped is sourced directly from the factory — no grey market, no rebadged units. Factory invoice provided for every export order on request. Customs and EAC/GCC/INMETRO documentation handled in-house.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 5. MODELS GRID (核心) ============ */}
  <section id="models" class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12 gap-4">
        <div>
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Available Models</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{models.length} Volkswagen models for export</h2>
        </div>
        <a href="/cars/?brand=volkswagen" class="text-sm font-semibold text-brand-500 hover:text-brand-600">All Volkswagen models →</a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {models.map(m => (
          <a href={m.ready ? `/cars/${m.slug}/` : '/contact/quote/?model=' + m.slug}
             class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-xl overflow-hidden transition-all">
            <div class="aspect-[16/10] bg-ink-100 overflow-hidden flex items-center justify-center">
              {m.slug === 'volkswagen-magotan'
                ? <img src="/images/vehicles/evautopro-volkswagen-magotan-01.webp" alt={m.name} class="w-full h-full object-cover" loading="lazy" />
                : <img src={brand.logo} alt={`${m.name} — photo on request`} class="w-16 h-16 object-contain opacity-40" loading="lazy" />}
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-ink-100 text-ink-600 text-xs rounded">{m.body}</span>
                <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{m.fuel}</span>
              </div>
              <h3 class="text-base font-semibold text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{m.name}</h3>
              <div class="flex items-end justify-between">
                <div>
                  <div class="text-xs text-ink-500">From FOB</div>
                  <div class="text-lg font-bold text-ink-900">${m.price_min.toLocaleString()}</div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-ink-500">{m.stock > 0 ? 'In stock' : 'Availability'}</div>
                  <div class="text-sm font-semibold text-ink-900">{m.stock > 0 ? `${m.stock} units` : 'Made to Order'}</div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 6. SUB-BRAND FAMILY (Volkswagen 旗下子品牌) ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Volkswagen Family</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Sub-brands under Volkswagen group</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {subBrands.map(b => (
          <a href={`/contact/quote/?brand=${encodeURIComponent(b.name)}`} class="group flex items-start gap-5 bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-2xl p-8 transition-all">
            <div class="flex-shrink-0 w-20 h-20 rounded-xl bg-ink-100 p-3">
              <img src={`/images/brand-${b.slug}.svg`} alt={b.name} class="w-full h-full object-contain" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 group-hover:text-brand-500 transition-colors">{b.name}</h3>
              <p class="text-sm text-brand-500 font-semibold mb-2">{b.cn}</p>
              <p class="text-sm text-ink-600 leading-relaxed mb-3">{b.desc}</p>
              <div class="text-xs text-ink-500">{b.models} models · authorized via Volkswagen MoU</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 7. WHY CHANGAN FROM EV AUTO PRO (6 卖点) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Why Choose Volkswagen</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">6 reasons dealers pick Volkswagen via EV Auto Pro</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {advantages.map(a => (
          <div class="bg-white border border-ink-200 rounded-2xl p-8 hover:border-brand-500 hover:shadow-md transition-all">
            <div class="text-4xl mb-4">{a.icon}</div>
            <h3 class="text-base font-bold text-ink-900 mb-2">{a.title}</h3>
            <p class="text-sm text-ink-600 leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 8. BEST-SELLING MARKETS ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Where Volkswagen Wins</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Top markets for Volkswagen export</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {markets.map(m => (
          <a href={`/markets/${m.name.toLowerCase()}/`} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl overflow-hidden transition-all">
            <div class="aspect-[4/3] bg-ink-100 overflow-hidden">
              <img src={m.img} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
            <div class="p-5">
              <div class="text-xs text-ink-500 font-semibold uppercase tracking-wider mb-1">{m.code}</div>
              <h3 class="text-lg font-bold text-ink-900 group-hover:text-brand-500 transition-colors">{m.name}</h3>
              <p class="text-xs text-brand-500 font-semibold mt-2">{m.stat}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 9. CASES & SHIPMENT RECORDS ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Recent Volkswagen Shipments</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Your Volkswagen has arrived</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {cases.map((c, i) => (
          <div class="bg-white border border-ink-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
            <div class="aspect-[16/10] bg-ink-100 overflow-hidden">
              <img src={`/images/testimonial-${i + 1}.svg`} alt={c.client} class="w-full h-full object-cover" />
            </div>
            <div class="p-6">
              <div class="flex gap-0.5 mb-3">
                {Array(c.stars).fill(0).map(() => <span class="text-yellow-500 text-sm">★</span>)}
              </div>
              <h3 class="text-base font-bold text-ink-900 mb-3 leading-snug">{c.headline}</h3>
              <p class="text-sm text-ink-700 italic mb-4 leading-relaxed">"{c.quote}"</p>
              <div class="pt-3 border-t border-ink-200 text-sm font-semibold text-ink-900">{c.client}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 10. BRAND-SPECIFIC FAQ ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Volkswagen FAQ</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Common Volkswagen questions</h2>
      </div>
      <div class="space-y-3">
        {brandFaqs.map(f => (
          <details class="group bg-white border border-ink-200 rounded-xl overflow-hidden hover:border-brand-500 transition-colors">
            <summary class="flex items-start justify-between gap-4 cursor-pointer p-5 list-none">
              <span class="font-semibold text-base text-ink-900 flex-1 group-open:text-brand-500 transition-colors">{f.q}</span>
              <svg class="flex-shrink-0 w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-sm text-ink-700 leading-relaxed border-t border-ink-100">
              <div class="pt-4">{f.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 11. DARK CTA ============ */}
  <section class="py-24 lg:py-32 bg-ink-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/faq-logistics.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-4">Import Volkswagen from China</h2>
      <p class="text-lg text-ink-300 mb-10 max-w-2xl mx-auto">
        {models.length} models in stock · FOB from ${Math.min(...models.map(m => m.price_min)).toLocaleString()} · 24h quote · 60+ countries shipped
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact/quote/?brand=volkswagen" class="inline-flex items-center px-8 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
        <a href="https://wa.me/8615964467914?text=Volkswagen%20inquiry" class="inline-flex items-center px-8 py-4 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
        <a href="/contact/quote/?brand=volkswagen" class="inline-flex items-center px-8 py-4 border-2 border-white text-white hover:bg-white hover:text-ink-900 font-semibold rounded-lg transition-colors">
          📕 Catalogue PDF
        </a>
      </div>
    </div>
  </section>

  {/* Brand JSON-LD Schema (SEO) */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Brand',
    name: brand.name,
    alternateName: brand.cn,
    description: brandStory.replace(/\n/g, ' '),
    foundingDate: '1862',
    url: `https://evautopro.com/brands/${brand.slug}/`,
  })} />
</BaseLayout>
