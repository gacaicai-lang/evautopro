<script>
  const form = document.getElementById('changan-inquiry-form') as HTMLFormElement | null;
  const status = document.getElementById('changan-inquiry-status') as HTMLDivElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!status) return;

    status.classList.remove('hidden', 'text-green-600', 'text-red-600', 'text-ink-500');
    status.classList.add('text-ink-500');
    status.textContent = 'Sending...';

    try {
      const response = await fetch('/api/inquiry', { method: 'POST', body: new FormData(form) });
      const data = await response.json();

      status.classList.remove('text-ink-500');
      if (response.ok) {
        status.classList.add('text-green-600');
        status.textContent = data.message ?? 'Thank you. Our team will reply within 24 hours.';
        form.reset();
      } else {
        status.classList.add('text-red-600');
        status.textContent = data.error ?? 'Something went wrong. Please try again.';
      }
    } catch {
      status.classList.remove('text-ink-500');
      status.classList.add('text-red-600');
      status.textContent = 'Network error. Please try again or contact us directly.';
    }
  });
</script>
