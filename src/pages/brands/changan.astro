---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cars as carsData } from '../../data/cars';

type IconKey = 'car' | 'price' | 'ship' | 'doc' | 'check' | 'shield' | 'support' | 'arrow' | 'factory' | 'route' | 'globe';

const allCars = Object.values(carsData);
const changanCars = allCars.filter((car) => car.brand === 'Changan');
const carBySlug = Object.fromEntries(changanCars.map((car) => [car.slug, car]));

const ICON: Record<IconKey, string> = {
  car: 'M3 13h18l-2 6H5l-2-6Zm4-5h10l2 5H5l2-5Zm2 11v2m6-2v2M8 8V5h8v3',
  price: 'M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6',
  ship: 'M3 17l3.5-1.5L12 17l5.5-1.5L21 17M5 17V9l7-4 7 4v8',
  doc: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm0 0v6h6M8 13h8M8 17h5',
  check: 'M20 6 9 17l-5-5',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z',
  support: 'M4 14v-2a8 8 0 0 1 16 0v2M18 19c0 1.1-.9 2-2 2h-2M6 14a2 2 0 0 0-2 2v1a2 2 0 0 0 2 2h1v-5h-1Zm12 0h1a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-1v-5Z',
  arrow: 'M5 12h14m-6-6 6 6-6 6',
  factory: 'M3 21V9l6 4V9l6 4V5h6v16H3Zm4-4h2m4 0h2m4 0h2',
  route: 'M6 19a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm12-8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM8.5 14.5l7-5',
  globe: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0 0c2.5-3 4-6.5 4-9s-1.5-6-4-9c-2.5 3-4 6.5-4 9s1.5 6 4 9ZM3 12h18',
};

const icon = (name: IconKey, className = 'h-5 w-5') =>
  `<svg class="${className}" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="${ICON[name]}"/></svg>`;

const primaryButton = 'inline-flex min-h-[50px] items-center justify-center gap-2 rounded-md bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-700/25 transition hover:bg-brand-600';
const darkButton = 'inline-flex min-h-[50px] items-center justify-center gap-2 rounded-md border border-white/18 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/18';
const lightButton = 'inline-flex min-h-[50px] items-center justify-center gap-2 rounded-md border border-ink-200 bg-white px-6 py-3 text-sm font-semibold text-ink-900 transition hover:border-brand-500 hover:text-brand-500';

const heroCar = '/images/真图/changan-uni-t/prepped/hero-02.png';
const heroMetrics = [
  { value: '20+', label: 'Changan Models' },
  { value: '95', label: 'Units in Live Data' },
  { value: '12-25d', label: 'Typical Lead Time' },
  { value: 'FOB / CIF', label: 'Quote Support' },
];

const programPillars = [
  {
    icon: 'car' as IconKey,
    title: 'Model Strategy',
    copy: 'Build a launch mix around SUVs first, then expand into UNI styling and Changan Group NEV brands.',
    image: carBySlug['changan-cs55-plus']?.hero_image ?? '/images/car-changan-cs55-plus.svg',
  },
  {
    icon: 'price' as IconKey,
    title: 'Commercial Clarity',
    copy: 'Quote by real stock, trim, color, production year and destination port instead of generic price sheets.',
    image: '/images/faq-payment.webp',
  },
  {
    icon: 'shield' as IconKey,
    title: 'Vehicle Proof',
    copy: 'VIN photos, inspection notes and loading updates help buyers approve the order faster.',
    image: '/images/faq-quality.webp',
  },
  {
    icon: 'ship' as IconKey,
    title: 'Export Execution',
    copy: 'RoRo, container, rail or truck routes are matched to batch size, port and document requirements.',
    image: '/images/faq-logistics.webp',
  },
];

const brandFamilies = [
  {
    name: 'Changan SUV Core',
    line: 'CS55 Plus / CS75 Plus',
    image: carBySlug['changan-cs55-plus']?.hero_image ?? '/images/car-changan-cs55-plus.svg',
    summary: 'The safest entry point for first-order dealers who need practical pricing and fast rotation.',
    proof: ['Compact and mid SUV demand', 'Gasoline preference markets', 'Clear trim and color checks'],
  },
  {
    name: 'UNI Design Series',
    line: 'UNI-T / UNI-K / UNI-Z',
    image: heroCar,
    summary: 'A sharper showroom story for buyers who need visual presence, younger traffic and higher perceived value.',
    proof: ['Sport SUV positioning', 'Stronger first impression', 'Good bridge into NEV options'],
  },
  {
    name: 'Group NEV Upgrade',
    line: 'Deepal / Qiyuan / Avatr',
    image: '/images/真图/laundered/evautopro-deepal-s07-01.webp',
    summary: 'Use the Changan Group ecosystem when your market is ready for EREV, BEV or premium smart EV demand.',
    proof: ['EREV for charging anxiety', 'Family NEV options', 'Premium intelligent EV path'],
  },
];

const launchPacks = [
  {
    name: 'Starter Dealer Batch',
    mix: '3-10 SUVs',
    image: '/images/faq-sourcing.webp',
    models: 'CS55 Plus + UNI-T + CS75 Plus',
    reason: 'Keeps first-order risk controlled while covering compact, sport and family SUV buyers.',
  },
  {
    name: 'Volume SUV Batch',
    mix: '10-30 units',
    image: carBySlug['changan-cs55-plus']?.hero_image ?? '/images/car-changan-cs55-plus.svg',
    models: 'CS55 Plus-led mix',
    reason: 'Built around price clarity, quick retail explanation and repeatable stock replenishment.',
  },
  {
    name: 'ICE + NEV Upgrade',
    mix: 'Mixed brand order',
    image: '/images/真图/laundered/evautopro-deepal-s07-01.webp',
    models: 'Changan + Deepal / Qiyuan',
    reason: 'Adds smart NEV models without abandoning the Changan brand ecosystem.',
  },
];

const featuredModels = [
  ...changanCars.map((car) => ({
    name: car.model,
    image: car.hero_image,
    body: car.body_type,
    fuel: car.fuel_type,
    stock: `${car.stock_units} units`,
    lead: `${car.lead_time_days} days`,
    fob: `$${car.pricing.fob_min.toLocaleString()}-${car.pricing.fob_max.toLocaleString()}`,
    note: car.slug === 'changan-cs55-plus' ? 'Fast-turning compact SUV anchor' : 'Sport-style SUV for younger retail buyers',
    href: `/cars/${car.slug}/`,
  })),
  {
    name: 'CS75 Plus',
    image: '/images/car-changan-cs75-plus.svg',
    body: 'Mid SUV',
    fuel: 'ICE',
    stock: 'By request',
    lead: '15-25 days',
    fob: 'Quote by trim',
    note: 'Family SUV for higher-ticket showroom demand',
    href: '/contact/quote/?model=changan-cs75-plus',
  },
  {
    name: 'UNI-K',
    image: '/images/car-changan-uni-k.svg',
    body: 'Large SUV',
    fuel: 'ICE',
    stock: 'By request',
    lead: '20-30 days',
    fob: 'Quote by trim',
    note: 'Premium SUV option for dealer image upgrade',
    href: '/contact/quote/?model=changan-uni-k',
  },
  {
    name: 'UNI-Z',
    image: '/images/car-changan-uni-z.svg',
    body: 'NEV SUV',
    fuel: 'PHEV',
    stock: 'By request',
    lead: '25-35 days',
    fob: 'Quote by trim',
    note: 'Bridge model from ICE to NEV',
    href: '/contact/quote/?model=changan-uni-z',
  },
].slice(0, 5);

const exportProof = [
  { title: 'Stock Yard', label: 'Actual availability check', image: '/images/faq-sourcing.webp' },
  { title: 'Inspection', label: 'Vehicle photos and PDI notes', image: '/images/faq-quality.webp' },
  { title: 'Loading Plan', label: 'RoRo, container, rail or truck', image: '/images/faq-logistics.webp' },
  { title: 'Document Set', label: 'Invoice, BL, COO and export papers', image: '/images/faq-payment.webp' },
];

const marketRoutes = [
  { region: 'Middle East', route: 'Jebel Ali / Jeddah / Dammam', image: '/images/market-ae.svg', fit: 'SUV demand, hot climate and practical gasoline models.' },
  { region: 'Central Asia', route: 'Khorgos rail / truck / container', image: '/images/market-kz.svg', fit: 'Strong SUV appetite with EAC and cold-weather checks.' },
  { region: 'Africa', route: 'Port Said / Mombasa / Durban', image: '/images/market-eg.svg', fit: 'Price-sensitive SUV and sedan orders with document support.' },
  { region: 'Latin America', route: 'Santos / Manzanillo / regional ports', image: '/images/market-mx.svg', fit: 'Growing Chinese SUV acceptance and certification review.' },
];

const quoteSteps = [
  { step: '01', title: 'Market and model', text: 'Send country, port, preferred model, fuel type and quantity.' },
  { step: '02', title: 'Stock and trim', text: 'We check real availability, color, trim, production year and lead time.' },
  { step: '03', title: 'FOB / CIF quote', text: 'You receive pricing, route assumptions, payment terms and document notes.' },
  { step: '04', title: 'Inspect and ship', text: 'VIN proof, loading updates and export documents move the order forward.' },
];

const faqs = [
  {
    q: 'Which Changan models can you export?',
    a: 'We can quote Changan SUVs, sedans, NEVs and pickup models. Current live examples include UNI-T and CS55 Plus, while CS75 Plus, UNI-K and UNI-Z are sourced by trim and market.',
  },
  {
    q: 'Is Changan suitable for a first import order?',
    a: 'Yes when your buyers need practical SUV pricing, recognizable Chinese brand strength and manageable after-sales conversations. We usually recommend a 3-10 unit SUV launch mix.',
  },
  {
    q: 'Can you quote FOB and CIF?',
    a: 'Yes. Send model, trim, quantity and destination port. We confirm stock and route assumptions before sending FOB China port or CIF destination port pricing.',
  },
  {
    q: 'Can I mix Changan with Deepal or Qiyuan?',
    a: 'Yes. Mixed-brand orders are useful when dealers want ICE SUVs plus NEV options in the same shipment plan.',
  },
];
---

<BaseLayout
  title="Changan Vehicles Export from China | EV Auto Pro"
  description="Premium Changan export page for overseas dealers and importers. Source Changan SUVs, sedans, NEVs and pickup models with stock checks, FOB/CIF pricing, inspection, documents and shipping support."
>
  <!-- 01 Hero -->
  <section class="relative isolate overflow-hidden bg-[#07111f] text-white">
    <div class="absolute inset-0 -z-30 bg-[radial-gradient(circle_at_78%_22%,rgba(229,62,47,.24),transparent_32%),linear-gradient(120deg,#07111f_0%,#0d1f38_45%,#05070d_100%)]"></div>
    <div class="absolute right-[-9%] top-[10%] -z-20 h-[580px] w-[760px] rounded-full border border-white/8"></div>
    <div class="absolute right-[8%] top-[24%] -z-20 h-[360px] w-[520px] rounded-full border border-white/6"></div>

    <div class="mx-auto grid min-h-[780px] max-w-7xl grid-cols-1 items-center gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[0.82fr,1.18fr] lg:px-8">
      <div class="relative z-10">
        <nav class="mb-10 text-xs text-white/50">
          <a href="/" class="hover:text-white">Home</a>
          <span class="mx-2 text-white/25">/</span>
          <a href="/brands/" class="hover:text-white">Brands</a>
          <span class="mx-2 text-white/25">/</span>
          <span class="font-semibold text-white">Changan</span>
        </nav>

        <div class="mb-7 flex items-center gap-4">
          <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-white p-3">
            <img src="/images/brand-changan.svg" alt="Changan" class="h-full w-full object-contain" />
          </div>
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.26em] text-brand-500">Changan export program</div>
            <div class="mt-1 text-sm text-white/58">For dealers, importers and fleet buyers</div>
          </div>
        </div>

        <h1 class="max-w-2xl text-5xl font-bold leading-[1.02] tracking-tight sm:text-6xl lg:text-[76px]">
          Smart Mobility<br />For A Better Life
        </h1>
        <p class="mt-7 max-w-xl text-base leading-8 text-white/72 lg:text-lg">
          A premium export program for Changan SUVs, sedans, NEVs and pickup models from China, built around real stock, practical pricing and controlled shipping execution.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#inquiry-form" class={primaryButton}>Get Changan Price</a>
          <a href="#models" class={darkButton}>View models</a>
          <a href="https://wa.me/8619912345678?text=Hi, I want Changan export pricing." target="_blank" rel="noopener" class={darkButton}>WhatsApp us</a>
        </div>
      </div>

      <div class="relative min-h-[560px]">
        <div class="absolute right-0 top-0 z-20 hidden rounded-full border border-white/12 bg-white/8 px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-white/74 backdrop-blur md:block">
          Stock and sourcing available
        </div>
        <img
          src={heroCar}
          alt="Changan UNI-T export vehicle"
          class="absolute bottom-10 right-[-8%] z-10 w-[116%] max-w-none object-contain drop-shadow-[0_45px_70px_rgba(0,0,0,.65)] lg:bottom-2 lg:w-[122%]"
          loading="eager"
        />
        <div class="absolute bottom-0 left-0 right-0 z-0 h-40 rounded-[50%] bg-black/45 blur-2xl"></div>
      </div>
    </div>

    <div class="relative z-20 border-y border-white/10 bg-black/22 backdrop-blur">
      <div class="mx-auto grid max-w-7xl grid-cols-2 gap-px px-4 sm:px-6 lg:grid-cols-4 lg:px-8">
        {heroMetrics.map((item) => (
          <div class="py-5">
            <div class="text-2xl font-bold tracking-tight text-white">{item.value}</div>
            <div class="mt-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/48">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 02 Program overview -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.72fr,1.28fr] lg:items-end">
        <div>
          <p class="eyebrow">Export program</p>
          <h2 class="h-section">A Changan page should help buyers decide, not browse endlessly.</h2>
        </div>
        <p class="max-w-3xl text-base leading-8 text-ink-600">
          Overseas buyers are usually comparing risk: market fit, stock certainty, price range, route, documents and after-sales expectations. This program turns the brand into a workable order path.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {programPillars.map((item) => (
          <article class="group overflow-hidden rounded-2xl border border-ink-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <div class="relative aspect-[4/3] overflow-hidden bg-ink-100">
              <img src={item.image} alt={item.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
              <div class="absolute left-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white text-brand-500 shadow" set:html={icon(item.icon, 'h-5 w-5')}></div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold tracking-tight text-ink-900">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-ink-600">{item.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 03 Brand authority -->
  <section class="bg-ink-50 py-20 lg:py-28">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[1.08fr,0.92fr] lg:px-8">
      <div class="relative min-h-[560px] overflow-hidden rounded-2xl bg-slate-950 shadow-2xl shadow-ink-900/10">
        <img src="/images/trust-warehouse.svg" alt="Changan export preparation and manufacturing support" class="absolute inset-0 h-full w-full object-cover opacity-70" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/45 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
          <div class="text-xs font-bold uppercase tracking-[0.24em] text-brand-500">Manufacturing scale matters</div>
          <h3 class="mt-4 max-w-2xl text-3xl font-bold leading-tight lg:text-4xl">A major Chinese automotive group with export-ready supply paths.</h3>
        </div>
      </div>

      <div class="flex flex-col justify-center">
        <p class="eyebrow">About Changan</p>
        <h2 class="h-section">Big enough for trust, practical enough for dealer turnover.</h2>
        <p class="mt-6 text-base leading-8 text-ink-600">
          Changan gives buyers a useful middle ground: recognized Chinese OEM scale, strong SUV coverage and a wider group ecosystem for NEV upgrades. For B2B importers, the real value is repeatable sourcing and fewer surprises after the quote.
        </p>
        <div class="mt-9 grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-ink-200 bg-ink-200">
          {[
            ['160+', 'Years industrial heritage'],
            ['Top 4', 'Chinese automotive group'],
            ['35M+', 'Vehicles produced'],
            ['50+', 'Countries and regions'],
          ].map(([value, label]) => (
            <div class="bg-white p-6">
              <div class="text-3xl font-bold tracking-tight text-ink-900">{value}</div>
              <div class="mt-2 text-xs font-semibold uppercase leading-5 tracking-wide text-ink-500">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 04 Lineup architecture -->
  <section class="bg-slate-950 py-20 text-white lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-4xl">
        <p class="mb-3 text-xs font-bold uppercase tracking-[0.22em] text-brand-500">Lineup architecture</p>
        <h2 class="text-3xl font-bold leading-tight tracking-tight text-white lg:text-5xl">Build the showroom by buyer job, not by model count.</h2>
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        {brandFamilies.map((family) => (
          <article class="group relative min-h-[560px] overflow-hidden rounded-2xl border border-white/10 bg-white/7 shadow-xl shadow-black/10 transition hover:-translate-y-1">
            <img src={family.image} alt={family.name} class="absolute inset-0 h-full w-full object-cover opacity-48 transition duration-500 group-hover:scale-105 group-hover:opacity-62" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/78 to-slate-950/8"></div>
            <div class="relative flex h-full min-h-[560px] flex-col justify-end p-7">
              <div class="text-xs font-bold uppercase tracking-[0.2em] text-brand-100">{family.line}</div>
              <h3 class="mt-3 text-3xl font-bold tracking-tight text-white">{family.name}</h3>
              <p class="mt-4 text-sm leading-7 text-white/66">{family.summary}</p>
              <div class="mt-6 space-y-2">
                {family.proof.map((point) => (
                  <div class="flex items-center gap-3 text-sm font-semibold text-white">
                    <span class="flex h-5 w-5 items-center justify-center rounded-full bg-white/12 text-brand-100" set:html={icon('check', 'h-3.5 w-3.5')}></span>
                    {point}
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 05 Launch mix -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.82fr,1.18fr] lg:items-end">
        <div>
          <p class="eyebrow">Dealer launch mix</p>
          <h2 class="h-section">Package the brand around the first order.</h2>
        </div>
        <p class="text-base leading-8 text-ink-600">
          The strongest Changan page should help an importer imagine the first purchase order, not just admire individual cars.
        </p>
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        {launchPacks.map((pack) => (
          <article class="overflow-hidden rounded-2xl border border-ink-200 bg-white shadow-sm">
            <div class="relative aspect-[16/10] overflow-hidden bg-ink-100">
              <img src={pack.image} alt={pack.name} class="h-full w-full object-cover" loading="lazy" />
              <div class="absolute left-4 top-4 rounded-full bg-white/92 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-brand-600">{pack.mix}</div>
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-bold tracking-tight text-ink-900">{pack.name}</h3>
              <div class="mt-4 rounded-lg bg-ink-50 p-4 text-sm font-semibold leading-6 text-ink-800">{pack.models}</div>
              <p class="mt-4 text-sm leading-7 text-ink-600">{pack.reason}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 06 Models -->
  <section id="models" class="bg-ink-50 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 flex flex-col justify-between gap-5 lg:flex-row lg:items-end">
        <div>
          <p class="eyebrow">Export models</p>
          <h2 class="h-section">Quote models with a clear role in the order.</h2>
        </div>
        <a href="/cars/" class={lightButton}>View all inventory</a>
      </div>

      <div class="grid gap-6 lg:grid-cols-[1.16fr,0.84fr]">
        <a href={featuredModels[0].href} class="group relative min-h-[640px] overflow-hidden rounded-2xl bg-ink-950 text-white shadow-2xl shadow-ink-900/15">
          <img src={featuredModels[0].image} alt={`Changan ${featuredModels[0].name}`} class="absolute inset-0 h-full w-full object-cover opacity-76 transition duration-500 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/56 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8">
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-brand-100">Featured ready stock</div>
            <h3 class="mt-3 text-5xl font-bold tracking-tight">{featuredModels[0].name}</h3>
            <p class="mt-4 max-w-xl text-base leading-8 text-white/68">{featuredModels[0].note}</p>
            <div class="mt-7 grid max-w-xl grid-cols-3 gap-px overflow-hidden rounded-xl bg-white/12 text-sm">
              <div class="bg-white/10 p-4 backdrop-blur">
                <div class="text-white/42">FOB</div>
                <div class="mt-1 font-bold">{featuredModels[0].fob}</div>
              </div>
              <div class="bg-white/10 p-4 backdrop-blur">
                <div class="text-white/42">Stock</div>
                <div class="mt-1 font-bold">{featuredModels[0].stock}</div>
              </div>
              <div class="bg-white/10 p-4 backdrop-blur">
                <div class="text-white/42">Lead</div>
                <div class="mt-1 font-bold">{featuredModels[0].lead}</div>
              </div>
            </div>
          </div>
        </a>

        <div class="grid gap-4">
          {featuredModels.slice(1).map((model) => (
