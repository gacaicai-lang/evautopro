---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Li Auto (理想) brand page — HONEST SOURCING framing.
// evautopro is NOT a Li Auto authorized dealer (Li Auto runs its own regional
// dealer network — signed dealerships in UAE/Saudi Apr 2026). We are a China-side
// export sourcing intermediary. NO authorized-dealer/MoU claims, NO fabricated
// customer cases, NO fabricated stock or FOB. All brand facts are verifiable.
// Built 2026-07-23 after a real Li Auto inquiry came in via ChatGPT referral.
// Model photos: none in library yet — using neutral text cards until real
// Li Auto photos are sourced (do NOT substitute another brand's car photo).

const brand = {
  name: 'Li Auto',
  cn: '理想汽车',
  slug: 'li-auto',
  tagline: 'China\'s EREV Pioneer — Extended-Range SUVs Built for Low-Charging Markets',
  hero_image: '/images/faq-sourcing.webp',
  founded: 2015,
  hq: 'Beijing',
};

const heroBadges = [
  'EREV Specialist · 1,000km+ combined range',
  'L6 / L7 / L9 Extended-Range SUVs',
  'Export sourcing — request a quote',
];

// Real, verifiable Li Auto facts (not evautopro stock claims).
const stats = [
  { num: '2015', label: 'Brand Founded', sub: 'Beijing, China' },
  { num: 'EREV', label: 'Core Technology', sub: 'Extended-Range EV' },
  { num: '1,000km+', label: 'Combined Range', sub: 'L-series, engine + battery' },
  { num: '2025-26', label: 'Overseas Rollout', sub: 'Egypt · Kazakhstan · UAE · Saudi' },
];

const brandStory = `Li Auto (理想汽车, Li Auto Inc.), founded in 2015 and headquartered in Beijing, pioneered the extended-range electric vehicle (EREV) format in China. Its L-series SUVs pair a battery-electric drivetrain with a small petrol engine that acts purely as a generator — delivering a genuine electric driving experience with a combined range exceeding 1,000 km and none of the range anxiety of a pure BEV. That makes Li Auto a strong fit for markets where public fast-charging is still developing.

Li Auto began its overseas expansion in late 2025, entering Egypt, Kazakhstan and Azerbaijan, and signed regional dealership partnerships in the UAE and Saudi Arabia in 2026 — the same Middle East and Central Asia markets EV Auto Pro's dealer customers serve.

EV Auto Pro is a China-side export sourcing partner, not a Li Auto authorized dealer. For dealers and fleet buyers who want to source Li Auto L-series vehicles for export, we handle procurement, export documentation, certification (EAC / GCC / INMETRO), and shipping. Ask us for current availability and a landed-cost quote for your market.`;

// Real Li Auto L-series models. No fabricated per-model FOB — quote on request.
const models = [
  { name: 'Li L6', body: 'Mid-size SUV', fuel: 'EREV', note: 'Entry L-series, 5-seat family EREV' },
  { name: 'Li L7', body: 'Mid-large SUV', fuel: 'EREV', note: '5-seat EREV, larger cabin than L6' },
  { name: 'Li L9', body: 'Full-size Flagship SUV', fuel: 'EREV', note: '6-seat flagship; International Exclusive Version announced for overseas markets' },
];

const advantages = [
  { icon: '🔋', title: 'True EREV Range', desc: 'Drives like an EV day to day; the onboard engine generates electricity to extend total range past 1,000 km. No charging network required to use the car fully.' },
  { icon: '🏜', title: 'Built for Low-Charging Markets', desc: 'EREV directly answers the sparse fast-charging in parts of the Gulf, Central Asia and Africa — a genuine reason buyers in your market choose Li over a pure BEV.' },
  { icon: '👨‍👩‍👧‍👦', title: 'Family / Executive Focus', desc: 'The L-series is built around spacious, tech-heavy family and executive interiors — the segment where Li Auto leads in China.' },
  { icon: '🌍', title: 'Real Regional Presence', desc: 'Li Auto is actively rolling out in Egypt, Kazakhstan, Azerbaijan, UAE and Saudi Arabia — a brand your customers can already recognize, not an untested nameplate.' },
  { icon: '📦', title: 'We Handle the Export Chain', desc: 'Procurement, factory-traceable invoicing, EAC / GCC / INMETRO documentation, and RoRo / container / block-train shipping — coordinated in-house.' },
  { icon: '💬', title: 'Straight Sourcing Answers', desc: 'We are a sourcing intermediary, not the OEM dealer — so we tell you plainly what we can and cannot get, and quote real landed cost for your country.' },
];

// Li Auto's real, publicly-reported overseas markets.
const markets = [
  { code: 'EG', name: 'Egypt', stat: 'Entered Dec 2025' },
  { code: 'KZ', name: 'Kazakhstan', stat: 'Entered Dec 2025' },
  { code: 'AE', name: 'UAE', stat: 'Dealership signed 2026' },
  { code: 'SA', name: 'Saudi Arabia', stat: 'Dealership signed 2026' },
];

const brandFaqs = [
  { q: 'Is EV Auto Pro an authorized Li Auto dealer?', a: 'No — and we will not claim to be. Li Auto operates its own regional dealer network (it signed dealerships in the UAE and Saudi Arabia in 2026). EV Auto Pro is a China-side export sourcing partner: for buyers who want to source Li Auto L-series vehicles for export, we handle procurement, documentation and shipping, and quote real landed cost. If you need OEM-warranty retail in a market Li Auto covers directly, its local dealer is the right channel; if you are a dealer or fleet buyer sourcing units for export, talk to us.' },
  { q: 'What is EREV, and why does it matter for my market?', a: 'EREV (Extended-Range Electric Vehicle) drives on electric power day to day, but carries a small petrol engine that only generates electricity to recharge the battery — never driving the wheels directly. The result is a genuine EV experience with a combined range above 1,000 km and no dependence on public fast-charging. That is exactly why EREV suits markets in the Gulf, Central Asia and Africa where charging infrastructure is still being built out.' },
  { q: 'Which Li Auto models can you source?', a: 'The L-series EREV SUVs: Li L6 (entry mid-size), Li L7 (mid-large), and Li L9 (full-size flagship, with an International Exclusive Version announced for overseas markets). Ask us for current export availability and specs for your target market — we quote per confirmed configuration rather than publishing a fixed price we cannot guarantee.' },
  { q: 'What does a Li Auto export order cost?', a: 'We do not publish a fixed FOB for Li Auto because availability and configuration for export vary — quoting a number we cannot hold would not be honest. Tell us the model, destination country and quantity, and we will come back with a real FOB/CIF quote plus the duty and certification picture for your market.' },
  { q: 'Which markets is Li Auto actually available in?', a: 'Li Auto began overseas rollout in late 2025 (Egypt, Kazakhstan, Azerbaijan) and signed regional dealerships in the UAE and Saudi Arabia in 2026, with further Asia-Pacific and European launches announced. These are publicly reported brand moves; confirm current on-the-ground availability for your specific country with us before planning an order.' },
];
---

<BaseLayout
  title="Li Auto (理想) Export Sourcing | L6 L7 L9 EREV SUVs — EV Auto Pro"
  description="Source Li Auto L6 / L7 / L9 extended-range (EREV) SUVs from China for export. 1,000km+ combined range, built for low-charging markets. EV Auto Pro is an export sourcing partner — request an availability and landed-cost quote."
>
  {/* ============ 1. HERO ============ */}
  <section class="relative bg-ink-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={brand.hero_image} alt="China NEV export sourcing" class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-t from-ink-900 via-ink-900/70 to-ink-900/40"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 lg:py-40">
      <p class="text-brand-500 font-bold text-sm uppercase tracking-widest mb-4">{brand.cn} · Li Auto</p>
      <h1 class="text-4xl lg:text-6xl font-bold text-white leading-tight max-w-4xl mb-6">{brand.tagline}</h1>
      <div class="flex flex-wrap gap-3 mb-10">
        {heroBadges.map(b => (
          <span class="px-4 py-2 bg-white/10 border border-white/20 text-white text-sm rounded-full">{b}</span>
        ))}
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/contact/quote/?brand=Li%20Auto" class="inline-flex items-center px-8 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request a Li Auto Quote
        </a>
        <a href="https://wa.me/8615964467914?text=Hi%2C%20I%27d%20like%20to%20source%20Li%20Auto%20%28L6%2FL7%2FL9%29%20for%20export.%20Can%20you%20share%20availability%20and%20a%20quote%3F" class="inline-flex items-center px-8 py-4 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
      </div>
    </div>
  </section>

  {/* ============ 2. STATS ============ */}
  <section class="py-12 bg-white border-b border-ink-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map(s => (
          <div>
            <div class="text-3xl lg:text-4xl font-bold text-brand-500">{s.num}</div>
            <div class="text-sm font-semibold text-ink-900 mt-1">{s.label}</div>
            <div class="text-xs text-ink-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 3. BRAND STORY ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">About the Brand</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-ink-900 mb-8">Who is Li Auto?</h2>
      {brandStory.split('\n\n').map(p => (
        <p class="text-base text-ink-700 leading-relaxed mb-5">{p}</p>
      ))}
      <a href="https://www.lixiang.com" target="_blank" rel="noopener" class="inline-flex items-center text-sm font-semibold text-brand-500 hover:text-brand-600 mt-2">
        Visit Li Auto official site ↗
      </a>
    </div>
  </section>

  {/* ============ 4. HOW WE SOURCE (honest, replaces authorized-dealer statement) ============ */}
  <section class="py-16 bg-ink-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-[80px_1fr] gap-6 items-start">
        <div class="w-20 h-20 rounded-2xl bg-brand-500 flex items-center justify-center text-4xl">📦</div>
        <div>
          <h3 class="text-2xl font-bold text-ink-900 mb-2">How EV Auto Pro sources Li Auto for export</h3>
          <p class="text-base text-ink-700 leading-relaxed">
            We are an export sourcing partner, not a Li Auto authorized dealer — Li Auto runs its own regional dealer network. For dealers and fleet buyers who want Li Auto L-series units for export, we handle procurement with factory-traceable invoicing, export and destination-market documentation (EAC / GCC / INMETRO), and shipping (RoRo, container, or block train). We quote real availability and landed cost per order rather than publishing a price we cannot guarantee. If a market is one Li Auto already serves directly, we will tell you so plainly.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 5. MODELS (quote-based, no fabricated FOB/photos) ============ */}
  <section id="models" class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">L-Series Lineup</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Li Auto EREV models we can source</h2>
        <p class="text-sm text-ink-500 mt-3 max-w-2xl">All three are extended-range (EREV) SUVs. We quote availability, specs and landed cost per confirmed configuration — request a quote for your market.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {models.map(m => (
          <a href={`/contact/quote/?brand=Li%20Auto&model=${encodeURIComponent(m.name)}`}
             class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-xl p-6 transition-all">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2 py-0.5 bg-ink-100 text-ink-600 text-xs rounded">{m.body}</span>
              <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{m.fuel}</span>
            </div>
            <h3 class="text-xl font-semibold text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{m.name}</h3>
            <p class="text-sm text-ink-600 leading-relaxed mb-4">{m.note}</p>
            <span class="inline-flex items-center text-sm font-semibold text-brand-500">Request a quote →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 6. WHY LI AUTO / EREV ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Why Li Auto</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Why dealers ask us for Li Auto</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {advantages.map(a => (
          <div class="bg-white border border-ink-200 rounded-2xl p-8 hover:border-brand-500 hover:shadow-md transition-all">
            <div class="text-4xl mb-4">{a.icon}</div>
            <h3 class="text-base font-bold text-ink-900 mb-2">{a.title}</h3>
            <p class="text-sm text-ink-600 leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 7. MARKETS (real Li Auto rollout) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Where Li Auto Is Rolling Out</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Li Auto's real overseas markets</h2>
        <p class="text-sm text-ink-500 mt-3 max-w-2xl">Publicly reported brand entries and dealership signings, 2025-2026. Confirm current availability for your specific country with us before ordering.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {markets.map(m => (
          <div class="bg-white border border-ink-200 rounded-xl p-6">
            <div class="text-xs text-ink-500 font-semibold uppercase tracking-wider mb-1">{m.code}</div>
            <h3 class="text-lg font-bold text-ink-900">{m.name}</h3>
            <p class="text-xs text-brand-500 font-semibold mt-2">{m.stat}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 8. FAQ ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Li Auto FAQ</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Common Li Auto questions</h2>
      </div>
      <div class="space-y-3">
        {brandFaqs.map(f => (
          <details class="group bg-white border border-ink-200 rounded-xl overflow-hidden hover:border-brand-500 transition-colors">
            <summary class="flex items-start justify-between gap-4 cursor-pointer p-5 list-none">
              <span class="font-semibold text-base text-ink-900 flex-1 group-open:text-brand-500 transition-colors">{f.q}</span>
              <svg class="flex-shrink-0 w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-sm text-ink-700 leading-relaxed border-t border-ink-100">
              <div class="pt-4">{f.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 9. DARK CTA ============ */}
  <section class="py-24 lg:py-32 bg-ink-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/faq-logistics.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-4">Source Li Auto from China</h2>
      <p class="text-lg text-ink-300 mb-10 max-w-2xl mx-auto">
        L6 / L7 / L9 extended-range SUVs · export procurement, documentation &amp; shipping · real landed-cost quote for your market
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact/quote/?brand=Li%20Auto" class="inline-flex items-center px-8 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
        <a href="https://wa.me/8615964467914?text=Hi%2C%20I%27d%20like%20to%20source%20Li%20Auto%20for%20export%20-%20can%20you%20share%20availability%20and%20a%20quote%3F" class="inline-flex items-center px-8 py-4 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
      </div>
    </div>
  </section>

  {/* Brand JSON-LD Schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Brand',
    name: brand.name,
    alternateName: brand.cn,
    description: brandStory.replace(/\n/g, ' '),
    foundingDate: '2015',
    url: `https://evautopro.com/brands/${brand.slug}/`,
  })} />
</BaseLayout>
