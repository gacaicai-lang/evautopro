---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Single brand master template — Qiyuan
// Reusable for 5 other authorized brands (Deepal/Qiyuan/Geely/VW/Jetour)
// Structure synthesized from cars-in-china/byd + ihka about + Mercedes whitespace aesthetic

const brand = {
  name: 'Changan NEVO',
  cn: '启源',
  slug: 'qiyuan',
  tagline: 'NEV Sub-Brand of Changan Group · Sold Overseas as "NEVO"',
  hero_image: '/images/faq-sourcing.webp',
  logo: '/images/brand-qiyuan.svg',
  authorized_since: 2023,
  founded: 2023,
  annual_production: '100K+ units',
  export_countries: '3+',
  in_stock: '0 units',
};

const heroBadges = [
  'Changan Group NEV Sub-Brand',
  '3 Real Export Models',
  'China domestic name "Qiyuan" (启源)',
];

const stats = [
  { num: '2023', label: 'Brand Launched', sub: 'Chongqing, China' },
  { num: '100K+', label: 'Annual Production', sub: 'units / year' },
  { num: '3', label: 'Confirmed Export Markets', sub: 'Thailand · Uzbekistan · Philippines' },
  { num: 'NEVO', label: 'Overseas Brand Name', sub: 'Same as "Qiyuan" at home' },
];

const brandStory = `Changan Qiyuan (长安启源), launched August 27, 2023, is Changan Auto Group's third NEV sub-brand — after Deepal and Avatr. Product line spans A-series sedans (A05/A06/A07) and Q/E-series SUVs (Q05/Q07/E07). Overseas, the brand sells under a different name entirely: "NEVO" — Changan's own global site, the Thailand launch, and Wikipedia all use NEVO with no "Qiyuan" branding visible to buyers.

NEVO Q05 (all-electric) is confirmed on official retail sale in Thailand (since May 2026) and Uzbekistan; the older plug-in hybrid Q05 generation is sold in the Philippines — these are two different cars sharing one name, not the same vehicle. NEVO A07 (BEV or EREV) has real delivery records to Russia, Kyrgyzstan and Saudi Arabia through export trading channels. NEVO Q07 has no official overseas retail launch yet, but genuine trade-platform inventory and real owner reports exist in Kazakhstan and Russia. EV Auto Pro sources through these established export channels — every unit traceable to factory invoice, zero grey market.`;

const models = [
  { slug: 'nevo-q05', name: 'NEVO Q05', body: 'Compact Electric SUV', fuel: 'BEV', price_min: 18500, stock: 0, ready: true },
  { slug: 'nevo-a07', name: 'NEVO A07', body: 'Mid-Large Sedan', fuel: 'EREV', price_min: 19640, stock: 0, ready: true },
  { slug: 'nevo-q07', name: 'NEVO Q07', body: 'Mid-size PHEV SUV', fuel: 'PHEV', price_min: 15999, stock: 0, ready: false },
  { slug: 'nevo-a05', name: 'NEVO A05', body: 'Compact PHEV Sedan/CUV', fuel: 'PHEV', price_min: 20600, stock: 0, ready: false },
];

const subBrands = [
  { slug: 'changan', name: 'Changan', cn: '长安', desc: 'Parent brand · state-owned auto group', models: 8 },
  { slug: 'deepal', name: 'Deepal', cn: '深蓝', desc: 'Sibling NEV brand · S05/S07/S09 EREV+BEV', models: 5 },
];

const advantages = [
  { icon: '🌏', title: 'Real Export Footprint', desc: 'NEVO Q05 is on official retail sale in Thailand and Uzbekistan today — not a paper launch. 3,000+ orders in the first two weeks in Thailand alone.' },
  { icon: '🏭', title: 'Changan Group R&D', desc: 'Changan Auto Group\'s third NEV sub-brand (after Deepal and Avatr) — shared platform engineering and supply chain with the wider group.' },
  { icon: '🔋', title: 'CATL Battery', desc: 'LFP batteries from CATL on the Q05 and Q07 — same chemistry as Tesla / BMW. Thermal stable, long-life.' },
  { icon: '👨‍👩‍👧', title: 'Family-Focused Design', desc: 'A07 / Q05 / Q07 designed for daily family use — spacious interiors, straightforward tech, low running cost.' },
  { icon: '🌍', title: 'Emerging Market Fit', desc: 'Thailand, Uzbekistan and Philippines launches show the brand\'s real-world fit for price-sensitive, first-time NEV buyers.' },
  { icon: '✅', title: 'Sourced Through Verified Channels', desc: 'We supply via established export trading channels with real delivery track records — every unit traceable to factory invoice.' },
];

const markets = [
  { code: 'TH', name: 'Thailand', stat: 'Official retail, live since May 2026', img: '/images/vehicles/evautopro-nevo-q05-01.webp' },
  { code: 'UZ', name: 'Uzbekistan', stat: 'Official retail, live', img: '/images/vehicles/evautopro-nevo-q05-appearance-01.webp' },
  { code: 'PH', name: 'Philippines', stat: 'Official retail via Inchcape, 14 dealers', img: '/images/vehicles/evautopro-nevo-a07-01.webp' },
  { code: 'KZ', name: 'Kazakhstan', stat: 'Trade-channel supply', img: '/images/vehicles/evautopro-nevo-a07-console-01.webp' },
];

const cases = [
  { headline: 'NEVO Q05: 3,000+ Orders in 2 Weeks, Thailand', client: 'Changan Thailand', stars: 5, quote: 'All-electric Q05 launched officially in Thailand May 2026 with CKD local assembly — a real, fast-moving launch, not a trade-show concept.' },
  { headline: 'CATL LFP Battery Reliability', client: 'Engineering Note', stars: 5, quote: 'NEVO uses CATL LFP cells on Q05/Q07 — same chemistry as Tesla. Proven thermal stability + long cycle life.' },
  { headline: 'Open for Emerging Market Dealers', client: 'Partnership Invitation', stars: 5, quote: 'Real launches in Thailand, Uzbekistan and the Philippines show where this brand is heading next. Contact us for current sourcing options.' },
];

const brandFaqs = [
  { q: 'Is "NEVO" the same as "Qiyuan"?', a: 'Yes — Changan Qiyuan (长安启源) is the China domestic brand name. NEVO is the name used everywhere the brand sells overseas: Changan\'s own global site, the Thailand launch, Wikipedia. Trade platforms often list both names together, e.g. "Qiyuan (NEVO)".' },
  { q: 'Is NEVO officially exported, or China-domestic only?', a: 'Officially exported and on real retail sale: NEVO Q05 in Thailand (since May 2026) and Uzbekistan. NEVO A07 has real delivery records to Russia, Kyrgyzstan and Saudi Arabia. Q07 and A05 are not yet on official overseas retail but are available through established export trading channels.' },
  { q: 'Is the Q05 sold everywhere the same car?', a: 'No — this is important. The Q05 sold in Thailand/Uzbekistan is an all-new electric platform (51.9 kWh battery, 462 km NEDC range). The Q05 sold in the Philippines is an older plug-in hybrid generation with different dimensions and a smaller battery. Confirm which generation you need before ordering.' },
  { q: 'Battery quality at this price point?', a: 'CATL LFP cells on Q05 and Q07 — same supplier used by Tesla, BMW and VW for LFP packs.' },
  { q: 'Warranty + after-sales?', a: 'Standard Changan-group NEV terms apply; confirm current warranty coverage with us at time of order, as this is a newly-exporting brand without a long overseas service track record yet.' },
  { q: 'Best market for NEVO right now?', a: 'Thailand and Uzbekistan have official retail launches today. Philippines has a running dealer network (Inchcape, 14 locations). South Africa, Indonesia, Latin America and Europe are officially announced but not yet live (2026-2027 timelines).' },
  { q: 'How much does Changan NEVO cost in USD for export?', a: 'Our Changan NEVO export catalogue runs from FOB $18,500–$22,450 depending on model, trim and configuration. FOB is the China-port price; your landed cost adds ocean freight, import duty and VAT for your destination. Tell us the model, country and quantity and we\'ll send a full CIF quote.' },
  { q: 'Can I buy Changan NEVO for export if it isn\'t sold new in my country?', a: 'Yes. Changan NEVO may not have official new-car retail in every market, but as a China-side export sourcing company we supply Changan NEVO to dealers and importers across 60+ countries — with factory-traceable invoicing, EAC / GCC / INMETRO documentation, and RoRo, container or block-train shipping. Send us your target model and market for current availability.' },
  { q: 'Who owns Changan NEVO?', a: 'Changan Automobile (长安汽车) — NEVO (domestic name Qiyuan / 启源) is Changan\'s mainstream new-energy sub-brand.' },
];
---

<BaseLayout
  title="Changan NEVO (Qiyuan) Export | EV Auto Pro"
  description="Buy Changan NEVO (启源/Qiyuan) from a China export trading partner. NEVO Q05 electric SUV, A07 sedan, Q07 PHEV SUV. Real launches in Thailand, Uzbekistan, Philippines. FOB from $15,999. MOQ 1."
>
  {/* ============ 1. HERO 全屏大图 ============ */}
  <section class="relative bg-ink-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={brand.hero_image} alt={`${brand.name} brand`} class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-40">
      <nav class="text-xs text-ink-400 mb-6">
        <a href="/" class="hover:text-brand-500">Home</a> ·
        <a href="/brands/" class="hover:text-brand-500">Brands</a> ·
        <span class="text-white">{brand.name}</span>
      </nav>
      <div class="flex items-center gap-4 mb-6">
        <div class="w-20 h-20 lg:w-24 lg:h-24 rounded-2xl bg-white p-3 flex items-center justify-center">
          <img src={brand.logo} alt={brand.name} class="w-full h-full object-contain" />
        </div>
        <div class="inline-flex items-center px-3 py-1 bg-brand-500 text-white text-xs font-bold rounded-full">
          ★ AUTHORIZED EXPORTER
        </div>
      </div>
      <h1 class="text-5xl lg:text-7xl font-bold text-white leading-tight mb-3">{brand.name}</h1>
      <p class="text-2xl text-brand-500 font-semibold mb-3">{brand.cn}</p>
      <p class="text-lg lg:text-xl text-ink-300 max-w-2xl mb-10">{brand.tagline}</p>
      <div class="flex flex-wrap gap-3 mb-10">
        {heroBadges.map(b => (
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 border border-white/20 rounded-full text-sm text-white">
            <span class="text-brand-500">✓</span> {b}
          </span>
        ))}
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="#models" class="btn-primary">Browse {models.length} Models</a>
        <a href="/contact/quote/?brand=qiyuan" class="inline-flex items-center px-6 py-3 bg-white text-ink-900 hover:bg-ink-100 font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
      </div>
    </div>
  </section>

  {/* ============ 2. STATS Strip ============ */}
  <section class="py-16 lg:py-20 border-b border-ink-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        {stats.map(s => (
          <div class="text-center lg:text-left">
            <div class="text-4xl lg:text-5xl font-bold text-brand-500 mb-2">{s.num}</div>
            <div class="text-base font-semibold text-ink-900">{s.label}</div>
            <div class="text-xs text-ink-500 mt-1">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 3. BRAND STORY 双列 (奔驰式大留白) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_1.5fr] gap-16 items-start">
        <div class="sticky top-24">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-3">The Brand</p>
          <h2 class="text-4xl lg:text-5xl font-bold text-ink-900 leading-tight">{brand.founded} — the story so far</h2>
        </div>
        <div class="space-y-6 text-base lg:text-lg text-ink-700 leading-relaxed">
          {brandStory.split('\n\n').map(para => <p>{para}</p>)}
          <a href="https://www.qiyuan.com.cn" target="_blank" rel="noopener" class="inline-flex items-center text-sm font-semibold text-brand-500 hover:text-brand-600 mt-4">
            Visit Qiyuan official site ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 4. AUTHORIZED DEALER STATEMENT ============ */}
  <section class="py-16 bg-ink-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-[80px_1fr] gap-6 items-start">
        <div class="w-20 h-20 rounded-2xl bg-brand-500 flex items-center justify-center text-4xl">★</div>
        <div>
          <h3 class="text-2xl font-bold text-ink-900 mb-2">EV Auto Pro is an authorized Qiyuan exporter</h3>
          <p class="text-base text-ink-700 leading-relaxed">
            We hold a signed dealer MoU with Qiyuan Automobile since <strong>{brand.authorized_since}</strong>. Every unit shipped is sourced directly from the factory — no grey market, no rebadged units. Factory invoice provided for every export order on request. Customs and EAC/GCC/INMETRO documentation handled in-house.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ============ 5. MODELS GRID (核心) ============ */}
  <section id="models" class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12 gap-4">
        <div>
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Available Models</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">{models.length} Qiyuan models for export</h2>
        </div>
        <a href="/cars/?brand=qiyuan" class="text-sm font-semibold text-brand-500 hover:text-brand-600">All Qiyuan models →</a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {models.map(m => (
          <a href={m.ready ? `/cars/${m.slug}/` : '/contact/quote/?model=' + m.slug}
             class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-lg rounded-xl overflow-hidden transition-all">
            <div class="aspect-[16/10] bg-ink-100 overflow-hidden flex items-center justify-center">
              {['nevo-q05','nevo-a07'].includes(m.slug)
                ? <img src={`/images/vehicles/evautopro-${m.slug}-01.webp`} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
                : <img src={brand.logo} alt={`${m.name} — photo on request`} class="w-16 h-16 object-contain opacity-40" loading="lazy" />}
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-ink-100 text-ink-600 text-xs rounded">{m.body}</span>
                <span class="px-2 py-0.5 bg-brand-50 text-brand-700 text-xs rounded">{m.fuel}</span>
              </div>
              <h3 class="text-base font-semibold text-ink-900 group-hover:text-brand-500 transition-colors mb-2">{m.name}</h3>
              <div class="flex items-end justify-between">
                <div>
                  <div class="text-xs text-ink-500">From FOB</div>
                  <div class="text-lg font-bold text-ink-900">${m.price_min.toLocaleString()}</div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-ink-500">{m.stock > 0 ? 'In stock' : 'Availability'}</div>
                  <div class="text-sm font-semibold text-ink-900">{m.stock > 0 ? `${m.stock} units` : 'Made to Order'}</div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 6. SUB-BRAND FAMILY (Qiyuan 旗下子品牌) ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Qiyuan Family</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Sub-brands under Qiyuan group</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {subBrands.map(b => (
          <a href={`/contact/quote/?brand=${encodeURIComponent(b.name)}`} class="group flex items-start gap-5 bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-2xl p-8 transition-all">
            <div class="flex-shrink-0 w-20 h-20 rounded-xl bg-ink-100 p-3">
              <img src={`/images/brand-${b.slug}.svg`} alt={b.name} class="w-full h-full object-contain" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 group-hover:text-brand-500 transition-colors">{b.name}</h3>
              <p class="text-sm text-brand-500 font-semibold mb-2">{b.cn}</p>
              <p class="text-sm text-ink-600 leading-relaxed mb-3">{b.desc}</p>
              <div class="text-xs text-ink-500">{b.models} models · authorized via Qiyuan MoU</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 7. WHY CHANGAN FROM EV AUTO PRO (6 卖点) ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Why Choose Qiyuan</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">6 reasons dealers pick Qiyuan via EV Auto Pro</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {advantages.map(a => (
          <div class="bg-white border border-ink-200 rounded-2xl p-8 hover:border-brand-500 hover:shadow-md transition-all">
            <div class="text-4xl mb-4">{a.icon}</div>
            <h3 class="text-base font-bold text-ink-900 mb-2">{a.title}</h3>
            <p class="text-sm text-ink-600 leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 8. BEST-SELLING MARKETS ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Where Qiyuan Wins</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Top markets for Qiyuan export</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {markets.map(m => (
          <a href={`/markets/${m.name.toLowerCase()}/`} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl overflow-hidden transition-all">
            <div class="aspect-[4/3] bg-ink-100 overflow-hidden">
              <img src={m.img} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
            <div class="p-5">
              <div class="text-xs text-ink-500 font-semibold uppercase tracking-wider mb-1">{m.code}</div>
              <h3 class="text-lg font-bold text-ink-900 group-hover:text-brand-500 transition-colors">{m.name}</h3>
              <p class="text-xs text-brand-500 font-semibold mt-2">{m.stat}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 9. CASES & SHIPMENT RECORDS ============ */}
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Recent Qiyuan Shipments</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Your Qiyuan has arrived</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {cases.map((c, i) => (
          <div class="bg-white border border-ink-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
            <div class="aspect-[16/10] bg-ink-100 overflow-hidden">
              <img src={`/images/testimonial-${i + 1}.svg`} alt={c.client} class="w-full h-full object-cover" />
            </div>
            <div class="p-6">
              <div class="flex gap-0.5 mb-3">
                {Array(c.stars).fill(0).map(() => <span class="text-yellow-500 text-sm">★</span>)}
              </div>
              <h3 class="text-base font-bold text-ink-900 mb-3 leading-snug">{c.headline}</h3>
              <p class="text-sm text-ink-700 italic mb-4 leading-relaxed">"{c.quote}"</p>
              <div class="pt-3 border-t border-ink-200 text-sm font-semibold text-ink-900">{c.client}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 10. BRAND-SPECIFIC FAQ ============ */}
  <section class="py-24 lg:py-32 bg-ink-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Qiyuan FAQ</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-ink-900">Common Qiyuan questions</h2>
      </div>
      <div class="space-y-3">
        {brandFaqs.map(f => (
          <details class="group bg-white border border-ink-200 rounded-xl overflow-hidden hover:border-brand-500 transition-colors">
            <summary class="flex items-start justify-between gap-4 cursor-pointer p-5 list-none">
              <span class="font-semibold text-base text-ink-900 flex-1 group-open:text-brand-500 transition-colors">{f.q}</span>
              <svg class="flex-shrink-0 w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-sm text-ink-700 leading-relaxed border-t border-ink-100">
              <div class="pt-4">{f.a}</div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 11. DARK CTA ============ */}
  <section class="py-24 lg:py-32 bg-ink-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/faq-logistics.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-4">Import Qiyuan from China</h2>
      <p class="text-lg text-ink-300 mb-10 max-w-2xl mx-auto">
        {models.length} models in stock · FOB from ${Math.min(...models.map(m => m.price_min)).toLocaleString()} · 24h quote · 60+ countries shipped
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact/quote/?brand=qiyuan" class="inline-flex items-center px-8 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors">
          Request a Quote
        </a>
        <a href="https://wa.me/8615964467914?text=Qiyuan%20inquiry" class="inline-flex items-center px-8 py-4 bg-white hover:bg-ink-100 text-ink-900 font-semibold rounded-lg transition-colors">
          💬 WhatsApp Cai
        </a>
        <a href="/contact/quote/?brand=qiyuan" class="inline-flex items-center px-8 py-4 border-2 border-white text-white hover:bg-white hover:text-ink-900 font-semibold rounded-lg transition-colors">
          📕 Catalogue PDF
        </a>
      </div>
    </div>
  </section>

  {/* Brand JSON-LD Schema (SEO) */}
