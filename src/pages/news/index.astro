---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WhatsAppField from '../../components/WhatsAppField.astro';
import { news } from '../../data/news';

// Data-driven listing: every article in news.ts appears here automatically,
// so no article can become orphaned. Categories are real content types
// (guides / market / comparisons / industry), not just "news".

const all = Object.values(news)
  .map(a => ({ ...a, dateOnly: a.date.slice(0, 10) }))
  .sort((x, y) => (x.date < y.date ? 1 : -1));

const featuredArticle = all[0];
const carouselItems = all.slice(1, 4);
const articles = all;
const sidebarArticles = all.filter(a => a.category === 'guide' || a.category === 'market').slice(0, 6);

const tabs = [
  { key: 'all', label: 'All Articles' },
  { key: 'guide', label: 'Buyer Guides' },
  { key: 'market', label: 'Market & Import' },
  { key: 'product', label: 'Model Comparisons' },
  { key: 'industry', label: 'Industry & Policy' },
];
---

<BaseLayout
  title="News & Insights | China NEV Export Guides, Model Comparisons, Market Analysis"
  description="Buyer guides, country import guides, model comparisons and industry analysis for dealers importing new energy vehicles from China. By EV Auto Pro."
>
  {/* ============ 1. Featured + Carousel ============ */}
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-ink-900 mb-2">News & Insights</h1>
      <p class="text-sm text-ink-500 mb-8">Buyer guides, import cost breakdowns, model comparisons and market analysis — written from real export orders, not press releases.</p>

      {/* Featured big article */}
      <a href={`/news/${featuredArticle.slug}/`} class="block relative rounded-2xl overflow-hidden mb-8 group">
        <div class="aspect-[21/9] bg-ink-100 relative">
          <img src={featuredArticle.hero} alt={featuredArticle.title} class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-900/90 via-ink-900/40 to-transparent"></div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-10 text-white">
          <span class="inline-block px-3 py-1 bg-brand-500 text-white text-xs font-semibold rounded-full mb-3">{featuredArticle.categoryLabel}</span>
          <h2 class="text-2xl lg:text-3xl font-bold mb-3 max-w-3xl">{featuredArticle.title}</h2>
          <p class="text-sm lg:text-base text-white/90 mb-5 max-w-2xl hidden sm:block">{featuredArticle.excerpt}</p>
          <span class="inline-flex items-center px-5 py-2 bg-white text-ink-900 hover:bg-ink-100 text-sm font-semibold rounded-full transition-colors">
            Read now
          </span>
        </div>
      </a>

      {/* Next 3 most recent */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {carouselItems.map(c => (
          <a href={`/news/${c.slug}/`} class="group flex gap-3 bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl p-3 transition-all">
            <div class="flex-shrink-0 w-28 aspect-square bg-ink-100 rounded overflow-hidden">
              <img src={c.hero} alt={c.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[10px] text-brand-500 uppercase font-semibold mb-1">{c.categoryLabel}</div>
              <h3 class="text-sm font-semibold text-ink-900 group-hover:text-brand-500 line-clamp-2 mb-1">{c.title}</h3>
              <p class="text-xs text-ink-500 line-clamp-2">{c.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============ 2. All Articles (real category filter) ============ */}
  <section class="py-12 bg-ink-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Tabs */}
      <div class="flex flex-wrap gap-2 mb-8">
        {tabs.map((t, i) => (
          <button data-tab={t.key} class:list={['px-4 py-2 text-sm font-semibold rounded-md transition-colors', i === 0 ? 'bg-brand-500 text-white' : 'bg-white border border-ink-200 text-ink-700 hover:border-brand-500']}>
            {t.label}
          </button>
        ))}
      </div>

      <div class="grid lg:grid-cols-[1fr_320px] gap-8">
        {/* Left: article grid */}
        <div>
          <div class="grid sm:grid-cols-2 gap-6" id="article-grid">
            {articles.map(a => (
              <a href={`/news/${a.slug}/`} data-cat={a.category} class="group block bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl overflow-hidden transition-all">
                <div class="aspect-[16/10] bg-ink-100 overflow-hidden">
                  <img src={a.hero} alt={a.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="p-5">
                  <div class="text-[10px] text-brand-500 uppercase font-semibold mb-2">{a.categoryLabel}</div>
                  <h3 class="text-base font-semibold text-ink-900 group-hover:text-brand-500 transition-colors mb-2 leading-snug">{a.title}</h3>
                  <div class="text-xs text-ink-500">{a.dateOnly} · {a.readMin} min read</div>
                </div>
              </a>
            ))}
          </div>
          <p id="empty-note" class="hidden text-sm text-ink-500 text-center py-10">No articles in this category yet.</p>
        </div>

        {/* Right: Sidebar */}
        <aside>
          <h3 class="text-base font-bold text-ink-900 mb-5">Guide to Importing Cars from China</h3>
          <div class="space-y-4">
            {sidebarArticles.map(a => (
              <a href={`/news/${a.slug}/`} class="group flex gap-3">
                <div class="flex-shrink-0 w-20 aspect-square bg-ink-100 rounded overflow-hidden">
                  <img src={a.hero} alt={a.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-[10px] text-ink-500 uppercase font-semibold mb-1">{a.categoryLabel}</div>
                  <h4 class="text-sm font-semibold text-ink-900 group-hover:text-brand-500 line-clamp-3 leading-tight mb-1">{a.title}</h4>
                  <div class="text-xs text-ink-500">{a.dateOnly}</div>
                </div>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  {/* ============ 3. Bottom Banner (Get a Quote) ============ */}
  <section class="py-16 bg-ink-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img src="/images/faq-logistics.webp" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="text-brand-500 font-bold text-lg mb-2">EV AUTO PRO</div>
        <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-3">
          Import Cars from China
        </h2>
        <p class="text-base text-ink-300 mb-6">
          95% Models & Full Certified · 6 Authorized OEMs · 60+ Countries
        </p>
      </div>
      <div class="bg-white/95 rounded-xl p-6">
        <h3 class="text-xl font-bold text-ink-900 mb-4">Get a quote</h3>
        <form id="news-quote" class="space-y-3" novalidate>
          <input type="text" name="honeypot" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" />
          <div class="grid grid-cols-2 gap-3">
            <input type="text" name="name" required placeholder="*Name" class="px-3 py-2 border border-ink-300 rounded text-sm focus:border-brand-500 focus:outline-none" />
            <input type="text" name="country" placeholder="Country" class="px-3 py-2 border border-ink-300 rounded text-sm focus:border-brand-500 focus:outline-none" />
          </div>
          <WhatsAppField required
            fieldClass="px-3 py-2 border border-ink-300 rounded text-sm focus:border-brand-500 focus:outline-none bg-white" />
          <div class="grid grid-cols-2 gap-3">
            <input type="text" name="buyer_type" placeholder="Dealer or individual" class="px-3 py-2 border border-ink-300 rounded text-sm focus:border-brand-500 focus:outline-none" />
            <input type="text" name="car_brand" placeholder="Car Brand" class="px-3 py-2 border border-ink-300 rounded text-sm focus:border-brand-500 focus:outline-none" />
          </div>
          <input type="email" name="email" required placeholder="*Email" class="w-full px-3 py-2 border border-ink-300 rounded text-sm focus:border-brand-500 focus:outline-none" />
          <button type="submit" class="w-full px-6 py-2.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded transition-colors text-sm">
            Submit
          </button>
          <div id="news-status" class="text-xs text-center hidden"></div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Real category filter — shows/hides cards by data-cat
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const cards = document.querySelectorAll<HTMLAnchorElement>('#article-grid [data-cat]');
  const emptyNote = document.getElementById('empty-note');
  tabs.forEach(t => {
    t.addEventListener('click', () => {
      tabs.forEach(x => {
        x.classList.remove('bg-brand-500', 'text-white');
        x.classList.add('bg-white', 'border', 'border-ink-200', 'text-ink-700', 'hover:border-brand-500');
      });
      t.classList.remove('bg-white', 'border', 'border-ink-200', 'text-ink-700', 'hover:border-brand-500');
      t.classList.add('bg-brand-500', 'text-white');

      const key = t.dataset.tab;
      let visible = 0;
      cards.forEach(c => {
        const show = key === 'all' || c.dataset.cat === key;
        c.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      emptyNote?.classList.toggle('hidden', visible > 0);
    });
  });

  // Quote form
  const f = document.getElementById('news-quote') as HTMLFormElement | null;
  const st = document.getElementById('news-status') as HTMLDivElement | null;
  f?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!st) return;
    st.classList.remove('hidden', 'text-green-600', 'text-red-600');
    st.classList.add('text-ink-500');
    st.textContent = 'Sending…';
    try {
      const r = await fetch('/api/inquiry', { method: 'POST', body: new FormData(f) });
      const d = await r.json();
      if (r.ok) {
        st.classList.add('text-green-600');
        st.textContent = '✓ ' + (d.message ?? 'Thank you!');
        f.reset();
      } else {
        st.classList.add('text-red-600');
        st.textContent = '⚠ ' + (d.error ?? 'Try again');
      }
    } catch {
      st.classList.add('text-red-600');
      st.textContent = '⚠ Network error';
    }
  });
</script>
