---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { news, newsSlugs } from '../../data/news';

export function getStaticPaths() {
  return newsSlugs.map(slug => ({ params: { slug }, props: { slug } }));
}

const { slug } = Astro.props;
const article = news[slug as keyof typeof news];

const relatedArticles = (article.related || [])
  .map(s => news[s as keyof typeof news])
  .filter(Boolean);

// ---------------------------------------------------------------------------
// Minimal block-level markdown parser for article.body. Grew from a
// line-by-line pass that only handled headings/bullets/bold — pipe-table
// lines rendered as raw monospace text and [links](url) never became <a>
// tags. Both are now real blocks; still not a full markdown lib (no nested
// lists, no code fences) because nothing in this site's articles needs them.
// ---------------------------------------------------------------------------
type InlinePart = { type: 'text' | 'strong' | 'a'; content: string; href?: string };
type Block =
  | { type: 'h2' | 'h3' | 'p' | 'bold'; text: string }
  | { type: 'ul'; items: string[] }
  | { type: 'table'; headers: string[]; rows: string[][] }
  | { type: 'image'; alt: string; src: string };

function parseInline(text: string): InlinePart[] {
  return text
    .split(/(\*\*[^*]+\*\*|\[[^\]]+\]\([^)]+\))/g)
    .filter(part => part !== '')
    .map(part => {
      if (part.startsWith('**') && part.endsWith('**')) {
        return { type: 'strong', content: part.slice(2, -2) };
      }
      const link = part.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
      if (link) return { type: 'a', content: link[1], href: link[2] };
      return { type: 'text', content: part };
    });
}

function tableCells(line: string): string[] {
  return line.trim().replace(/^\|/, '').replace(/\|$/, '').split('|').map(c => c.trim());
}

function parseBody(body: string): Block[] {
  const lines = body.split('\n');
  const blocks: Block[] = [];
  let i = 0;
  while (i < lines.length) {
    const line = lines[i];

    if (line.trim() === '') { i++; continue; }
    if (line.startsWith('## ')) { blocks.push({ type: 'h2', text: line.slice(3) }); i++; continue; }
    if (line.startsWith('### ')) { blocks.push({ type: 'h3', text: line.slice(4) }); i++; continue; }

    const img = line.match(/^!\[([^\]]*)\]\(([^)]+)\)$/);
    if (img) { blocks.push({ type: 'image', alt: img[1], src: img[2] }); i++; continue; }

    if (line.trim().startsWith('|')) {
      const tableLines: string[] = [];
      while (i < lines.length && lines[i].trim().startsWith('|')) { tableLines.push(lines[i]); i++; }
      const headers = tableCells(tableLines[0]);
      const isSeparator = /^[-:\s|]+$/.test(tableLines[1] ?? '');
      const rows = (isSeparator ? tableLines.slice(2) : tableLines.slice(1)).map(tableCells);
      blocks.push({ type: 'table', headers, rows });
      continue;
    }

    if (line.startsWith('- ')) {
      const items: string[] = [];
      while (i < lines.length && lines[i].startsWith('- ')) { items.push(lines[i].slice(2)); i++; }
      blocks.push({ type: 'ul', items });
      continue;
    }

    if (line.startsWith('**') && line.endsWith('**') && line.length > 3) {
      blocks.push({ type: 'bold', text: line.slice(2, -2) });
      i++; continue;
    }

    blocks.push({ type: 'p', text: line });
    i++;
  }
  return blocks;
}

const bodyBlocks = parseBody(article.body);
---

<BaseLayout
  title={`${article.title} | EV Auto Pro News`}
  description={article.excerpt}
>
  {/* Hero */}
  <section class="relative h-72 lg:h-96 overflow-hidden">
    <div class="absolute inset-0 bg-ink-900">
      <img src={article.hero} alt={article.title} class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-end pb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="px-3 py-1 bg-brand-500 text-white text-xs font-bold rounded-full uppercase tracking-wider">{article.categoryLabel}</span>
          <span class="text-xs text-ink-300">{article.date} · {article.readMin} min read</span>
        </div>
        <h1 class="text-3xl lg:text-5xl font-bold text-white leading-tight">{article.title}</h1>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <nav class="text-xs text-ink-500">
      <a href="/" class="hover:text-brand-500">Home</a> ·
      <a href="/news/" class="hover:text-brand-500">News</a> ·
      <span class="text-ink-900">{article.title.slice(0, 50)}...</span>
    </nav>
  </div>

  {/* Body */}
  <section class="py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-ink-600 leading-relaxed mb-8 italic">{article.excerpt}</p>

      {/* Author byline — E-E-A-T signal */}
      <a href="/about/founder/" class="flex items-center gap-3 mb-10 pb-8 border-b border-ink-200 group no-underline">
        <div class="w-11 h-11 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold text-lg flex-shrink-0">C</div>
        <div class="text-sm leading-tight">
          <div class="text-ink-900"><span class="text-ink-500">By</span> <span class="font-bold group-hover:text-brand-500 transition-colors">Cai</span> · Founder &amp; Trade Director, EV Auto Pro</div>
          <div class="text-ink-500 mt-0.5">15 years cross-border trade · 6 authorized OEM partnerships · reviewed for {article.date.slice(0, 4)}</div>
        </div>
      </a>

      <div class="prose-content space-y-5 text-base text-ink-700 leading-relaxed">
        {bodyBlocks.map(block => {
          const inline = (parts: InlinePart[]) => parts.map(part => {
            if (part.type === 'strong') return <strong>{part.content}</strong>;
            if (part.type === 'a') {
              const external = /^https?:\/\//.test(part.href ?? '');
              return external
                ? <a href={part.href} target="_blank" rel="noopener nofollow" class="text-brand-500 hover:underline font-medium">{part.content}</a>
                : <a href={part.href} class="text-brand-500 hover:underline font-medium">{part.content}</a>;
            }
            return part.content;
          });

          if (block.type === 'h2') return <h2 class="text-2xl lg:text-3xl font-bold text-ink-900 mt-12 mb-4">{block.text}</h2>;
          if (block.type === 'h3') return <h3 class="text-xl font-bold text-ink-900 mt-8 mb-3">{block.text}</h3>;
          if (block.type === 'bold') return <p class="font-bold text-ink-900">{block.text}</p>;
          if (block.type === 'image') return (
            <img src={block.src} alt={block.alt} class="w-full rounded-xl border border-ink-200 my-2" loading="lazy" />
          );
          if (block.type === 'ul') return (
            <ul class="space-y-2 my-2">
              {block.items.map(item => (
                <li class="ml-6 text-base text-ink-700 list-disc">{inline(parseInline(item))}</li>
              ))}
            </ul>
          );
          if (block.type === 'table') return (
            <div class="overflow-x-auto my-4 -mx-4 sm:mx-0">
              <table class="w-full min-w-[560px] sm:min-w-0 text-sm border-collapse">
                <thead>
                  <tr class="border-b-2 border-ink-200">
                    {block.headers.map(h => (
                      <th class="text-left py-2.5 px-3 text-xs font-bold text-ink-500 uppercase tracking-wider">{inline(parseInline(h))}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {block.rows.map(row => (
                    <tr class="border-b border-ink-100">
                      {row.map(cell => (
                        <td class="py-2.5 px-3 text-ink-700">{inline(parseInline(cell))}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          );
          return <p>{inline(parseInline(block.text))}</p>;
        })}
      </div>
    </div>
  </section>

  {/* FAQ */}
  {article.faqs && article.faqs.length > 0 && (
    <section class="py-16 bg-ink-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold text-brand-500 uppercase tracking-wider mb-2">Article FAQ</p>
          <h2 class="text-2xl lg:text-3xl font-bold text-ink-900">Common questions</h2>
        </div>
        <div class="space-y-3">
          {article.faqs.map(f => (
            <details class="group bg-white border border-ink-200 rounded-xl overflow-hidden hover:border-brand-500 transition-colors">
              <summary class="flex items-start justify-between gap-4 cursor-pointer p-5 list-none">
                <span class="font-semibold text-base text-ink-900 flex-1 group-open:text-brand-500 transition-colors">{f.q}</span>
                <svg class="flex-shrink-0 w-5 h-5 text-ink-500 group-open:rotate-180 transition-transform mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="px-5 pb-5 pt-1 text-sm text-ink-700 leading-relaxed border-t border-ink-100">
                <div class="pt-4">{f.a}</div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Related Articles */}
  {relatedArticles.length > 0 && (
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-ink-900 mb-8">Related Articles</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {relatedArticles.map(r => (
            <a href={`/news/${r.slug}/`} class="group flex gap-4 bg-white border border-ink-200 hover:border-brand-500 hover:shadow-md rounded-xl p-4 transition-all">
              <div class="flex-shrink-0 w-28 aspect-square bg-ink-100 rounded overflow-hidden">
                <img src={r.hero} alt={r.title} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="flex-1 min-w-0">
                <span class="text-[10px] text-brand-500 font-semibold uppercase">{r.categoryLabel}</span>
                <h3 class="text-sm font-semibold text-ink-900 group-hover:text-brand-500 line-clamp-2 leading-snug mt-1">{r.title}</h3>
                <p class="text-xs text-ink-500 mt-2">{r.date} · {r.readMin} min</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* CTA */}
  <section class="py-16 bg-brand-500">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-3">Ready to import Chinese cars?</h2>
      <p class="text-base text-white/90 mb-6">Get FOB + CIF quote within 24h.</p>
      <a href="/contact/quote/" class="inline-flex items-center px-8 py-3 bg-white text-brand-500 hover:bg-ink-100 font-semibold rounded-lg transition-colors">
        Request a Quote
      </a>
    </div>
  </section>

  {/* Article Schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'NewsArticle',
    headline: article.title,
    datePublished: article.date,
    dateModified: article.date,
    description: article.excerpt,
    image: new URL(article.hero, 'https://evautopro.com').href,
    author: {
      '@type': 'Person',
      name: 'Cai',
      jobTitle: 'Founder & Trade Director',
      worksFor: { '@type': 'Organization', name: 'EV Auto Pro' },
      url: 'https://evautopro.com/about/founder/',
      description: '15 years cross-border trade experience; 6 authorized Chinese OEM dealer partnerships.',
    },
    publisher: {
      '@type': 'Organization', name: 'EV Auto Pro', url: 'https://evautopro.com',
      logo: { '@type': 'ImageObject', url: 'https://evautopro.com/og-default.jpg' },
    },
  })} />

  {article.faqs && article.faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org', '@type': 'FAQPage',
      mainEntity: article.faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
    })} />
  )}
</BaseLayout>
